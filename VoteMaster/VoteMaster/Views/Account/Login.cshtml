@model string
@{
    Layout = "_Layout";
}
<div class="d-flex justify-content-center align-items-center">
  <div class="card p-4 shadow-sm" style="max-width:420px;width:100%;border-radius:1rem;">
    <div class="text-center mb-4">
      <h4 class="mb-0 fw-700">Welcome back</h4>
      <p class="text-muted small mb-0">Sign in to continue to VoteMaster</p>
    </div>

    @if (ViewBag.Error != null)
    {
      <div class="alert alert-danger">@ViewBag.Error</div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]</div>
    }

    <form method="post">
      @Html.AntiForgeryToken()
      <div class="mb-3">
        <label class="form-label fw-semibold">Username</label>
        <input class="form-control" name="username" required autocomplete="username" />
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Password</label>
        <input class="form-control" type="password" name="password" required autocomplete="current-password" />
      </div>
      <input type="hidden" name="returnUrl" value="@Model" />
      <button class="btn btn-primary w-100 mb-3">
        <i class="bi bi-box-arrow-in-right me-2"></i>Login
      </button>
    </form>

    <div class="d-flex align-items-center gap-2 mb-3">
      <hr class="flex-grow-1 m-0" />
      <span class="text-muted small">or</span>
      <hr class="flex-grow-1 m-0" />
    </div>

    <a href="/Account/GoogleLogin?returnUrl=@Model" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2">
      <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
        <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
        <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
        <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
        <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        <path fill="none" d="M0 0h48v48H0z"/>
      </svg>
      Continue with Google
    </a>

    <p class="text-center text-muted small mt-3 mb-0">
      No account? <a href="/Account/GoogleLogin" class="text-decoration-none fw-semibold" style="color:#14b8a6;">Register with Google</a>
    </p>
  </div>
</div>
