@model string
@{
    Layout = "_Layout";
}

<style>
    .role-selector { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; }
    .role-btn {
        flex: 1; padding: 0.75rem; border-radius: 0.75rem; border: 2px solid var(--vm-border);
        background: white; cursor: pointer; text-align: center; transition: all 0.15s;
        color: var(--vm-text-secondary); font-weight: 600; font-size: 0.9rem;
    }
    .role-btn:hover { border-color: #14b8a6; color: #14b8a6; }
    .role-btn.active { border-color: #14b8a6; background: #f0fdfa; color: #0d9488; }
    .role-btn i { display: block; font-size: 1.5rem; margin-bottom: 0.25rem; }
    .google-btn {
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        width: 100%; padding: 0.5rem 1rem; border-radius: 0.5rem;
        border: 1px solid var(--vm-border); background: white;
        color: var(--vm-text-primary); font-size: 0.875rem; font-weight: 500;
        text-decoration: none; transition: background 0.15s;
    }
    .google-btn:hover { background: #f8fafc; color: var(--vm-text-primary); }
    .or-divider { display: flex; align-items: center; gap: 0.5rem; margin: 1rem 0; color: #94a3b8; font-size: 0.8rem; }
    .or-divider hr { flex: 1; margin: 0; border-color: var(--vm-border); }
</style>

<div class="d-flex justify-content-center align-items-center">
  <div class="card p-4 shadow-sm" style="max-width:420px;width:100%;border-radius:1rem;">
    <div class="text-center mb-4">
      <h4 class="mb-0 fw-700">Welcome back</h4>
      <p class="text-muted small mb-0">Sign in to continue to VoteMaster</p>
    </div>

    @if (ViewBag.Error != null)
    {
      <div class="alert alert-danger">@ViewBag.Error</div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]</div>
    }

    <div class="role-selector">
      <button type="button" class="role-btn active" id="btn-voter" onclick="selectRole('voter')">
        <i class="bi bi-person-check"></i>Voter
      </button>
      <button type="button" class="role-btn" id="btn-admin" onclick="selectRole('admin')">
        <i class="bi bi-shield-lock"></i>Admin
      </button>
    </div>

    @* ── VOTER PANEL ── *@
    <div id="voter-fields">
      <p class="text-muted small mb-3">
        <i class="bi bi-info-circle me-1"></i>Your account is set up by an admin. Enter your credentials to sign in.
      </p>
      <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="intent" value="voter" />
        <div class="mb-3">
          <label class="form-label fw-semibold">Username</label>
          <input class="form-control" name="username" required autocomplete="username" />
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Password</label>
          <input class="form-control" type="password" name="password" required autocomplete="current-password" />
        </div>
        <input type="hidden" name="returnUrl" value="@Model" />
        <button class="btn btn-primary w-100">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
      </form>
    </div>

    @* ── ADMIN PANEL ── *@
    <div id="admin-fields" style="display:none">
      <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="intent" value="admin" />
        <div class="mb-3">
          <label class="form-label fw-semibold">Username</label>
          <input class="form-control" name="username" required autocomplete="username" />
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Password</label>
          <input class="form-control" type="password" name="password" required autocomplete="current-password" />
        </div>
        <input type="hidden" name="returnUrl" value="@Model" />
        <button class="btn btn-primary w-100">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
      </form>
      <div class="or-divider"><hr />or<hr /></div>
      <a href="/Account/GoogleLogin?intent=admin&returnUrl=@Model" class="google-btn">
        <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          <path fill="none" d="M0 0h48v48H0z"/>
        </svg>
        Continue with Google
      </a>
    </div>

  </div>
</div>

@section Scripts {
<script>
  function selectRole(role) {
    const isVoter = role === 'voter';
    document.getElementById('voter-fields').style.display = isVoter ? '' : 'none';
    document.getElementById('admin-fields').style.display = isVoter ? 'none' : '';
    document.getElementById('btn-voter').classList.toggle('active', isVoter);
    document.getElementById('btn-admin').classList.toggle('active', !isVoter);
  }
  // Restore tab if server returned an error on a specific tab
  selectRole('@(ViewBag.Intent ?? "voter")');
</script>
}
