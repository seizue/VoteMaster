@{
    var user = Context.User.Identity;
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>VoteMaster</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-light fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <span class="brand-icon rounded-circle d-inline-flex align-items-center justify-content-center me-2"><i class="bi bi-check2-square fs-5"></i></span>
                <span class="fs-5 fw-semibold" style="color: var(--vm-text-primary);">VoteMaster</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-3 me-auto mb-2 mb-lg-0">
                    @if (!(user?.IsAuthenticated ?? false))
                    {
                        <li class="nav-item"><a class="nav-link" id="nav-home" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" id="nav-features" href="/#features">Features</a></li>
                        <li class="nav-item"><a class="nav-link @(currentPath.StartsWith("/account/login") ? "active" : "")" href="/#get-started">Get Started</a></li>
                    }
                    else if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item"><a class="nav-link @(currentPath.StartsWith("/admin/dashboard") ? "active" : "")" href="/Admin/Dashboard">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link @(currentPath.StartsWith("/admin/polls") ? "active" : "")" href="/Admin/Polls">Polls</a></li>
                        <li class="nav-item"><a class="nav-link @(currentPath.StartsWith("/admin/users") ? "active" : "")" href="/Admin/Users">Users</a></li>
                        <li class="nav-item"><a class="nav-link @(currentPath.StartsWith("/admin/analytics") ? "active" : "")" href="/Admin/Analytics">Analytics</a></li>
                        <li class="nav-item"><a class="nav-link @(currentPath.StartsWith("/admin/templates") ? "active" : "")" href="/Admin/Templates">Templates</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link @(currentPath == "/client/home" || currentPath == "/client/home/index" || currentPath == "/client" ? "active" : "")" href="/Client/Home">Home</a></li>
                        <li class="nav-item"><a class="nav-link @(currentPath.Contains("/client/home/pastpolls") ? "active" : "")" href="/Client/Home/PastPolls">Past Polls</a></li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-2">
                    @if (user?.IsAuthenticated ?? false)
                    {
                        <div class="small d-none d-lg-block" style="color: var(--vm-text-secondary);">Signed in as <strong style="color: var(--vm-text-primary);">@Context.User.Identity?.Name</strong></div>
                        <a class="btn btn-sm" href="/Account/Logout" style="background: var(--vm-bg); color: var(--vm-text-primary); border: 1px solid var(--vm-border);"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" href="/Account/Login"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="container navbar-offset my-5">
        @RenderBody()
    </main>

    <!-- Toast Container for Notifications -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div id="pollNotificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="bi bi-bell-fill me-2 text-primary"></i>
                <strong class="me-auto">Poll Notification</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toastMessage">
                <!-- Message will be inserted here -->
            </div>
        </div>
    </div>

    <footer class="site-footer">
        <!-- Decorative top accent bar -->
        <div class="footer-accent-bar"></div>

        <div class="container">

            @if (user?.IsAuthenticated ?? false)
            {
                <!-- ── Authenticated footer: two-column layout ── -->
                <div class="footer-auth">
                    <div class="footer-auth-top">
                        <p class="footer-auth-tagline">Simple, modern voting for teams and communities. Create polls, collect votes, and see results in real time.</p>
                        <div class="footer-auth-right">
                            <div class="footer-auth-actions">
                                <div class="footer-stats">
                                    <div class="footer-stat">
                                        <i class="bi bi-bar-chart-fill"></i>
                                        <span>Real-time results</span>
                                    </div>
                                    <div class="footer-stat-divider"></div>
                                    <div class="footer-stat">
                                        <i class="bi bi-shield-check"></i>
                                        <span>Secure voting</span>
                                    </div>
                                </div>
                                <a href="https://github.com/seizure/VoteMaster" target="_blank" rel="noopener noreferrer" class="footer-github">
                                    <i class="bi bi-github"></i>
                                    <span>View on GitHub</span>
                                    <i class="bi bi-arrow-up-right footer-github-arrow"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="footer-auth-bottom">
                        <span>© @DateTime.UtcNow.Year VoteMaster. All rights reserved.</span>
                        <div class="footer-auth-bottom-right">
                            <a href="/Privacy" class="footer-auth-legal"><i class="bi bi-shield-lock"></i> Privacy</a>
                            <span class="footer-auth-sep"></span>
                            <a href="/Cookies" class="footer-auth-legal"><i class="bi bi-cookie"></i> Cookies</a>
                            <span class="footer-auth-sep"></span>
                            <span class="footer-auth-status">
                                <span class="footer-status-dot"></span>
                                All systems operational
                            </span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <!-- ── Guest footer: 3-column grid ── -->
                <div class="footer-grid">

                    <!-- Brand column -->
                    <div class="footer-brand-col">
                        <a href="/" class="footer-brand">
                            <span class="footer-brand-icon"><i class="bi bi-check2-square"></i></span>
                            <span class="footer-brand-name">VoteMaster</span>
                        </a>
                        <p class="footer-tagline">
                            Simple, modern voting for teams and communities. Create polls, collect votes, and see results in real time.
                        </p>
                        <div class="footer-stats">
                            <div class="footer-stat">
                                <i class="bi bi-bar-chart-fill"></i>
                                <span>Real-time results</span>
                            </div>
                            <div class="footer-stat-divider"></div>
                            <div class="footer-stat">
                                <i class="bi bi-shield-check"></i>
                                <span>Secure voting</span>
                            </div>
                        </div>
                        <a href="https://github.com/seizure/VoteMaster" target="_blank" rel="noopener noreferrer" class="footer-github">
                            <i class="bi bi-github"></i>
                            <span>View on GitHub</span>
                            <i class="bi bi-arrow-up-right footer-github-arrow"></i>
                        </a>
                    </div>

                    <!-- Product column -->
                    <div class="footer-links-col">
                        <h6 class="footer-col-heading">
                            <span class="footer-col-heading-dot"></span>
                            Product
                        </h6>
                        <ul class="footer-links">
                            <li>
                                <a href="/#features">
                                    <span class="footer-link-icon"><i class="bi bi-stars"></i></span>
                                    <span>Features</span>
                                </a>
                            </li>
                            <li>
                                <a href="/#get-started">
                                    <span class="footer-link-icon"><i class="bi bi-rocket-takeoff"></i></span>
                                    <span>Get Started</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Legal column -->
                    <div class="footer-links-col">
                        <h6 class="footer-col-heading">
                            <span class="footer-col-heading-dot"></span>
                            Legal
                        </h6>
                        <ul class="footer-links">
                            <li>
                                <a href="/Privacy">
                                    <span class="footer-link-icon"><i class="bi bi-shield-lock"></i></span>
                                    <span>Privacy Policy</span>
                                </a>
                            </li>
                            <li>
                                <a href="/Cookies">
                                    <span class="footer-link-icon"><i class="bi bi-cookie"></i></span>
                                    <span>Cookie Policy</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                </div><!-- /footer-grid -->

                <!-- Bottom bar -->
                <div class="footer-bottom">
                    <div class="footer-bottom-left">
                        <span class="footer-bottom-logo"><i class="bi bi-check2-square"></i></span>
                        <span>© @DateTime.UtcNow.Year VoteMaster. All rights reserved.</span>
                    </div>
                    <div class="footer-bottom-right">
                        <span class="footer-bottom-status">
                            <span class="footer-status-dot"></span>
                            All systems operational
                        </span>
                    </div>
                </div>
            }

        </div>
    </footer>

    <!-- GDPR Cookie Consent Banner — bottom-right card -->
    <div id="cookieBanner" style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;max-width:320px;background:white;border-radius:1rem;box-shadow:0 8px 32px rgba(15,23,42,0.18);padding:1.25rem 1.5rem;border:1px solid #e2e8f0;">
        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
            <i class="bi bi-shield-lock-fill" style="color:#14b8a6;font-size:1.25rem;"></i>
            <span style="font-weight:700;color:#0f172a;font-size:0.9375rem;">Cookie Notice</span>
        </div>
        <p style="font-size:0.8125rem;color:#475569;margin-bottom:1rem;line-height:1.5;">
            We use essential session cookies to keep you logged in. No tracking or third-party cookies.
            <a href="/Privacy" style="color:#14b8a6;font-weight:600;">Privacy Policy</a>
        </p>
        <div style="display:flex;gap:0.5rem;">
            <button onclick="acceptCookies()" style="flex:1;background:#14b8a6;color:white;border:none;border-radius:0.5rem;padding:0.5rem;font-size:0.8125rem;font-weight:600;cursor:pointer;">Accept</button>
            <button onclick="declineCookies()" style="flex:1;background:transparent;color:#64748b;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.5rem;font-size:0.8125rem;font-weight:600;cursor:pointer;">Decline</button>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <!-- Page loader -->
    <style>
        #page-loader {
            position: fixed; inset: 0; z-index: 99999;
            background: white;
            display: flex; align-items: center; justify-content: center;
            transition: opacity 0.2s ease;
        }
        #page-loader.hidden { opacity: 0; pointer-events: none; }
        .loader-spinner {
            width: 40px; height: 40px;
            border: 4px solid #e2e8f0;
            border-top-color: #14b8a6;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>
    <div id="page-loader"><div class="loader-spinner"></div></div>
    <script>
        // Global function pages call when they're ready to show
        function dismissLoader() {
            const loader = document.getElementById('page-loader');
            if (!loader) return;
            loader.classList.add('hidden');
            setTimeout(() => loader.remove(), 250);
        }
        // Fallback: dismiss after 2s no matter what
        setTimeout(dismissLoader, 2000);
    </script>
    
    <script>
        // Highlight correct nav link for landing page hash sections (only on the home page)
        (function () {
            var navHome = document.getElementById('nav-home');
            var navFeatures = document.getElementById('nav-features');
            if (!navHome || !navFeatures) return;

            var isHomePage = window.location.pathname === '/';
            if (!isHomePage) return;

            var navGetStarted = document.querySelector('a[href="/#get-started"]');

            // Sections in top-to-bottom DOM order
            var sections = [
                { id: 'features',    nav: navFeatures },
                { id: 'get-started', nav: navGetStarted },
            ];

            function setActive(nav) {
                navHome.classList.remove('active');
                navFeatures.classList.remove('active');
                if (navGetStarted) navGetStarted.classList.remove('active');
                if (nav) nav.classList.add('active');
                else navHome.classList.add('active');
            }

            function updateFromScroll() {
                // Walk sections bottom-to-top; first one whose top is at/above threshold wins
                var matched = null;
                for (var i = sections.length - 1; i >= 0; i--) {
                    var el = document.getElementById(sections[i].id);
                    if (el && el.getBoundingClientRect().top <= 120) {
                        matched = sections[i].nav;
                        break;
                    }
                }
                setActive(matched);
            }

            // Run on scroll
            window.addEventListener('scroll', updateFromScroll, { passive: true });

            // Run on hash change (browser back/forward or direct link)
            window.addEventListener('hashchange', updateFromScroll);

            // Initial state
            updateFromScroll();
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // GDPR Cookie Consent
        (function() {
            const consent = localStorage.getItem('cookieConsent');
            if (!consent) document.getElementById('cookieBanner').style.display = 'block';
        })();
        function acceptCookies() {
            localStorage.setItem('cookieConsent', 'accepted');
            document.getElementById('cookieBanner').style.display = 'none';
        }
        function declineCookies() {
            localStorage.setItem('cookieConsent', 'declined');
            document.getElementById('cookieBanner').style.display = 'none';
        }
    </script>

    <script>
        // Global SignalR connection for poll notifications
        @if (user?.IsAuthenticated ?? false)
        {
            <text>
            if (typeof signalR !== 'undefined') {
                const notificationConnection = new signalR.HubConnectionBuilder()
                    .withUrl("/hubs/results")
                    .withAutomaticReconnect()
                    .build();

                notificationConnection.on("PollStarted", function (pollId, pollTitle) {
                    showToast(`New poll started: ${pollTitle}`, `/Client/Vote/${pollId}`);
                });

                notificationConnection.on("PollEnded", function (pollId, pollTitle) {
                    showToast(`Poll ended: ${pollTitle}`, `/Client/Vote/${pollId}`);
                });

                notificationConnection.start()
                    .then(() => console.log("Notification hub connected"))
                    .catch(err => console.error("Notification hub error:", err));

                function showToast(message, link) {
                    const toastEl = document.getElementById('pollNotificationToast');
                    const toastBody = document.getElementById('toastMessage');
                    
                    if (link) {
                        toastBody.innerHTML = `${message} <a href="${link}" class="btn btn-sm btn-primary mt-2 w-100">View Poll</a>`;
                    } else {
                        toastBody.textContent = message;
                    }
                    
                    const toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                    toast.show();
                }
            }
            </text>
        }
    </script>
</body>
</html>
