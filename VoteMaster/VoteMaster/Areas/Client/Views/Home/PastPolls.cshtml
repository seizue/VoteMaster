@model IEnumerable<(VoteMaster.Models.Poll poll, int voteCount)>
@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="polls-header mb-4">
    <div>
        <h3 class="mb-1">Past Polls</h3>
        <p class="text-muted mb-0">View polls you've participated in (Logged in as: @User.Identity?.Name)</p>
    </div>
    <a href="/Client/Home" class="btn btn-dark">
        <i class="bi bi-arrow-left me-2"></i>Back to Open Polls
    </a>
</div>

@if (!Model.Any()) {
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>You haven't voted in any polls yet.
        @if (ViewBag.TotalPolls != null)
        {
            <br /><small class="text-muted">Debug: Total polls in system: @ViewBag.TotalPolls, Polls you voted in: @ViewBag.UserVotedCount</small>
        }
    </div>
}
else
{
    <div class="polls-grid">
    @foreach (var item in Model) {
        var p = item.poll;
        var voteCount = item.voteCount;
        var now = DateTime.UtcNow;
        var isActive = p.StartTime <= now && p.EndTime >= now;
        var isUpcoming = p.StartTime > now;
        var isEnded = p.EndTime < now;
        
        <div class="poll-card-item">
            <div class="poll-card-content">
                <div class="poll-card-header">
                    <h5 class="poll-card-title">@p.Title</h5>
                    <p class="poll-card-description">@p.Description</p>
                </div>
                <div class="poll-card-footer">
                    <div class="poll-card-meta">
                        <span class="badge bg-secondary">
                            <i class="bi bi-check-circle-fill me-1"></i>
                            You voted (@voteCount vote@(voteCount > 1 ? "s" : ""))
                        </span>
                        @if (isEnded)
                        {
                            <span class="text-muted">
                                <i class="bi bi-calendar-x"></i>
                                Ended @p.EndTime.ToLocalTime().ToString("MMM dd, yyyy")
                            </span>
                        }
                        else if (isActive)
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-clock-fill"></i>
                                Active
                            </span>
                        }
                        else if (isUpcoming)
                        {
                            <span class="badge bg-info">
                                <i class="bi bi-calendar-event"></i>
                                Upcoming
                            </span>
                        }
                    </div>
                    <a class="btn btn-outline-primary" href="/Client/Vote/@p.Id">
                        <i class="bi bi-bar-chart me-2"></i>View @(isEnded ? "Results" : "Poll")
                    </a>
                </div>
            </div>
        </div>
    }
    </div>
}
