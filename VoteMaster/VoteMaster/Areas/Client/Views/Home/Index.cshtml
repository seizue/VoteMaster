@model IEnumerable<VoteMaster.Models.Poll>
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var userId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
    int page       = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int pageSize   = ViewBag.PageSize;
    int totalCount = ViewBag.TotalCount;
}

<div class="polls-header mb-4">
    <div>
        <h3 class="mb-1">Open Polls</h3>
        <p class="text-muted mb-0">Cast your vote on active polls</p>
    </div>
    <a href="/Client/Home/PastPolls" class="btn btn-dark">
        <i class="bi bi-clock-history me-2"></i>View Past Polls
    </a>
</div>

@if (!Model.Any() && page == 1) {
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No active polls right now. Check back later!
    </div>
}
else
{
    <div class="polls-grid">
    @foreach (var p in Model) {
        <div class="poll-card-item">
            <div class="poll-card-content">
                <div class="poll-card-header">
                    <h5 class="poll-card-title">@p.Title</h5>
                    <p class="poll-card-description">@p.Description</p>
                </div>
                <div class="poll-card-footer">
                    <div class="poll-card-meta">
                        <i class="bi bi-calendar-event"></i>
                        <span>Ends @p.EndTime.ToLocalTime().ToString("MMM dd, h:mm tt")</span>
                    </div>
                    <a class="btn btn-primary" href="/Client/Vote/@p.Id">
                        <i class="bi bi-hand-index me-2"></i>Vote Now
                    </a>
                </div>
            </div>
        </div>
    }
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Polls pagination" class="mt-4">
            <div class="d-flex flex-column flex-sm-row align-items-center justify-content-between gap-2">
                <p class="text-muted small mb-0">
                    Showing @((page - 1) * pageSize + 1)–@(Math.Min(page * pageSize, totalCount)) of @totalCount polls
                </p>
                <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                    <li class="page-item @(page == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(page - 1)&pageSize=@pageSize" aria-label="Previous">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == 1 || i == totalPages || (i >= page - 2 && i <= page + 2))
                        {
                            <li class="page-item @(i == page ? "active" : "")">
                                <a class="page-link" href="?page=@i&pageSize=@pageSize">@i</a>
                            </li>
                        }
                        else if (i == page - 3 || i == page + 3)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }
                    <li class="page-item @(page == totalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(page + 1)&pageSize=@pageSize" aria-label="Next">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <label class="text-muted small mb-0 d-none d-sm-inline">Per page:</label>
                    <select class="form-select form-select-sm" style="width:auto"
                            onchange="window.location='?page=1&pageSize='+this.value">
                        @foreach (var s in new[] { 6, 12, 24 })
                        {
                            <option value="@s" @(pageSize == s ? "selected" : "")>@s</option>
                        }
                    </select>
                </div>
            </div>
        </nav>
    }
}
