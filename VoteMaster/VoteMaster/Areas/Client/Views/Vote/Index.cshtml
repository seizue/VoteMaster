@model VoteMaster.Models.Poll
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    bool hasVoted = (bool?)ViewBag.HasVoted ?? false;
    int voteCount = (int?)ViewBag.VoteCount ?? 0;
    int maxVotes = (int?)ViewBag.MaxVotes ?? 0;
    var userVotes = (List<int>?)ViewBag.UserVotes ?? new List<int>();
    bool showResults = (bool?)ViewBag.ShowResults ?? false;
    string pollStatus = (string?)ViewBag.PollStatus ?? "Active";
    bool isAuthenticated = (bool?)ViewBag.IsAuthenticated ?? false;
    bool allowUsercodeEntry = (bool?)ViewBag.AllowUsercodeEntry ?? false;
    var sortedOptions = Model.Options.OrderByDescending(o => o.Votes.Count).ToList();
    var totalVotes = sortedOptions.Sum(o => o.Votes.Count);
}

<style>
    /* ── Kiosk split layout ── */
    /* Default (mobile-first): stack vertically */
    .kiosk-layout { width: 100%; }

    .kiosk-panel {
        margin-bottom: 1.5rem;
    }

    /* Desktop (≥ 768px): side-by-side */
    @@media (min-width: 768px) {
        .kiosk-split {
            display: grid;
            grid-template-columns: 340px 1fr;
            gap: 2rem;
            align-items: start;
        }
        .kiosk-panel {
            position: sticky;
            top: 80px; /* below navbar */
            margin-bottom: 0;
        }
    }

    /* ── Kiosk entry card ── */
    .kiosk-entry-card {
        background: white;
        border-radius: 1.25rem;
        box-shadow: 0 4px 24px rgba(15,23,42,0.10);
        padding: 2rem 1.75rem 1.5rem;
        text-align: center;
    }
    .kiosk-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.6rem;
        color: white;
    }
    .kiosk-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 0.3rem;
    }
    .kiosk-subtitle {
        font-size: 0.9rem;
        color: #64748b;
        margin-bottom: 1.25rem;
    }
    .kiosk-input {
        display: block;
        width: 100%;
        font-size: 1.2rem;
        font-weight: 600;
        padding: 0.85rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        outline: none;
        color: #0f172a;
        text-align: center;
        letter-spacing: 0.05em;
        transition: border-color 0.2s, box-shadow 0.2s;
        margin-bottom: 0.75rem;
        background: #f8fafc;
    }
    .kiosk-input:focus {
        border-color: #6366f1;
        background: white;
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .kiosk-btn {
        display: block;
        width: 100%;
        padding: 0.875rem;
        font-size: 1.05rem;
        font-weight: 700;
        border: none;
        border-radius: 0.75rem;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
    }
    .kiosk-btn:hover  { opacity: 0.9; }
    .kiosk-btn:active { transform: scale(0.98); }
    .kiosk-hint {
        font-size: 0.78rem;
        color: #94a3b8;
        margin-top: 0.9rem;
        margin-bottom: 0;
    }

    /* Mobile: full-width, larger tap targets */
    @@media (max-width: 575px) {
        .kiosk-entry-card {
            border-radius: 1rem;
            padding: 1.5rem 1.25rem 1.25rem;
            box-shadow: none;
            border: 1px solid #e2e8f0;
        }
        .kiosk-title  { font-size: 1.2rem; }
        .kiosk-input  { font-size: 1.1rem; padding: 1rem; }
        .kiosk-btn    { font-size: 1rem; padding: 1rem; }
        .kiosk-icon   { width: 52px; height: 52px; font-size: 1.4rem; }
    }
</style>

<div class="vote-page">
    <!-- Back to Home and Share Buttons -->
    <div class="mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <a class="btn btn-dark" href="/">
            <i class="bi bi-arrow-left me-2"></i>Back to Home
        </a>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" onclick="copyPollLink()">
                <i class="bi bi-link-45deg me-2"></i>Copy Link
            </button>
            <button class="btn btn-success" onclick="showQRCode()">
                <i class="bi bi-qr-code me-2"></i>QR Code
            </button>
        </div>
    </div>
    
    <!-- Poll Header Card -->
    <div class="vote-header-card">
        <h1>@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p>@Model.Description</p>
        }
        @if (pollStatus == "Archived")
        {
            <span class="badge bg-secondary" style="font-size: 1rem; padding: 0.5rem 1rem;">
                <i class="bi bi-lock-fill me-2"></i>Poll Closed
            </span>
        }
    </div>

    @if (hasVoted && voteCount >= maxVotes)
    {
        <div class="alert alert-secondary">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Voting Complete!</strong> You have already cast @voteCount vote(s) for this poll.
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]
        </div>
    }

    @if (showResults)
    {
        <!-- Results View -->
        <div class="results-section">
            <h4 class="mb-3">
                <i class="bi bi-bar-chart-fill me-2"></i>Poll Results
            </h4>
            
            <div class="results-grid">
                @foreach (var option in sortedOptions)
                {
                    var votes = option.Votes.Count;
                    var percentage = totalVotes > 0 ? (votes * 100.0 / totalVotes) : 0;
                    var isUserVote = userVotes.Contains(option.Id);
                    
                    <div class="result-card @(isUserVote ? "user-voted" : "")" data-result-option-id="@option.Id">
                        <div class="result-header">
                            <div class="result-title">
                                @option.Text
                                @if (isUserVote)
                                {
                                    <span class="badge bg-primary ms-2">
                                        <i class="bi bi-check-circle-fill"></i> Your Vote
                                    </span>
                                }
                            </div>
                            <div class="result-count">@votes vote@(votes != 1 ? "s" : "")</div>
                        </div>
                        <div class="result-bar-container">
                            <div class="result-bar" style="width: @percentage.ToString("F1")%"></div>
                        </div>
                        <div class="result-percentage">@percentage.ToString("F1")%</div>
                    </div>
                }
            </div>
            
            <div class="results-summary">
                <i class="bi bi-people-fill me-2"></i>
                <strong>Total Votes:</strong> @totalVotes
            </div>
        </div>
    }
    else
    {
        @* Desktop: side-by-side layout. Mobile: stacked. *@
        <div class="kiosk-layout @(!isAuthenticated && allowUsercodeEntry ? "kiosk-split" : "")">

        @* LEFT / TOP — kiosk entry panel (only when unauthenticated + kiosk enabled) *@
        @if (!isAuthenticated && allowUsercodeEntry)
        {
            <div class="kiosk-panel">
                <div class="kiosk-entry-card">
                    <div class="kiosk-icon">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <h4 class="kiosk-title">Enter Your Username</h4>
                    <p class="kiosk-subtitle">Type the username printed on your ballot ticket</p>

                    @if (TempData["KioskError"] != null)
                    {
                        <div class="alert alert-danger py-2 mb-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["KioskError"]
                        </div>
                    }

                    <form method="post" action="@Url.Action("KioskEntry", "Vote", new { area = "Client" })">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="pollId" value="@Model.Id" />
                        <input type="text" name="username" class="kiosk-input"
                               placeholder="Your username" autofocus required
                               autocomplete="off" spellcheck="false" />
                        <button type="submit" class="kiosk-btn">
                            Continue <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </form>

                    <p class="kiosk-hint">
                        <i class="bi bi-ticket-perforated me-1"></i>Your username is on your ballot ticket
                    </p>
                </div>
            </div>
        }

        @* RIGHT / BOTTOM — voting form *@
        <div class="kiosk-options-panel">
        <!-- Voting Form -->
        <form method="post" action="@Url.Action("Cast", "Vote", new { area = "Client" })" id="voteForm">
            <input type="hidden" name="pollId" value="@Model.Id" />
            @Html.AntiForgeryToken()
            
            @if (TempData["Error"] != null) 
            { 
                <div class="alert alert-danger">@TempData["Error"]</div> 
            }

        <div class="vote-options-grid">
            @foreach (var option in sortedOptions)
            {
                var votes = option.Votes.Count;
                var isDisabled = hasVoted && voteCount >= maxVotes;
                
                <div class="vote-option-card @(isDisabled ? "disabled" : "")" data-option-id="@option.Id">
                    <input type="checkbox" name="optionIds" value="@option.Id" id="option-@option.Id" class="vote-checkbox" @(isDisabled ? "disabled" : "") />
                    <label for="option-@option.Id" class="vote-option-label">
                        <div class="vote-option-header">
                            <div class="vote-option-title">@option.Text</div>
                            <div class="vote-check-icon">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                        </div>
                        <div class="vote-option-footer">
                            <div class="vote-count-badge">
                                <i class="bi bi-people-fill"></i>
                                <span>@votes</span>
                            </div>
                        </div>
                    </label>
                </div>
            }
        </div>

        <div class="vote-submit-container">
            @if (!isAuthenticated)
            {
                @if (!allowUsercodeEntry)
                {
                    <div class="alert alert-info text-center">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Sign in required to vote</strong>
                        <p class="mb-0 mt-2">You need to sign in to participate in this poll.</p>
                    </div>
                    <div class="vote-buttons">
                        <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Context.Request.Path)" class="btn btn-primary btn-lg" style="background: #14b8a6 !important; box-shadow: 0 2px 8px rgba(20,184,166,0.25) !important;">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In to Vote
                        </a>
                    </div>
                }
                @* kiosk mode: entry form already shown above — options grid is read-only until signed in *@
            }
            else
            {
                <div class="vote-hint" id="voteHint"></div>
                <div class="vote-buttons">
                    <button type="submit" class="btn btn-primary btn-lg" id="submitButton" @(hasVoted && voteCount >= maxVotes ? "disabled" : "")>
                        <i class="bi bi-check2-circle me-2"></i>@(hasVoted && voteCount >= maxVotes ? "Voting Complete" : "Submit Your Votes")
                    </button>
                    @if (hasVoted && voteCount >= maxVotes && pollStatus != "Archived")
                    {
                        <button type="button" class="btn btn-dark btn-lg" onclick="if(confirm('Are you sure you want to reset your votes? This will remove all your current votes for this poll.')) { document.getElementById('resetForm').submit(); }">
                            <i class="bi bi-arrow-counterclockwise me-2"></i>Reset My Votes
                        </button>
                    }
                </div>
            }
        </div>
    </form>
        </div>@* end kiosk-options-panel *@
        </div>@* end kiosk-layout *@
    }
    @if (hasVoted && voteCount >= maxVotes && pollStatus != "Archived")
    {
        <form method="post" action="@Url.Action("Reset", "Vote", new { area = "Client" })" id="resetForm" style="display: none;">
            <input type="hidden" name="pollId" value="@Model.Id" />
            @Html.AntiForgeryToken()
        </form>
    }
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
  (function(){
    const min = @Model.MinVotesPerVoter;
    const max = @Model.MaxVotesPerVoter;
    const submit = document.getElementById('submitButton');
    const hint = document.getElementById('voteHint');
    const checkboxes = document.querySelectorAll('.vote-checkbox');
    const cards = document.querySelectorAll('.vote-option-card');
    const enableLiveVoteCount = @(Model.EnableLiveVoteCount.ToString().ToLower());
    const pollId = @Model.Id;

    // Only run voting logic if form elements exist
    if (submit && hint && checkboxes.length > 0) {
      function updateState() {
        const checked = document.querySelectorAll('input[name="optionIds"]:checked').length;
        
        // Update card states
        checkboxes.forEach((checkbox, index) => {
          if (checkbox.checked) {
            cards[index].classList.add('selected');
          } else {
            cards[index].classList.remove('selected');
          }
        });
        
        // Update submit button
        if (checked < min) {
          submit.disabled = true;
          hint.textContent = `Please select at least ${min} option${min > 1 ? 's' : ''}.`;
          hint.style.display = 'block';
        } else if (checked > max) {
          submit.disabled = true;
          hint.textContent = `Maximum ${max} option${max > 1 ? 's' : ''} allowed.`;
          hint.style.display = 'block';
        } else {
          submit.disabled = false;
          hint.style.display = 'none';
        }
      }

      checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', updateState);
      });

      updateState();
    }

    // SignalR connection for real-time updates
    if (enableLiveVoteCount) {
      const connection = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/results")
        .withAutomaticReconnect()
        .build();

      connection.on("VoteUpdated", function (optionId, newVoteCount) {
        const badge = document.querySelector(`[data-option-id="${optionId}"] .vote-count-badge span`);
        if (badge) {
          badge.textContent = newVoteCount;
          badge.parentElement.classList.add('pulse-animation');
          setTimeout(() => badge.parentElement.classList.remove('pulse-animation'), 600);
        }
        
        // Update result bars if on results view
        const resultCard = document.querySelector(`[data-result-option-id="${optionId}"]`);
        if (resultCard) {
          const countEl = resultCard.querySelector('.result-count');
          const barEl = resultCard.querySelector('.result-bar');
          const percentEl = resultCard.querySelector('.result-percentage');
          
          if (countEl) countEl.textContent = `${newVoteCount} vote${newVoteCount !== 1 ? 's' : ''}`;
          
          // Recalculate percentage
          const allCounts = Array.from(document.querySelectorAll('.result-count'))
            .map(el => parseInt(el.textContent.match(/\d+/)[0]));
          const total = allCounts.reduce((a, b) => a + b, 0);
          const percentage = total > 0 ? (newVoteCount * 100.0 / total) : 0;
          
          if (barEl) barEl.style.width = percentage.toFixed(1) + '%';
          if (percentEl) percentEl.textContent = percentage.toFixed(1) + '%';
        }
      });

      connection.on("VoterParticipationUpdated", function (totalVoters, votedCount) {
        const summary = document.querySelector('.results-summary');
        if (summary) {
          const percentage = totalVoters > 0 ? ((votedCount / totalVoters) * 100).toFixed(1) : 0;
          summary.innerHTML = `<i class="bi bi-people-fill me-2"></i><strong>Participation:</strong> ${votedCount}/${totalVoters} voters (${percentage}%)`;
        }
      });

      connection.start()
        .then(() => {
          console.log("SignalR connected");
          connection.invoke("JoinPollGroup", pollId);
        })
        .catch(err => console.error("SignalR connection error:", err));

      // Cleanup on page unload
      window.addEventListener('beforeunload', () => {
        connection.invoke("LeavePollGroup", pollId);
        connection.stop();
      });
    }
  })();
  
  // Share and QR Code functionality
  const pollUrl = window.location.href;
  
  function copyPollLink() {
    navigator.clipboard.writeText(pollUrl).then(() => {
      // Show success message
      const alert = document.createElement('div');
      alert.className = 'alert alert-success alert-dismissible fade show';
      alert.style.position = 'fixed';
      alert.style.top = '20px';
      alert.style.right = '20px';
      alert.style.zIndex = '9999';
      alert.innerHTML = '<i class="bi bi-check-circle me-2"></i>Poll link copied to clipboard! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
      document.body.appendChild(alert);
      
      setTimeout(() => alert.remove(), 3000);
    }).catch(err => {
      alert('Failed to copy link. Please copy manually: ' + pollUrl);
    });
  }
  
  function showQRCode() {
    // Generate QR code
    const qrContainer = document.getElementById('qrCodeContainer');
    qrContainer.innerHTML = ''; // Clear previous QR code
    
    const qr = new QRCode(qrContainer, {
      text: pollUrl,
      width: 256,
      height: 256,
      colorDark: "#000000",
      colorLight: "#ffffff",
      correctLevel: QRCode.CorrectLevel.H
    });
    
    // Show modal
    const modal = new bootstrap.Modal(document.getElementById('qrCodeModal'));
    modal.show();
  }
  
  function downloadQRCode() {
    const canvas = document.querySelector('#qrCodeContainer canvas');
    if (canvas) {
      const link = document.createElement('a');
      link.download = 'poll-qr-code.png';
      link.href = canvas.toDataURL();
      link.click();
    }
  }
  
  // Set poll URL in modal input
  document.addEventListener('DOMContentLoaded', function() {
    const pollLinkInput = document.getElementById('pollLinkInput');
    if (pollLinkInput) {
      pollLinkInput.value = window.location.href;
    }
  });
</script>
<!-- QR Code Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
}

<!-- QR Code Modal -->
<div class="modal fade" id="qrCodeModal" tabindex="-1" aria-labelledby="qrCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="qrCodeModalLabel">
                    <i class="bi bi-qr-code me-2"></i>Share Poll QR Code
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3">Scan this QR code to access the poll</p>
                <div id="qrCodeContainer" class="d-flex justify-content-center mb-3"></div>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="pollLinkInput" readonly>
                    <button class="btn btn-outline-primary" onclick="copyPollLink()">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="downloadQRCode()">
                    <i class="bi bi-download me-2"></i>Download QR Code
                </button>
            </div>
        </div>
    </div>
</div>
