@model IEnumerable<VoteMaster.Models.AppUser>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var seedAdminUsername = Configuration["Seed:Admin:Username"];
}

<style>
    .users-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .users-header h3 {
        margin: 0;
        flex: 1;
        min-width: 100px;
    }
    .users-header .button-group {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .search-sort-container {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--vm-shadow-sm);
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
    }
    .search-box {
        position: relative;
        flex: 1;
        min-width: 250px;
    }
    .search-box i {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--vm-muted);
        font-size: 1rem;
    }
    .search-box .form-control {
        padding-left: 2.75rem;
        border-radius: 0.75rem;
    }
    .sort-group {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }
    .sort-group label {
        margin: 0;
        font-weight: 600;
        color: var(--vm-text-primary);
        white-space: nowrap;
    }
    .summary-card {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: var(--vm-shadow-sm);
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.2s ease;
        height: 100%;
    }
    .summary-card:hover {
        box-shadow: var(--vm-shadow-md);
        transform: translateY(-2px);
    }
    .summary-icon {
        width: 56px;
        height: 56px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }
    .summary-content {
        flex: 1;
        min-width: 0;
    }
    .summary-label {
        font-size: 0.875rem;
        color: var(--vm-text-secondary);
        font-weight: 600;
        margin-bottom: 0.25rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .summary-value {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--vm-text-primary);
        line-height: 1;
    }
    .table th.sortable {
        cursor: pointer;
        user-select: none;
    }
    .table th.sortable:hover {
        background: #e2e8f0;
    }
    .table th.sortable i {
        margin-left: 0.5rem;
        font-size: 0.75rem;
        opacity: 0.5;
    }
    .table th.sortable.sorted i {
        opacity: 1;
    }
    .table .text-end {
        white-space: nowrap;
    }
    .table .text-end .btn {
        min-width: 70px;
    }
    .table .text-end form {
        display: inline-block;
    }
    .table .text-end form .btn {
        min-width: 70px;
    }
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    /* User cards for mobile */
    .users-cards-wrap { display: none; }
    .user-card {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 0.875rem;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        box-shadow: 0 1px 3px rgba(15,23,42,0.06);
        display: block;
    }
    .user-card-top {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin-bottom: 0.75rem;
    }
    .user-card-avatar {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: #e0e7ff;
        color: #4338ca;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 1.1rem; flex-shrink: 0;
    }
    .user-card-name { font-weight: 700; color: #0f172a; font-size: 0.9375rem; }
    .user-card-meta { font-size: 0.8125rem; color: #64748b; }
    .user-card-actions { display: flex; gap: 0.5rem; }
    .user-card-actions .btn { flex: 1; font-size: 0.8125rem; }

    @@media (max-width: 768px) {
        .users-header { flex-direction: column; align-items: stretch; }
        .users-header .button-group { flex-direction: column; }
        .users-header .button-group .btn { width: 100%; }
        .search-sort-container { flex-direction: column; align-items: stretch; }
        .search-box { width: 100%; min-width: auto; }
        .sort-group { width: 100%; }
        .sort-group .form-select { flex: 1; }
        .sort-group label { min-width: 60px; }
        .summary-card { padding: 1rem; gap: 0.75rem; }
        .summary-icon { width: 44px; height: 44px; font-size: 1.25rem; }
        .summary-label { font-size: 0.75rem; }
        .summary-value { font-size: 1.5rem; }
        /* Hide table, show cards on mobile */
        .users-table-wrap { display: none !important; }
        .users-cards-wrap { display: block !important; }
    }
    @@media (max-width: 768px) {
        .users-header {
            flex-direction: column;
            align-items: stretch;
        }
        .users-header .button-group {
            flex-direction: column;
        }
        .users-header .button-group .btn {
            width: 100%;
        }
        .search-sort-container {
            flex-direction: column;
            align-items: stretch;
        }
        .search-box {
            width: 100%;
            min-width: auto;
        }
        .sort-group {
            width: 100%;
        }
        .sort-group .form-select {
            flex: 1;
        }
        .sort-group label {
            min-width: 60px;
        }
        /* Compact summary cards on mobile */
        .summary-card {
            padding: 1rem;
            gap: 0.75rem;
        }
        .summary-icon {
            width: 44px;
            height: 44px;
            font-size: 1.25rem;
        }
        .summary-label {
            font-size: 0.75rem;
        }
        .summary-value {
            font-size: 1.5rem;
        }
        /* Make action buttons stack vertically on mobile */
        .table .text-end {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            align-items: stretch;
        }
        .table .text-end .btn {
            width: 100%;
            min-width: auto;
        }
        .table .text-end form {
            width: 100%;
            display: block;
        }
        .table .text-end form .btn {
            width: 100%;
            min-width: auto;
        }
        /* Adjust table for better mobile display */
        .table thead th {
            font-size: 0.75rem;
            padding: 0.75rem 0.5rem;
        }
        .table tbody td {
            font-size: 0.875rem;
            padding: 0.75rem 0.5rem;
        }
    }
    @@media (max-width: 576px) {
        .table thead th {
            font-size: 0.7rem;
            padding: 0.5rem 0.25rem;
        }
        .table tbody td {
            font-size: 0.8rem;
            padding: 0.5rem 0.25rem;
        }
        .table .text-end .btn {
            font-size: 0.75rem;
            padding: 0.375rem 0.5rem;
        }
    }
</style>

<div class="users-header">
    <h3>Users</h3>
    <div class="button-group">
        <a class="btn btn-success" href="/Admin/Users/Create">
            <i class="bi bi-plus-circle me-2"></i>Add User
        </a>
        <a class="btn btn-info" href="/Admin/Users/ExportVotersJson">
            <i class="bi bi-download me-2"></i>Export Voters (JSON)
        </a>
        <a class="btn btn-dark" href="/Admin/Dashboard">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>
</div>

<!-- Search and Sort -->
<div class="search-sort-container">
    <div class="search-box">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" class="form-control" placeholder="Search users...">
    </div>
    
    <div class="sort-group">
        <label for="roleFilter">Role:</label>
        <select id="roleFilter" class="form-select" onchange="filterTable()">
            <option value="all">All</option>
            <option value="voter">Voter</option>
            <option value="admin">Admin</option>
        </select>
    </div>
    
    <div class="sort-group">
        <label for="sortSelect">Sort by:</label>
        <select id="sortSelect" class="form-select" onchange="sortTable()">
            <option value="username-asc">Username (A-Z)</option>
            <option value="username-desc">Username (Z-A)</option>
            <option value="weight-asc">Weight (Low to High)</option>
            <option value="weight-desc" selected>Weight (High to Low)</option>
            <option value="role-asc">Role (A-Z)</option>
            <option value="role-desc">Role (Z-A)</option>
        </select>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-6">
        <div class="summary-card">
            <div class="summary-icon" style="background: #dbeafe; color: #1e40af;">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Total Users</div>
                <div class="summary-value" id="totalUsers">@Model.Count()</div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="summary-card">
            <div class="summary-icon" style="background: #d1fae5; color: #065f46;">
                <i class="bi bi-person-check-fill"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Voters</div>
                <div class="summary-value" id="totalVoters">@Model.Count(u => u.Role.Equals("Voter", StringComparison.OrdinalIgnoreCase))</div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="summary-card">
            <div class="summary-icon" style="background: #fef3c7; color: #92400e;">
                <i class="bi bi-shield-fill-check"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Admins</div>
                <div class="summary-value" id="totalAdmins">@Model.Count(u => u.Role.Equals("Admin", StringComparison.OrdinalIgnoreCase))</div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="summary-card">
            <div class="summary-icon" style="background: #e0e7ff; color: #4338ca;">
                <i class="bi bi-bar-chart-fill"></i>
            </div>
            <div class="summary-content">
                <div class="summary-label">Total Weight</div>
                <div class="summary-value" id="totalWeight">@Model.Sum(u => u.Weight).ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<div class="users-table-wrap table-responsive">
    <table class="table table-striped" id="usersTable">
        <thead>
            <tr>
                <th class="sortable" onclick="sortByColumn('username')">
                    Username<i class="bi bi-arrow-down-up"></i>
                </th>
                <th class="sortable" onclick="sortByColumn('role')">
                    Role<i class="bi bi-arrow-down-up"></i>
                </th>
                <th class="sortable sorted" onclick="sortByColumn('weight')">
                    Weight<i class="bi bi-arrow-down"></i>
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var u in Model) {
            <tr data-id="@u.Id" data-username="@u.Username.ToLower()" data-role="@u.Role.ToLower()" data-weight="@u.Weight" style="display:none;">
                <td>@u.Username</td>
                <td>@u.Role</td>
                <td>@u.Weight</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" href="/Admin/Users/Edit/@u.Id">Edit</a>
                    @if (!string.Equals(u.Username, seedAdminUsername, StringComparison.OrdinalIgnoreCase))
                    {
                        <form method="post" action="/Admin/Users/Delete/@u.Id" style="display:inline">
                            <button class="btn btn-sm btn-danger" onclick="return confirm('Delete user?')">Delete</button>
                        </form>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<!-- Mobile cards -->
<div class="users-cards-wrap" id="usersCards">
    @foreach (var u in Model)
    {
        var initials = u.Username.Length > 0 ? u.Username[0].ToString().ToUpper() : "?";
        var roleColor = u.Role.Equals("Admin", StringComparison.OrdinalIgnoreCase) ? "#fef3c7" : "#d1fae5";
        var roleText  = u.Role.Equals("Admin", StringComparison.OrdinalIgnoreCase) ? "#92400e" : "#065f46";
        <div class="user-card"
             data-id="@u.Id"
             data-username="@u.Username.ToLower()"
             data-role="@u.Role.ToLower()"
             data-weight="@u.Weight">
            <div class="user-card-top">
                <div class="user-card-avatar">@initials</div>
                <div class="flex-grow-1 min-width-0">
                    <div class="user-card-name">@u.Username</div>
                    <div class="user-card-meta">
                        <span class="badge" style="background:@roleColor;color:@roleText;">@u.Role</span>
                        &nbsp;Weight: @u.Weight
                    </div>
                </div>
            </div>
            <div class="user-card-actions">
                <a class="btn btn-sm btn-outline-primary" href="/Admin/Users/Edit/@u.Id">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>
                @if (!string.Equals(u.Username, seedAdminUsername, StringComparison.OrdinalIgnoreCase))
                {
                    <form method="post" action="/Admin/Users/Delete/@u.Id" style="flex:1;">
                        <button class="btn btn-sm btn-danger w-100" onclick="return confirm('Delete user?')">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                }
            </div>
        </div>
    }
</div>

<!-- Pagination -->
<div class="pagination-container">
    <div class="pagination-info">
        Showing <span id="showingStart">1</span> to <span id="showingEnd">10</span> of <span id="totalItems">@Model.Count()</span> users
    </div>
    <nav>
        <ul class="pagination" id="pagination">
            <!-- Pagination will be generated by JavaScript -->
        </ul>
    </nav>
</div>

<script>
let currentSort = { column: 'weight', direction: 'desc' };
let currentPage = 1;
let itemsPerPage = 10;
let allUsers = [];
let filteredUsers = [];

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    // Collect all user rows
    const rows = document.querySelectorAll('#usersTable tbody tr');
    allUsers = Array.from(rows);
    filteredUsers = [...allUsers];
    
    // Sort by weight descending by default
    sortTable();
    
    // Initialize pagination
    updatePagination();
    displayPage(1);
    
    // Search functionality
    document.getElementById('searchInput').addEventListener('input', function(e) {
        filterTable();
    });
});

function displayPage(page) {
    currentPage = page;
    const start = (page - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    
    // Hide all table rows and all cards
    allUsers.forEach(row => {
        row.style.display = 'none';
        const card = document.querySelector(`.user-card[data-id="${row.dataset.id}"]`);
        if (card) card.style.display = 'none';
    });
    
    // Show items for current page
    const itemsToShow = filteredUsers.slice(start, end);
    itemsToShow.forEach(row => {
        row.style.display = '';
        const card = document.querySelector(`.user-card[data-id="${row.dataset.id}"]`);
        if (card) card.style.display = '';
    });
    
    // Update pagination info
    document.getElementById('showingStart').textContent = filteredUsers.length > 0 ? start + 1 : 0;
    document.getElementById('showingEnd').textContent = Math.min(end, filteredUsers.length);
    document.getElementById('totalItems').textContent = filteredUsers.length;
    
    updatePaginationButtons();
    if (typeof dismissLoader === 'function') dismissLoader();
}

function updatePagination() {
    const totalPages = Math.ceil(filteredUsers.length / itemsPerPage);
    const pagination = document.getElementById('pagination');
    pagination.innerHTML = '';
    
    if (totalPages <= 1) return;
    
    // Previous button
    const prevLi = document.createElement('li');
    prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
    prevLi.innerHTML = `<a class="page-link" href="#" onclick="changePage(${currentPage - 1}); return false;"><i class="bi bi-chevron-left"></i></a>`;
    pagination.appendChild(prevLi);
    
    // Page numbers
    const maxVisible = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    if (startPage > 1) {
        const li = document.createElement('li');
        li.className = 'page-item';
        li.innerHTML = `<a class="page-link" href="#" onclick="changePage(1); return false;">1</a>`;
        pagination.appendChild(li);
        
        if (startPage > 2) {
            const dots = document.createElement('li');
            dots.className = 'page-item disabled';
            dots.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dots);
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === currentPage ? 'active' : ''}`;
        li.innerHTML = `<a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>`;
        pagination.appendChild(li);
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            const dots = document.createElement('li');
            dots.className = 'page-item disabled';
            dots.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dots);
        }
        
        const li = document.createElement('li');
        li.className = 'page-item';
        li.innerHTML = `<a class="page-link" href="#" onclick="changePage(${totalPages}); return false;">${totalPages}</a>`;
        pagination.appendChild(li);
    }
    
    // Next button
    const nextLi = document.createElement('li');
    nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
    nextLi.innerHTML = `<a class="page-link" href="#" onclick="changePage(${currentPage + 1}); return false;"><i class="bi bi-chevron-right"></i></a>`;
    pagination.appendChild(nextLi);
}

function updatePaginationButtons() {
    updatePagination();
}

function changePage(page) {
    const totalPages = Math.ceil(filteredUsers.length / itemsPerPage);
    if (page < 1 || page > totalPages) return;
    displayPage(page);
}

function filterTable() {
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    const roleFilter = document.getElementById('roleFilter').value;
    
    filteredUsers = allUsers.filter(row => {
        const username = row.dataset.username;
        const role = row.dataset.role;
        const weight = row.dataset.weight;
        
        // Search filter
        const matchesSearch = username.includes(searchTerm) || 
                             role.includes(searchTerm) || 
                             weight.includes(searchTerm);
        
        // Role filter
        const matchesRole = roleFilter === 'all' || role === roleFilter;
        
        return matchesSearch && matchesRole;
    });
    
    currentPage = 1;
    updatePagination();
    displayPage(1);
    updateSummary();
}

function updateSummary() {
    // Calculate summary from filtered users
    const totalUsers = filteredUsers.length;
    const totalVoters = filteredUsers.filter(row => row.dataset.role === 'voter').length;
    const totalAdmins = filteredUsers.filter(row => row.dataset.role === 'admin').length;
    const totalWeight = filteredUsers.reduce((sum, row) => sum + parseFloat(row.dataset.weight), 0);
    
    // Update summary cards
    document.getElementById('totalUsers').textContent = totalUsers;
    document.getElementById('totalVoters').textContent = totalVoters;
    document.getElementById('totalAdmins').textContent = totalAdmins;
    document.getElementById('totalWeight').textContent = totalWeight.toLocaleString('en-US', { maximumFractionDigits: 0 });
}

function sortByColumn(column) {
    // Toggle direction if same column, otherwise default to ascending
    if (currentSort.column === column) {
        currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
    } else {
        currentSort.column = column;
        currentSort.direction = column === 'weight' ? 'desc' : 'asc';
    }
    
    // Update select dropdown
    document.getElementById('sortSelect').value = `${column}-${currentSort.direction}`;
    
    sortTable();
    updateSortIcons();
}

function sortTable() {
    const sortValue = document.getElementById('sortSelect').value;
    const [column, direction] = sortValue.split('-');
    
    currentSort = { column, direction };
    
    const tbody = document.querySelector('#usersTable tbody');
    
    filteredUsers.sort((a, b) => {
        let aVal, bVal;
        
        if (column === 'username') {
            aVal = a.dataset.username;
            bVal = b.dataset.username;
        } else if (column === 'role') {
            aVal = a.dataset.role;
            bVal = b.dataset.role;
        } else if (column === 'weight') {
            aVal = parseFloat(a.dataset.weight);
            bVal = parseFloat(b.dataset.weight);
        }
        
        if (column === 'weight') {
            return direction === 'asc' ? aVal - bVal : bVal - aVal;
        } else {
            if (direction === 'asc') {
                return aVal > bVal ? 1 : -1;
            } else {
                return aVal < bVal ? 1 : -1;
            }
        }
    });
    
    // Re-append rows in sorted order
    filteredUsers.forEach(row => tbody.appendChild(row));
    
    updateSortIcons();
    displayPage(currentPage);
}

function updateSortIcons() {
    // Remove all sorted classes
    document.querySelectorAll('.table th.sortable').forEach(th => {
        th.classList.remove('sorted');
        const icon = th.querySelector('i');
        icon.className = 'bi bi-arrow-down-up';
    });
    
    // Add sorted class to current column
    const headers = {
        'username': 0,
        'role': 1,
        'weight': 2
    };
    
    const headerIndex = headers[currentSort.column];
    const th = document.querySelectorAll('.table th.sortable')[headerIndex];
    th.classList.add('sorted');
    
    const icon = th.querySelector('i');
    icon.className = currentSort.direction === 'asc' ? 'bi bi-arrow-up' : 'bi bi-arrow-down';
}
</script>
