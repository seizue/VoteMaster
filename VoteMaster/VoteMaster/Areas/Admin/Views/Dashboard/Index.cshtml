@model IEnumerable<PollViewDto>
@using VoteMaster.Services
@using VoteMaster.Areas.Admin.Controllers
@using System.Collections.Generic
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var currentStatus = ViewBag.CurrentStatus ?? "all";
    var statusOptions = ViewBag.StatusOptions ?? new List<string>();
}

<style>
    /* ─── Page wrapper ───────────────────────────────────── */
    .dash-page { display: flex; flex-direction: column; gap: 0; }

    /* ─── Hero banner ────────────────────────────────────── */
    .dash-hero {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #134e4a 100%);
        border-radius: 1.25rem;
        padding: 2rem 2rem 2.75rem;
        margin-bottom: -1.5rem;           /* cards overlap the banner */
        position: relative;
        overflow: hidden;
    }
    .dash-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 80% 50%, rgba(20,184,166,.18) 0%, transparent 70%);
        pointer-events: none;
    }
    .dash-hero-inner {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
    }
    .dash-hero-text h2 {
        margin: 0 0 0.35rem;
        font-size: 1.7rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
    }
    .dash-hero-text p {
        margin: 0;
        font-size: 0.875rem;
        color: rgba(255,255,255,.55);
    }
    .dash-hero-actions { display: flex; gap: 0.625rem; flex-wrap: wrap; align-items: center; }
    .hero-btn-outline {
        background: rgba(255,255,255,.08);
        border: 1.5px solid rgba(255,255,255,.22);
        color: #fff;
        font-size: 0.8375rem;
        font-weight: 600;
        padding: 0.55rem 1.1rem;
        border-radius: 0.65rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        cursor: pointer;
        transition: background .18s, border-color .18s;
        text-decoration: none;
    }
    .hero-btn-outline:hover { background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.4); color: #fff; }
    .hero-btn-solid {
        background: #14b8a6;
        border: none;
        color: #fff;
        font-size: 0.8375rem;
        font-weight: 700;
        padding: 0.55rem 1.25rem;
        border-radius: 0.65rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
        transition: background .18s, box-shadow .18s;
        box-shadow: 0 4px 14px rgba(20,184,166,.35);
    }
    .hero-btn-solid:hover { background: #0d9488; color: #fff; box-shadow: 0 6px 18px rgba(20,184,166,.45); }

    /* ─── KPI cards (overlap hero) ───────────────────────── */
    .kpi-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
        position: relative;
        z-index: 2;
        padding: 0 0.25rem;
    }
    .kpi-card {
        background: #fff;
        border-radius: 1rem;
        border: 1px solid rgba(15,23,42,.07);
        padding: 1.25rem 1.25rem 0;
        box-shadow: 0 4px 24px rgba(15,23,42,.10);
        display: flex;
        flex-direction: column;
        gap: 0;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(15,23,42,.14); }
    .kpi-card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.75rem; }
    .kpi-icon-wrapper {
        width: 42px; height: 42px; border-radius: 0.75rem;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem; flex-shrink: 0;
    }
    .kpi-icon-wrapper.polls    { background: rgba(20,184,166,.12);  color: #14b8a6; }
    .kpi-icon-wrapper.active   { background: rgba(16,185,129,.12);  color: #10b981; }
    .kpi-icon-wrapper.voters   { background: rgba(59,130,246,.12);  color: #3b82f6; }
    .kpi-icon-wrapper.templates{ background: rgba(139,92,246,.12);  color: #8b5cf6; }
    .kpi-info { display: flex; flex-direction: column; }
    .kpi-value { font-size: 1.75rem; font-weight: 800; color: #0f172a; line-height: 1.15; }
    .kpi-label { font-size: 0.775rem; color: #64748b; font-weight: 500; margin-top: 0.15rem; text-transform: uppercase; letter-spacing: .04em; }
    /* Colored bottom accent bar */
    .kpi-bar {
        height: 3px;
        margin: 1rem -0 0;
        border-radius: 0 0 1rem 1rem;
    }
    .kpi-bar.polls     { background: linear-gradient(90deg, #14b8a6, #06b6d4); }
    .kpi-bar.active    { background: linear-gradient(90deg, #10b981, #34d399); }
    .kpi-bar.voters    { background: linear-gradient(90deg, #3b82f6, #818cf8); }
    .kpi-bar.templates { background: linear-gradient(90deg, #8b5cf6, #ec4899); }

    /* ─── Section title ──────────────────────────────────── */
    .section-title {
        font-size: 0.9375rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0.5rem 0 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        letter-spacing: -.01em;
    }
    .section-title i { font-size: 1rem; }

    /* ─── Activity feed card ─────────────────────────────── */
    .activity-card {
        background: #fff;
        border: 1px solid rgba(15,23,42,.08);
        border-radius: 1.1rem;
        box-shadow: 0 2px 12px rgba(15,23,42,.07);
        overflow: hidden;
        margin-bottom: 1.75rem;
    }
    .activity-card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .activity-search-wrap {
        flex: 1; min-width: 160px;
    }
    .activity-search-wrap .input-group-text {
        background: #f8fafc; border-color: #e2e8f0; color: #94a3b8;
    }
    .activity-search-wrap .form-control {
        background: #f8fafc; border-color: #e2e8f0; border-left: none;
        font-size: 0.8375rem; box-shadow: none;
    }
    .activity-search-wrap .form-control:focus { border-color: #14b8a6; background: #fff; }
    .act-pills { display: flex; gap: 0.35rem; flex-wrap: wrap; }
    .act-pill {
        padding: 0.3rem 0.8rem;
        font-size: 0.775rem;
        font-weight: 600;
        border-radius: 2rem;
        border: 1.5px solid #e2e8f0;
        background: #fff;
        color: #64748b;
        cursor: pointer;
        transition: all .15s;
        line-height: 1.4;
    }
    .act-pill:hover { border-color: #14b8a6; color: #14b8a6; }
    .act-pill.active-all    { background: #0f172a; border-color: #0f172a; color: #fff; }
    .act-pill.active-vote   { background: #dcfce7; border-color: #16a34a; color: #16a34a; }
    .act-pill.active-poll   { background: #dbeafe; border-color: #2563eb; color: #2563eb; }
    .act-pill.active-voter  { background: #ede9fe; border-color: #7c3aed; color: #7c3aed; }

    /* Feed rows */
    .activity-feed { display: flex; flex-direction: column; }
    .activity-item {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        padding: 0.8rem 1.25rem;
        border-bottom: 1px solid #f8fafc;
        transition: background .12s;
    }
    .activity-item:last-child { border-bottom: none; }
    .activity-item:hover { background: #f8fafc; }
    .activity-icon {
        width: 2rem; height: 2rem; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.875rem; flex-shrink: 0;
    }
    .activity-icon.vote  { background: #dcfce7; color: #16a34a; }
    .activity-icon.poll  { background: #dbeafe; color: #2563eb; }
    .activity-icon.voter { background: #ede9fe; color: #7c3aed; }
    .activity-text { flex: 1; font-size: 0.8375rem; color: #1e293b; line-height: 1.45; }
    .activity-time { font-size: 0.75rem; color: #94a3b8; white-space: nowrap; }

    /* Feed footer (pagination) */
    .activity-card-footer {
        padding: 0.75rem 1.25rem;
        border-top: 1px solid #f1f5f9;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.775rem;
        color: #94a3b8;
    }
    .act-pager-btn {
        padding: 0.3rem 0.75rem;
        font-size: 0.775rem;
        font-weight: 600;
        border: 1.5px solid #e2e8f0;
        border-radius: 0.5rem;
        background: #fff;
        color: #334155;
        cursor: pointer;
        transition: all .15s;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }
    .act-pager-btn:hover:not(:disabled) { border-color: #14b8a6; color: #14b8a6; }
    .act-pager-btn:disabled { opacity: .4; cursor: default; }

    /* ─── Poll table section title row ───────────────────── */
    .polls-section-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 0.875rem;
    }

    /* ─── Filter pill tabs ───────────────────────────────── */
    .filter-buttons {
        display: flex;
        gap: 0.375rem;
        flex-wrap: wrap;
        background: #fff;
        padding: 0.375rem;
        border-radius: 0.75rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 4px rgba(15,23,42,.06);
    }
    .filter-buttons .btn {
        padding: 0.45rem 1rem;
        font-size: 0.8125rem;
        border-radius: 0.5rem;
        font-weight: 600;
        border: none;
        background: transparent;
        color: #64748b;
        transition: all .18s;
    }
    .filter-buttons .btn:hover { background: rgba(20,184,166,.07); color: #14b8a6; }
    .filter-buttons .btn-primary { background: #14b8a6; color: #fff; box-shadow: 0 2px 8px rgba(20,184,166,.28); }
    .filter-buttons .btn-primary:hover { background: #0d9488; color: #fff; }

    /* ─── Search / date filter bar ───────────────────────── */
    .dashboard-filters {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }
    .search-box {
        flex: 1;
        min-width: 180px;
        position: relative;
        display: flex;
        align-items: center;
    }
    .search-box i {
        position: absolute;
        left: 0.875rem;
        color: #94a3b8;
        font-size: 0.875rem;
        pointer-events: none;
    }
    .search-box .form-control {
        padding-left: 2.25rem;
        border-radius: 0.65rem;
        border: 1.5px solid #e2e8f0;
        font-size: 0.8375rem;
        background: #fff;
        box-shadow: none;
    }
    .search-box .form-control:focus { border-color: #14b8a6; }
    .filter-group { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
    .date-filter .form-control {
        border-radius: 0.65rem;
        border: 1.5px solid #e2e8f0;
        font-size: 0.8125rem;
        width: auto;
    }

    /* ─── Table ──────────────────────────────────────────── */
    .table-responsive {
        border-radius: 1rem;
        overflow: visible;
        box-shadow: 0 2px 12px rgba(15,23,42,.07);
        background: #fff;
        border: 1px solid rgba(15,23,42,.07);
        margin-bottom: 2rem;
    }
    .table-actions { display: flex; gap: 0.35rem; flex-wrap: nowrap; align-items: center; }
    .table-actions .dropdown { display: inline-flex; align-items: center; }
    .table-actions .btn { white-space: nowrap; font-size: 0.8125rem; padding: 0.3rem 0.65rem; flex: 0 0 auto; }
    .table-actions form { display: inline-flex; margin: 0; flex: 0 0 auto; }
    .table-actions form .btn { padding: 0.3rem 0.65rem; font-size: 0.8125rem; }
    .ta-end { background: #f97316; color: white; border: none; }
    .ta-end:hover { background: #ea6c0a; color: white; }

    /* ─── Mobile poll cards ──────────────────────────────── */
    .poll-card { display: none; background: white; border-radius: 1rem; border: 1px solid #e2e8f0; margin-bottom: 1rem; padding: 1.25rem; box-shadow: 0 1px 4px rgba(15,23,42,.07); transition: box-shadow .2s; }
    .poll-card:hover { box-shadow: 0 4px 16px rgba(15,23,42,.10); }
    .poll-card-title { font-weight: 700; font-size: 1.05rem; color: #0f172a; margin-bottom: 0.4rem; }
    .poll-card-meta { font-size: 0.85rem; color: #64748b; display: flex; align-items: center; gap: 0.35rem; margin: 0.5rem 0 1rem; }
    .poll-card-actions { display: none; grid-template-columns: 1fr 1fr; gap: 0.6rem; margin-top: 0.75rem; }
    .poll-card-actions.open { display: grid; }
    .poll-card-actions .btn, .poll-card-actions form { margin: 0; }
    .poll-card-actions form { display: contents; }
    .poll-card-actions form .btn { width: 100%; }
    .poll-card-actions .btn-full, .poll-card-actions form.full { grid-column: 1 / -1; }
    .poll-card-actions form.full .btn { width: 100%; }
    .poll-card-actions .btn { padding: 0.7rem 1rem; font-size: 0.9rem; font-weight: 600; border-radius: 0.65rem; }
    .pc-toggle { display: flex; align-items: center; justify-content: center; gap: 0.35rem; width: 100%; margin-top: 0.75rem; padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 600; color: #64748b; background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 0.5rem; cursor: pointer; transition: background .15s; }
    .pc-toggle:hover { background: #e2e8f0; }

    /* ─── Dropdown menu ──────────────────────────────────── */
    .actions-dropdown-menu { display: flex; flex-direction: column; padding: 0.35rem; gap: 0.25rem; }
    .actions-dropdown-menu .btn { width: 100%; text-align: left; font-size: 0.8125rem; padding: 0.4rem 0.75rem; border-radius: 0.4rem; border-width: 1.5px; }
    .actions-dropdown-menu form { display: contents; }
    .actions-dropdown-menu form .btn { width: 100%; text-align: left; }
    .actions-dropdown-menu hr { margin: 0.15rem 0 !important; border: 0 !important; border-top: 1px solid #e2e8f0 !important; opacity: 1 !important; height: 0 !important; }

    /* ─── Responsive ─────────────────────────────────────── */
    @@media (max-width: 768px) {
        .dash-hero { padding: 1.5rem 1.25rem 2.25rem; }
        .dash-hero-text h2 { font-size: 1.35rem; }
        .kpi-container { grid-template-columns: 1fr 1fr; }
        .table-responsive { display: none !important; }
        .poll-card { display: block; }
    }
    @@media (max-width: 480px) {
        .kpi-container { grid-template-columns: 1fr; }
        .dash-hero-text h2 { font-size: 1.2rem; }
    }
    @@media (min-width: 769px) { .table-actions { flex-wrap: nowrap; } }
</style>

<!-- ── Hero Banner ─────────────────────────────────────────────── -->
<div class="dash-hero">
    <div class="dash-hero-inner">
        <div class="dash-hero-text">
            <h2><i class="bi bi-speedometer2 me-2" style="color:#14b8a6;"></i>Polling Dashboard</h2>
            <p>Manage your polls, monitor voter activity, and track results.</p>
        </div>
        <div class="dash-hero-actions">
            <a class="btn btn-success" href="/Admin/Polls/Create">
                <i class="bi bi-plus-circle me-2"></i>Create New Poll
            </a>
        </div>
    </div>
</div>

<!-- ── KPI Cards ──────────────────────────────────────────────── -->
<div class="kpi-container">
    <div class="kpi-card">
        <div class="kpi-card-top">
            <div class="kpi-info">
                <span class="kpi-value">@ViewBag.TotalPollsCount</span>
                <span class="kpi-label">Total Polls</span>
            </div>
            <div class="kpi-icon-wrapper polls"><i class="bi bi-list-check"></i></div>
        </div>
        <div class="kpi-bar polls"></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <div class="kpi-info">
                <span class="kpi-value">@ViewBag.ActivePollsCount</span>
                <span class="kpi-label">Active Polls</span>
            </div>
            <div class="kpi-icon-wrapper active"><i class="bi bi-activity"></i></div>
        </div>
        <div class="kpi-bar active"></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <div class="kpi-info">
                <span class="kpi-value">@ViewBag.TotalVotersCount</span>
                <span class="kpi-label">Registered Voters</span>
            </div>
            <div class="kpi-icon-wrapper voters"><i class="bi bi-people"></i></div>
        </div>
        <div class="kpi-bar voters"></div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card-top">
            <div class="kpi-info">
                <span class="kpi-value">@ViewBag.TotalTemplatesCount</span>
                <span class="kpi-label">Ballot Templates</span>
            </div>
            <div class="kpi-icon-wrapper templates"><i class="bi bi-ticket-perforated"></i></div>
        </div>
        <div class="kpi-bar templates"></div>
    </div>
</div>

<!-- Recent Activity Feed -->
<h4 class="section-title"><i class="bi bi-clock-history" style="color:#14b8a6;"></i>Recent Activity</h4>
@{
    var allActivity = ViewBag.AllActivityItems as List<ActivityItem>;
    var activityJson = System.Text.Json.JsonSerializer.Serialize(
        (allActivity ?? new List<ActivityItem>()).Select(a => new {
            kind = a.Kind,
            description = a.Description,
            when = a.HasTimestamp ? a.When.ToString("o") : (string?)null
        })
    );
}

<div class="activity-card">
    <!-- Card header: search + filter pills -->
    <div class="activity-card-header">
        <div class="activity-search-wrap">
            <div class="input-group input-group-sm">
                <span class="input-group-text border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" id="activitySearch" class="form-control" placeholder="Search activity...">
            </div>
        </div>
        <div class="act-pills">
            <button class="act-pill active-all act-filter" data-kind="all">All</button>
            <button class="act-pill act-filter" data-kind="vote">
                <i class="bi bi-check2-circle me-1"></i>Votes
            </button>
            <button class="act-pill act-filter" data-kind="poll">
                <i class="bi bi-collection me-1"></i>Polls
            </button>
            <button class="act-pill act-filter" data-kind="voter">
                <i class="bi bi-person-plus me-1"></i>Voters
            </button>
        </div>
    </div>

    <!-- Feed rows rendered by JS -->
    <div class="activity-feed" id="activityFeedWrap">
        <div id="activityList"></div>
        <div id="activityEmpty" class="text-center py-5" style="display:none;">
            <i class="bi bi-search" style="font-size:1.5rem; color:#cbd5e1; display:block; margin-bottom:.5rem;"></i>
            <span style="font-size:0.8375rem; color:#94a3b8;">No matching activity found.</span>
        </div>
    </div>

    <!-- Card footer: count + prev/next -->
    <div class="activity-card-footer" id="activityPager" style="display:none;">
        <span id="activityInfo"></span>
        <div style="display:flex; gap:.4rem;">
            <button id="actPrev" class="act-pager-btn" onclick="actPage(-1)">
                <i class="bi bi-chevron-left"></i> Prev
            </button>
            <button id="actNext" class="act-pager-btn" onclick="actPage(1)">
                Next <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
</div>

<script>
(function () {
    const PAGE_SIZE = 5;
    const raw = @Html.Raw(activityJson);
    let filtered = [...raw];
    let currentPage = 1;
    let currentKind = 'all';
    let searchTerm = '';

    function timeAgo(iso) {
        if (!iso) return 'Recently added';
        const diff = (Date.now() - new Date(iso)) / 1000;
        if (diff < 60)    return Math.floor(diff) + 's ago';
        if (diff < 3600)  return Math.floor(diff / 60) + 'm ago';
        if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
        return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
    }

    function kindIcon(k) {
        return k === 'vote' ? 'bi-check2-circle' : k === 'poll' ? 'bi-collection' : 'bi-person-plus';
    }

    function render() {
        filtered = raw.filter(item =>
            (currentKind === 'all' || item.kind === currentKind) &&
            (!searchTerm || item.description.toLowerCase().includes(searchTerm.toLowerCase()))
        );

        const total = filtered.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;

        const start = (currentPage - 1) * PAGE_SIZE;
        const page  = filtered.slice(start, start + PAGE_SIZE);

        const list  = document.getElementById('activityList');
        const empty = document.getElementById('activityEmpty');
        const pager = document.getElementById('activityPager');
        const info  = document.getElementById('activityInfo');

        if (page.length === 0) {
            list.innerHTML = '';
            empty.style.display = '';
            pager.style.display = 'none';
        } else {
            empty.style.display = 'none';
            pager.style.display = 'flex';
            list.innerHTML = page.map(item => `
                <div class="activity-item">
                    <div class="activity-icon ${item.kind}">
                        <i class="bi ${kindIcon(item.kind)}"></i>
                    </div>
                    <span class="activity-text">${item.description}</span>
                    <span class="activity-time">${timeAgo(item.when)}</span>
                </div>`).join('');
        }

        const end = Math.min(start + PAGE_SIZE, total);
        info.textContent = total > 0 ? `Showing ${start + 1}–${end} of ${total}` : '';
        document.getElementById('actPrev').disabled = currentPage <= 1;
        document.getElementById('actNext').disabled = currentPage >= totalPages;
    }

    window.actPage = function (dir) {
        const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        currentPage = Math.min(Math.max(1, currentPage + dir), totalPages);
        render();
    };

    document.getElementById('activitySearch').addEventListener('input', function () {
        searchTerm = this.value;
        currentPage = 1;
        render();
    });

    const pillActiveMap = { all: 'active-all', vote: 'active-vote', poll: 'active-poll', voter: 'active-voter' };

    document.querySelectorAll('.act-filter').forEach(btn => {
        btn.addEventListener('click', function () {
            currentKind = this.dataset.kind;
            currentPage = 1;
            // Reset all pills
            document.querySelectorAll('.act-filter').forEach(b => {
                b.className = 'act-pill act-filter';
                const icon = b.dataset.kind !== 'all' ? b.querySelector('i') : null;
            });
            // Activate clicked
            this.classList.add(pillActiveMap[currentKind]);
            render();
        });
    });

    render();
})();
</script>


