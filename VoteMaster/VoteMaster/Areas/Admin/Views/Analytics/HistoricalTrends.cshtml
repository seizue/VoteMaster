@model List<VoteMaster.Models.Analytics.HistoricalTrendDto>
@{
    ViewData["Title"] = "Historical Trends";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<style>
    .analytics-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .analytics-header h3 {
        margin: 0;
        flex: 1;
        min-width: 150px;
        font-weight: 700;
        color: var(--vm-text-primary);
        font-size: 1.75rem;
    }
    .summary-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .summary-card {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        padding: 1.75rem;
        box-shadow: var(--vm-shadow-sm);
        transition: all 0.2s ease;
        text-align: center;
    }
    .summary-card:hover {
        box-shadow: var(--vm-shadow-md);
        transform: translateY(-2px);
    }
    .summary-card h6 {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--vm-text-secondary);
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .summary-card h2 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
    }
    .summary-card.primary h2 {
        color: var(--vm-accent);
    }
    .summary-card.success h2 {
        color: #10b981;
    }
    .summary-card.info h2 {
        color: #06b6d4;
    }
    
    /* Mobile card view for table */
    .trend-card {
        display: none;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        background: white;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--vm-shadow-sm);
        transition: all 0.2s ease;
    }
    .trend-card:hover {
        box-shadow: var(--vm-shadow-md);
        transform: translateY(-2px);
    }
    .trend-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--vm-border);
    }
    .trend-card-date {
        font-weight: 700;
        font-size: 1.125rem;
        color: var(--vm-text-primary);
    }
    .trend-card-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    .trend-stat {
        text-align: center;
        padding: 1rem;
        background: #f8fafc;
        border-radius: 0.75rem;
        border: 1px solid var(--vm-border);
    }
    .trend-stat-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--vm-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }
    .trend-stat-value {
        font-size: 1.5rem;
        font-weight: 700;
    }
    .trend-stat-value.primary {
        color: var(--vm-accent);
    }
    .trend-stat-value.success {
        color: #10b981;
    }
    .trend-card-participation {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--vm-border);
    }
    .trend-card-participation-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--vm-text-secondary);
        margin-bottom: 0.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    @@media (max-width: 768px) {
        .analytics-header {
            flex-direction: column;
            align-items: stretch;
        }
        .analytics-header h3 {
            font-size: 1.5rem;
        }
        .analytics-header .btn {
            width: 100%;
        }
        .summary-cards {
            grid-template-columns: 1fr;
        }
        .summary-card {
            padding: 1.25rem;
        }
        .summary-card h6 {
            font-size: 0.75rem;
        }
        .summary-card h2 {
            font-size: 1.75rem;
        }
        
        .card .card-header h5 {
            font-size: 1rem;
        }
        
        /* Hide table, show cards on mobile */
        .table-responsive {
            display: none !important;
        }
        .trend-card {
            display: block;
        }
    }
    
    @@media (max-width: 480px) {
        .analytics-header h3 {
            font-size: 1.25rem;
        }
        .trend-card {
            padding: 1rem;
        }
        .trend-card-date {
            font-size: 1rem;
        }
        .trend-stat-value {
            font-size: 1.25rem;
        }
    }
</style>

<div class="analytics-header">
    <h3><i class="bi bi-clock-history me-2"></i>Historical Trends</h3>
</div>

    <!-- Date Range Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="HistoricalTrends" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="startDate" class="form-label" style="font-weight: 600; color: var(--vm-text-primary);">Start Date</label>
                    <input type="date" class="form-control" id="startDate" name="startDate" value="@ViewBag.StartDate">
                </div>
                <div class="col-md-4">
                    <label for="endDate" class="form-label" style="font-weight: 600; color: var(--vm-text-primary);">End Date</label>
                    <input type="date" class="form-control" id="endDate" name="endDate" value="@ViewBag.EndDate">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-2"></i>Apply Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No data available for the selected date range.
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="summary-cards">
            <div class="summary-card primary">
                <h6>Total Polls Created</h6>
                <h2>@Model.Sum(t => t.PollsCreated)</h2>
            </div>
            <div class="summary-card success">
                <h6>Total Votes Cast</h6>
                <h2>@Model.Sum(t => t.TotalVotes)</h2>
            </div>
            <div class="summary-card info">
                <h6>Avg Participation Rate</h6>
                <h2>@(Model.Any() ? $"{Model.Average(t => t.AverageParticipation):F1}%" : "0%")</h2>
            </div>
        </div>

        <!-- Charts -->
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header" style="background: #f8fafc; border-bottom: 1px solid var(--vm-border); padding: 1.25rem 1.5rem;">
                        <h5 class="mb-0" style="font-weight: 700; color: var(--vm-text-primary);">Polls Created Over Time</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="pollsCreatedChart" height="100"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header" style="background: #f8fafc; border-bottom: 1px solid var(--vm-border); padding: 1.25rem 1.5rem;">
                        <h5 class="mb-0" style="font-weight: 700; color: var(--vm-text-primary);">Votes Cast Over Time</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="votesCastChart" height="100"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-lg-12 mb-4">
                <div class="card">
                    <div class="card-header" style="background: #f8fafc; border-bottom: 1px solid var(--vm-border); padding: 1.25rem 1.5rem;">
                        <h5 class="mb-0" style="font-weight: 700; color: var(--vm-text-primary);">Participation Rate Trend</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="participationChart" height="50"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Table -->
        <div class="card">
            <div class="card-header" style="background: #f8fafc; border-bottom: 1px solid var(--vm-border); padding: 1.25rem 1.5rem;">
                <h5 class="mb-0" style="font-weight: 700; color: var(--vm-text-primary);">Detailed Breakdown</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Polls Created</th>
                                <th>Total Votes</th>
                                <th>Avg Participation</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var trend in Model.OrderByDescending(t => t.Date))
                            {
                                <tr>
                                    <td style="font-weight: 600; color: var(--vm-text-primary);">@trend.Date.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <span class="badge bg-primary">@trend.PollsCreated</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-success">@trend.TotalVotes</span>
                                    </td>
                                    <td>
                                        <div class="progress" style="height: 28px; border-radius: 0.5rem;">
                                            <div class="progress-bar @(trend.AverageParticipation >= 75 ? "bg-success" : trend.AverageParticipation >= 50 ? "bg-info" : trend.AverageParticipation >= 25 ? "bg-warning" : "bg-danger")" 
                                                 role="progressbar" 
                                                 style="width: @(trend.AverageParticipation)%"
                                                 aria-valuenow="@trend.AverageParticipation" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100">
                                                <span style="font-weight: 600;">@trend.AverageParticipation.ToString("F1")%</span>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <!-- Mobile Card View -->
        @foreach (var trend in Model.OrderByDescending(t => t.Date))
        {
            <div class="trend-card">
                <div class="trend-card-header">
                    <div class="trend-card-date">
                        <i class="bi bi-calendar-event me-2"></i>@trend.Date.ToString("MMM dd, yyyy")
                    </div>
                </div>
                <div class="trend-card-stats">
                    <div class="trend-stat">
                        <div class="trend-stat-label">Polls Created</div>
                        <div class="trend-stat-value primary">@trend.PollsCreated</div>
                    </div>
                    <div class="trend-stat">
                        <div class="trend-stat-label">Total Votes</div>
                        <div class="trend-stat-value success">@trend.TotalVotes</div>
                    </div>
                </div>
                <div class="trend-card-participation">
                    <div class="trend-card-participation-label">
                        <span>Participation Rate</span>
                        <span style="font-weight: 700; color: var(--vm-text-primary);">@trend.AverageParticipation.ToString("F1")%</span>
                    </div>
                    <div class="progress" style="height: 28px; border-radius: 0.5rem;">
                        <div class="progress-bar @(trend.AverageParticipation >= 75 ? "bg-success" : trend.AverageParticipation >= 50 ? "bg-info" : trend.AverageParticipation >= 25 ? "bg-warning" : "bg-danger")" 
                             role="progressbar" 
                             style="width: @(trend.AverageParticipation)%"
                             aria-valuenow="@trend.AverageParticipation" 
                             aria-valuemin="0" 
                             aria-valuemax="100">
                            <span style="font-weight: 600;">@trend.AverageParticipation.ToString("F1")%</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Back Button -->
<div class="mt-4 text-center">
    <a href="/Admin/Analytics" class="btn btn-dark">
        <i class="bi bi-arrow-left me-2"></i>Back to Analytics
    </a>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        @if (Model.Any())
        {
            <text>
            const labels = @Html.Raw(Json.Serialize(Model.Select(t => t.Date.ToString("MMM dd"))));

            // Polls Created Chart
            const pollsCreatedCtx = document.getElementById('pollsCreatedChart').getContext('2d');
            new Chart(pollsCreatedCtx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Polls Created',
                        data: @Html.Raw(Json.Serialize(Model.Select(t => t.PollsCreated))),
                        backgroundColor: 'rgba(20, 184, 166, 0.6)',
                        borderColor: 'rgba(20, 184, 166, 1)',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });

            // Votes Cast Chart
            const votesCastCtx = document.getElementById('votesCastChart').getContext('2d');
            new Chart(votesCastCtx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Total Votes',
                        data: @Html.Raw(Json.Serialize(Model.Select(t => t.TotalVotes))),
                        borderColor: 'rgba(16, 185, 129, 1)',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });

            // Participation Chart
            const participationCtx = document.getElementById('participationChart').getContext('2d');
            new Chart(participationCtx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Average Participation %',
                        data: @Html.Raw(Json.Serialize(Model.Select(t => t.AverageParticipation))),
                        borderColor: 'rgba(6, 182, 212, 1)',
                        backgroundColor: 'rgba(6, 182, 212, 0.1)',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100,
                            ticks: {
                                callback: function(value) {
                                    return value + '%';
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        }
                    }
                }
            });
            </text>
        }
    </script>
}

