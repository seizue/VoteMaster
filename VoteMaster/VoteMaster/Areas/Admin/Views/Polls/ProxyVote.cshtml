@model List<VoteMaster.Models.AppUser>
@using VoteMaster.Models
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var poll         = ViewBag.Poll as Poll;
    var votedIds     = (ViewBag.VotedIds as HashSet<int>) ?? new HashSet<int>();
    var pending      = Model?.Where(u => !votedIds.Contains(u.Id)).ToList() ?? new List<AppUser>();
    var alreadyVoted = Model?.Where(u => votedIds.Contains(u.Id)).ToList() ?? new List<AppUser>();
    var options      = poll?.Options.OrderBy(o => o.Text).ToList() ?? new List<PollOption>();
    int min          = poll?.MinVotesPerVoter ?? 1;
    int max          = poll?.MaxVotesPerVoter ?? 1;
}

<style>
    .pv-header { margin-bottom: 1.75rem; }
    .pv-header h3 { font-weight: 700; color: #0f172a; margin-bottom: 0.25rem; }

    .pv-info { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .pv-badge {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.45rem 0.9rem; border-radius: 2rem;
        font-size: 0.82rem; font-weight: 600;
        background: #f1f5f9; color: #475569; border: 1px solid #e2e8f0;
    }
    .pv-badge.accent { background: #eef2ff; color: #4338ca; border-color: #c7d2fe; }

    /* ── Pagination bar ── */
    .pv-pagination-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1rem;
        padding: 0.75rem 1rem;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
    }
    .pv-page-info { font-size: 0.85rem; color: #64748b; }
    .pv-page-info strong { color: #0f172a; }
    .pv-other-pages-badge {
        display: none;
        align-items: center; gap: 0.35rem;
        padding: 0.3rem 0.7rem; border-radius: 2rem;
        font-size: 0.78rem; font-weight: 700;
        background: #fef9c3; color: #92400e; border: 1px solid #fde68a;
    }
    .pv-other-pages-badge.visible { display: inline-flex; }

    /* ── Desktop table ── */
    .pv-table-wrap { overflow-x: auto; }
    .pv-table {
        width: 100%; border-collapse: separate; border-spacing: 0; min-width: 480px;
    }
    .pv-table thead th {
        background: #f8fafc; padding: 0.75rem 1rem;
        font-size: 0.8125rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.04em;
        color: #64748b; border-bottom: 2px solid #e2e8f0; white-space: nowrap;
    }
    .pv-table tbody tr:hover { background: #f8fafc; }
    .pv-table tbody td {
        padding: 0.75rem 1rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle;
    }
    .pv-table tbody tr:last-child td { border-bottom: none; }
    /* rows hidden by pagination — still in DOM so inputs submit */
    .pv-table tbody tr.pv-hidden { display: none; }

    .voter-identity { display: flex; align-items: center; gap: 0.625rem; min-width: 130px; }
    .voter-avatar {
        width: 34px; height: 34px; border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white; display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.875rem; flex-shrink: 0;
    }
    .voter-name   { font-weight: 600; color: #0f172a; font-size: 0.9375rem; }
    .voter-weight { font-size: 0.72rem; color: #94a3b8; margin-top: 0.05rem; }

    .opt-cell { text-align: center; min-width: 90px; }
    .opt-checkbox { width: 20px; height: 20px; accent-color: #6366f1; cursor: pointer; }

    .vote-counter {
        display: inline-flex; align-items: center; gap: 0.3rem;
        min-width: 54px; padding: 0.3rem 0.6rem; border-radius: 0.5rem;
        font-size: 0.82rem; font-weight: 700;
        background: #f1f5f9; color: #475569; transition: background 0.15s, color 0.15s;
    }
    .vote-counter.ok    { background: #dcfce7; color: #16a34a; }
    .vote-counter.over  { background: #fee2e2; color: #dc2626; }
    .vote-counter.under { background: #fef9c3; color: #ca8a04; }

    /* ── Mobile cards ── */
    .pv-cards { display: none; }
    .pv-voter-card {
        background: white; border: 1px solid #e2e8f0; border-radius: 1rem;
        padding: 1.125rem; margin-bottom: 1rem;
        box-shadow: 0 1px 4px rgba(15,23,42,0.07);
    }
    .pv-voter-card.pv-hidden { display: none !important; }
    .pv-voter-card-header { display: flex; align-items: center; gap: 0.625rem; margin-bottom: 1rem; }
    .pv-options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
    .pv-option-btn {
        display: flex; align-items: center; gap: 0.5rem;
        padding: 0.6rem 0.75rem; border: 2px solid #e2e8f0; border-radius: 0.65rem;
        cursor: pointer; font-size: 0.875rem; font-weight: 500;
        color: #475569; background: white;
        transition: border-color 0.15s, background 0.15s, color 0.15s; user-select: none;
    }
    .pv-option-btn:hover { border-color: #a5b4fc; background: #f5f3ff; }
    .pv-option-btn.selected { border-color: #6366f1; background: #eef2ff; color: #4338ca; }
    .pv-option-check {
        width: 18px; height: 18px; border-radius: 4px; border: 2px solid #cbd5e1;
        flex-shrink: 0; display: flex; align-items: center; justify-content: center;
        font-size: 0.65rem; transition: border-color 0.15s, background 0.15s;
    }
    .pv-option-btn.selected .pv-option-check { background: #6366f1; border-color: #6366f1; color: white; }

    /* ── Bottom pagination ── */
    .pv-pagination { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
    .pv-pagination .page-link {
        min-width: 36px; text-align: center;
        border-radius: 0.5rem !important;
        font-size: 0.875rem; font-weight: 600;
    }

    .already-voted-section { margin-top: 2rem; }
    .already-voted-section summary {
        cursor: pointer; font-weight: 600; color: #64748b; padding: 0.5rem 0; user-select: none;
    }

    @@media (max-width: 768px) {
        .pv-table-wrap { display: none; }
        .pv-cards      { display: block; }
    }
    @@media (max-width: 480px) {
        .pv-options-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="pv-header">
    <h3><i class="bi bi-person-check-fill me-2"></i>Proxy Voting</h3>
    <p class="text-muted small mb-0">@poll?.Title</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="pv-info">
    <span class="pv-badge"><i class="bi bi-people-fill"></i>@pending.Count pending voter(s)</span>
    <span class="pv-badge"><i class="bi bi-check2-square"></i>Select @min–@max option(s) per voter</span>
    <span class="pv-badge"><i class="bi bi-list-ul"></i>@options.Count option(s)</span>
</div>

@if (pending.Count == 0)
{
    <div class="card p-5 text-center text-muted">
        <i class="bi bi-check-circle-fill fs-1 d-block mb-2 text-success"></i>
        <strong>All voters have already voted!</strong>
        <p class="mb-0 mt-1">There are no pending voters left to proxy-vote for.</p>
    </div>
}
else
{
    <form method="post"
          action="@Url.Action("ProxyVote", "Polls", new { area = "Admin", id = poll!.Id })"
          id="proxyForm">
        @Html.AntiForgeryToken()

        @* ── Pagination bar (top) ── *@
        <div class="pv-pagination-bar">
            <div class="pv-page-info" id="pvPageInfo">
                Showing <strong id="pvRangeFrom">1</strong>–<strong id="pvRangeTo">100</strong>
                of <strong>@pending.Count</strong> voters
            </div>
            <span class="pv-other-pages-badge" id="pvOtherPagesBadge">
                <i class="bi bi-check2-square"></i>
                <span id="pvOtherPagesCount">0</span> voter(s) selected on other pages
            </span>
            <nav aria-label="Proxy vote pages">
                <ul class="pagination pv-pagination mb-0" id="pvPaginationTop"></ul>
            </nav>
        </div>

        @* ── Desktop table — ALL rows always in DOM, pagination hides/shows via class ── *@
        <div class="card pv-table-wrap">
            <table class="pv-table">
                <thead>
                    <tr>
                        <th>Voter</th>
                        @foreach (var opt in options)
                        {
                            <th class="opt-cell" title="@opt.Text">
                                @(opt.Text.Length > 18 ? opt.Text[..18] + "…" : opt.Text)
                            </th>
                        }
                        <th class="opt-cell">Selected</th>
                        <th class="opt-cell">Clear</th>
                    </tr>
                </thead>
                <tbody id="pvTableBody">
                    @foreach (var voter in pending)
                    {
                        var initials = voter.Username.Length > 0 ? voter.Username[0].ToString().ToUpper() : "?";
                        <tr data-user-id="@voter.Id" class="pv-hidden">
                            <td>
                                <input type="hidden" name="userId_@voter.Id" value="@voter.Id" />
                                <div class="voter-identity">
                                    <div class="voter-avatar">@initials</div>
                                    <div>
                                        <div class="voter-name">@voter.Username</div>
                                        <div class="voter-weight">weight: @voter.Weight</div>
                                    </div>
                                </div>
                            </td>
                            @foreach (var opt in options)
                            {
                                <td class="opt-cell">
                                    <input type="checkbox"
                                           class="opt-checkbox"
                                           name="vote_@(voter.Id)_@(opt.Id)"
                                           id="chk_@(voter.Id)_@(opt.Id)"
                                           value="1"
                                           data-voter="@voter.Id"
                                           data-option="@opt.Id"
                                           onchange="onTableCheck(this)" />
                                </td>
                            }
                            <td class="opt-cell">
                                <span class="vote-counter under" id="counter_@voter.Id">0</span>
                            </td>
                            <td class="opt-cell">
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        onclick="clearVoterRow('@voter.Id')"
                                        title="Clear @voter.Username">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* ── Mobile cards — visual mirrors of the table rows ── *@
        <div class="pv-cards" id="pvCardsWrap">
            @foreach (var voter in pending)
            {
                var initials = voter.Username.Length > 0 ? voter.Username[0].ToString().ToUpper() : "?";
                <div class="pv-voter-card pv-hidden" data-user-id="@voter.Id">
                    <div class="pv-voter-card-header">
                        <div class="voter-avatar">@initials</div>
                        <div class="flex-grow-1">
                            <div class="voter-name">@voter.Username</div>
                            <div class="voter-weight">weight: @voter.Weight</div>
                        </div>
                        <span class="vote-counter under" id="mcounter_@voter.Id">0</span>
                    </div>
                    <div class="pv-options-grid">
                        @foreach (var opt in options)
                        {
                            <div class="pv-option-btn"
                                 id="mbtn_@(voter.Id)_@(opt.Id)"
                                 onclick="toggleMobileOpt('@voter.Id', '@opt.Id', this)">
                                <span class="pv-option-check"><i class="bi bi-check"></i></span>
                                <span>@opt.Text</span>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* ── Bottom pagination + submit bar ── *@
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
            <nav aria-label="Proxy vote pages bottom">
                <ul class="pagination pv-pagination mb-0" id="pvPaginationBottom"></ul>
            </nav>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3 pt-3 border-top">
            <span class="text-muted small">
                <i class="bi bi-info-circle me-1"></i>Selections are kept across pages. Voters with nothing selected are skipped.
            </span>
            <div class="d-flex gap-2 flex-wrap">
                <button type="button" class="btn btn-outline-secondary" onclick="clearAll()">
                    <i class="bi bi-x-circle me-2"></i>Clear All
                </button>
                <a class="btn btn-dark" href="@Url.Action("Index", "Polls", new { area = "Admin" })">
                    <i class="bi bi-arrow-left me-2"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="bi bi-person-check me-2"></i>Submit Proxy Votes
                </button>
            </div>
        </div>
    </form>
}

@if (alreadyVoted.Count > 0)
{
    <details class="already-voted-section">
        <summary>
            <i class="bi bi-check-circle-fill text-success me-1"></i>
            @alreadyVoted.Count voter(s) already voted (read-only)
        </summary>
        <div class="card mt-2">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead><tr><th>Username</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var voter in alreadyVoted)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold">@voter.Username</td>
                                    <td class="align-middle">
                                        <span class="badge bg-success px-3 py-2">
                                            <i class="bi bi-check-lg me-1"></i>Voted
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </details>
}

<div class="mt-3">
    <a href="@Url.Action("VoterStatus", "Polls", new { area = "Admin", id = poll?.Id })"
       class="btn btn-outline-secondary">
        <i class="bi bi-people me-2"></i>View Voter Status
    </a>
</div>

@section Scripts {
<script>
(function () {
    const MIN          = @min;
    const MAX          = @max;
    const PAGE_SIZE    = 100;

    // ── Collect all row/card pairs once ──────────────────────────────────────
    const tableRows = Array.from(document.querySelectorAll('#pvTableBody tr[data-user-id]'));
    const totalRows = tableRows.length;
    let   currentPage = 1;
    const totalPages  = Math.max(1, Math.ceil(totalRows / PAGE_SIZE));

    // ── Pagination render ─────────────────────────────────────────────────────
    function renderPagination() {
        ['pvPaginationTop', 'pvPaginationBottom'].forEach(function (id) {
            var ul = document.getElementById(id);
            if (!ul) return;
            ul.innerHTML = '';
            if (totalPages <= 1) return;

            // Prev
            var li = document.createElement('li');
            li.className = 'page-item' + (currentPage === 1 ? ' disabled' : '');
            li.innerHTML = '<a class="page-link" href="#" onclick="goPage(' + (currentPage - 1) + ');return false;">' +
                           '<i class="bi bi-chevron-left"></i></a>';
            ul.appendChild(li);

            // Pages (show window of 7 around current)
            var start = Math.max(1, currentPage - 3);
            var end   = Math.min(totalPages, start + 6);
            if (end - start < 6) start = Math.max(1, end - 6);

            if (start > 1) {
                ul.appendChild(makeLi(1));
                if (start > 2) ul.appendChild(makeDots());
            }
            for (var p = start; p <= end; p++) ul.appendChild(makeLi(p));
            if (end < totalPages) {
                if (end < totalPages - 1) ul.appendChild(makeDots());
                ul.appendChild(makeLi(totalPages));
            }

            // Next
            var li2 = document.createElement('li');
            li2.className = 'page-item' + (currentPage === totalPages ? ' disabled' : '');
            li2.innerHTML = '<a class="page-link" href="#" onclick="goPage(' + (currentPage + 1) + ');return false;">' +
                            '<i class="bi bi-chevron-right"></i></a>';
            ul.appendChild(li2);
        });
    }

    function makeLi(p) {
        var li = document.createElement('li');
        li.className = 'page-item' + (p === currentPage ? ' active' : '');
        li.innerHTML = '<a class="page-link" href="#" onclick="goPage(' + p + ');return false;">' + p + '</a>';
        return li;
    }
    function makeDots() {
        var li = document.createElement('li');
        li.className = 'page-item disabled';
        li.innerHTML = '<span class="page-link">…</span>';
        return li;
    }

    // ── Show / hide rows for current page ────────────────────────────────────
    function applyPage() {
        var start = (currentPage - 1) * PAGE_SIZE; // 0-based
        var end   = start + PAGE_SIZE;

        tableRows.forEach(function (row, idx) {
            var uid     = row.dataset.userId;
            var visible = idx >= start && idx < end;
            row.classList.toggle('pv-hidden', !visible);

            var card = document.querySelector('.pv-voter-card[data-user-id="' + uid + '"]');
            if (card) card.classList.toggle('pv-hidden', !visible);
        });

        // Update range label
        document.getElementById('pvRangeFrom').textContent = start + 1;
        document.getElementById('pvRangeTo').textContent   = Math.min(end, totalRows);

        updateOtherPagesBadge();
        renderPagination();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ── "X selected on other pages" badge ────────────────────────────────────
    function updateOtherPagesBadge() {
        var start = (currentPage - 1) * PAGE_SIZE;
        var end   = start + PAGE_SIZE;
        var count = 0;
        tableRows.forEach(function (row, idx) {
            if (idx >= start && idx < end) return; // current page — skip
            if (row.querySelectorAll('input.opt-checkbox:checked').length > 0) count++;
        });
        var badge = document.getElementById('pvOtherPagesBadge');
        var span  = document.getElementById('pvOtherPagesCount');
        if (badge && span) {
            span.textContent = count;
            badge.classList.toggle('visible', count > 0);
        }
    }

    // Public: change page
    window.goPage = function (p) {
        if (p < 1 || p > totalPages) return;
        currentPage = p;
        applyPage();
    };

    // ── Counter helpers ───────────────────────────────────────────────────────
    function colorClass(n) {
        return n === 0 ? 'under' : n < MIN ? 'under' : n > MAX ? 'over' : 'ok';
    }

    function updateCounter(userId) {
        var row     = document.querySelector('tr[data-user-id="' + userId + '"]');
        var counter = document.getElementById('counter_' + userId);
        if (!row || !counter) return;
        var checked = row.querySelectorAll('input.opt-checkbox:checked').length;
        counter.textContent = checked;
        counter.className   = 'vote-counter ' + colorClass(checked);
        var mc = document.getElementById('mcounter_' + userId);
        if (mc) { mc.textContent = checked; mc.className = 'vote-counter ' + colorClass(checked); }
        updateOtherPagesBadge();
    }

    // ── Desktop checkbox change ───────────────────────────────────────────────
    window.onTableCheck = function (checkbox) {
        var uid = checkbox.dataset.voter;
        var oid = checkbox.dataset.option;
        var mbtn = document.getElementById('mbtn_' + uid + '_' + oid);
        if (mbtn) mbtn.classList.toggle('selected', checkbox.checked);
        updateCounter(uid);
    };

    // ── Mobile button click ───────────────────────────────────────────────────
    window.toggleMobileOpt = function (uid, oid, btn) {
        var chk = document.getElementById('chk_' + uid + '_' + oid);
        if (!chk) return;
        chk.checked = !chk.checked;
        btn.classList.toggle('selected', chk.checked);
        updateCounter(uid);
    };

    // ── Clear helpers ─────────────────────────────────────────────────────────
    window.clearVoterRow = function (uid) {
        var row = document.querySelector('tr[data-user-id="' + uid + '"]');
        if (row) {
            row.querySelectorAll('input.opt-checkbox').forEach(function (c) {
                c.checked = false;
                var mbtn = document.getElementById('mbtn_' + uid + '_' + c.dataset.option);
                if (mbtn) mbtn.classList.remove('selected');
            });
        }
        updateCounter(uid);
    };

    window.clearAll = function () {
        tableRows.forEach(function (row) { clearVoterRow(row.dataset.userId); });
    };

    // ── Submit validation ─────────────────────────────────────────────────────
    document.getElementById('proxyForm')?.addEventListener('submit', function (e) {
        var anySelected = false;
        var violations  = [];

        tableRows.forEach(function (row) {
            var uid     = row.dataset.userId;
            var checked = row.querySelectorAll('input.opt-checkbox:checked').length;
            if (checked > 0) {
                anySelected = true;
                if (checked < MIN || checked > MAX) {
                    var nameEl = row.querySelector('.voter-name');
                    violations.push((nameEl ? nameEl.textContent.trim() : 'User ' + uid) +
                        ' (' + checked + ' selected, need ' + MIN + '–' + MAX + ')');
                }
            }
        });

        if (!anySelected) {
            e.preventDefault();
            alert('Please select at least one option for at least one voter.');
            return;
        }
        if (violations.length > 0) {
            e.preventDefault();
            alert('Invalid selections:\n\n' + violations.join('\n') +
                '\n\nPlease correct before submitting.');
        }
    });

    // ── Init ──────────────────────────────────────────────────────────────────
    applyPage();

})();
</script>
}
