@using VoteMaster.Models
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var poll = ViewBag.Poll as Poll;
    var title = ViewBag.Title as string ?? poll?.Title ?? "";
    var description = ViewBag.Description as string ?? poll?.Description ?? "";
    var optionsCsv = ViewBag.OptionsCsv as string ?? "";
    var maxVotes = ViewBag.MaxVotes ?? poll?.MaxVotesPerVoter ?? 1;
    var minVotes = ViewBag.MinVotes ?? poll?.MinVotesPerVoter ?? 1;
    var allowPublicResults = ViewBag.AllowPublicResults ?? poll?.AllowPublicResults ?? false;
    var startDateTime = ViewBag.StartDateTime as string ?? "";
    var endDateTime = ViewBag.EndDateTime as string ?? "";
}

<div class="card">
    <div class="card-header">
        <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Poll</h4>
    </div>
    <div class="card-body">
        <form method="post" action="/Admin/Polls/Edit/@(poll?.Id ?? 0)">
            @Html.AntiForgeryToken()
            
            <div class="mb-3">
                <label class="form-label" for="title">Poll Title</label>
                <input type="text" class="form-control" id="title" name="title" value="@(title ?? "")" required />
                <span class="text-danger" asp-validation-for="title"></span>
            </div>
            
            <div class="mb-3">
                <label class="form-label" for="description">Description (optional)</label>
                <textarea class="form-control" id="description" name="description" rows="3">@description</textarea>
            </div>
            
            <div class="mb-3">
                <label class="form-label" for="optionsCsv">Options (comma-separated)</label>
                <input type="text" class="form-control" id="optionsCsv" name="optionsCsv" value="@optionsCsv" required />
                <small class="form-text text-muted">Example: Option A, Option B, Option C</small>
                <span class="text-danger" asp-validation-for="optionsCsv"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="minVotesPerVoter">Minimum Votes Per Voter</label>
                    <input type="number" class="form-control" id="minVotesPerVoter" name="minVotesPerVoter" value="@minVotes" min="1" required />
                    <span class="text-danger" asp-validation-for="minVotesPerVoter"></span>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="maxVotesPerVoter">Maximum Votes Per Voter</label>
                    <input type="number" class="form-control" id="maxVotesPerVoter" name="maxVotesPerVoter" value="@maxVotes" min="1" required />
                    <span class="text-danger" asp-validation-for="maxVotesPerVoter"></span>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="startDateTime">Start Time</label>
                    <input type="datetime-local" class="form-control" id="startDateTime" name="startDateTime" value="@startDateTime" required />
                    <span class="text-danger" asp-validation-for="startDateTime"></span>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="endDateTime">End Time</label>
                    <input type="datetime-local" class="form-control" id="endDateTime" name="endDateTime" value="@endDateTime" required />
                    <span class="text-danger" asp-validation-for="endDateTime"></span>
                </div>
            </div>
            
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="allowPublicResults" name="allowPublicResults" value="true" @(allowPublicResults ? "checked" : "") />
                <label class="form-check-label" for="allowPublicResults">
                    Allow public to view results
                </label>
            </div>
            
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="enableLiveVoteCount" name="enableLiveVoteCount" value="true" @((ViewBag.EnableLiveVoteCount ?? poll?.EnableLiveVoteCount ?? false) ? "checked" : "") />
                <label class="form-check-label" for="enableLiveVoteCount">
                    Enable live vote count updates for users
                </label>
            </div>
            
            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="enablePollNotifications" name="enablePollNotifications" value="true" @((ViewBag.EnablePollNotifications ?? poll?.EnablePollNotifications ?? false) ? "checked" : "") />
                <label class="form-check-label" for="enablePollNotifications">
                    Enable notifications when poll starts/ends
                </label>
            </div>
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>Update Poll
                </button>
                <a class="btn btn-secondary" href="/Admin/Polls">
                    <i class="bi bi-x-circle me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>
