@using VoteMaster.Models
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var poll             = ViewBag.Poll as Poll;
    var voters           = (ViewBag.Voters as List<AppUser>) ?? new List<AppUser>();
    var title            = ViewBag.Title as string ?? poll?.Title ?? "";
    var description      = ViewBag.Description as string ?? poll?.Description ?? "";
    var optionsCsv       = ViewBag.OptionsCsv as string ?? "";
    var maxVotes         = ViewBag.MaxVotes ?? poll?.MaxVotesPerVoter ?? 1;
    var minVotes         = ViewBag.MinVotes ?? poll?.MinVotesPerVoter ?? 1;
    var allowPublicResults = ViewBag.AllowPublicResults ?? poll?.AllowPublicResults ?? false;
    var startDateTime    = ViewBag.StartDateTime as string ?? "";
    var endDateTime      = ViewBag.EndDateTime as string ?? "";

    // Determine if current options match any voter labels (so we can restore toggle state)
    var currentOptions = optionsCsv
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(o => o.Trim('"'))
        .ToList();
    bool hasVoterOptions = false;
    if (voters.Any())
    {
        foreach (var v in voters)
        {
            var lbl = string.IsNullOrWhiteSpace(v.FullName) ? v.Username : v.FullName;
            var lblW = $"{lbl} ({v.Weight.ToString("N0")} {(v.Weight == 1 ? "share" : "shares")})";
            if (currentOptions.Contains(lbl) || currentOptions.Contains(lblW))
            {
                hasVoterOptions = true;
                break;
            }
        }
    }
}

<style>
    .voter-picker-panel {
        background: #f8fafc;
        border: 1px solid var(--vm-border, #e2e8f0);
        border-radius: 0.875rem;
        padding: 1.25rem;
        max-height: 320px;
        overflow-y: auto;
    }
    .voter-picker-panel .voter-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.25rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .voter-picker-panel .voter-item:last-child { border-bottom: none; }
    .voter-item label { flex: 1; cursor: pointer; margin: 0; font-size: 0.9rem; }
    .voter-item .voter-weight { font-size: 0.8rem; color: #64748b; white-space: nowrap; }
    .voter-picker-actions { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; flex-wrap: wrap; align-items: center; }
    .options-mode-toggle .btn-check + .btn { font-size: 0.875rem; }
    .collapse-icon { transition: transform 0.2s ease-in-out; }
    .voter-collapse-btn[aria-expanded="false"] .collapse-icon { transform: rotate(-90deg); }
</style>

<div class="card">
    <div class="card-header">
        <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Poll</h4>
    </div>
    <div class="card-body">
        <form method="post" action="/Admin/Polls/Edit/@(poll?.Id ?? 0)">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label" for="title">Poll Title</label>
                <input type="text" class="form-control" id="title" name="title" value="@title" required />
            </div>

            <div class="mb-3">
                <label class="form-label" for="description">Description (optional)</label>
                <textarea class="form-control" id="description" name="description" rows="3">@description</textarea>
            </div>

            @* Options *@
            <div class="mb-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                    <label class="form-label mb-0 fw-semibold" for="optionsCsv">Options</label>

                    @if (voters.Any())
                    {
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <div class="btn-group btn-group-sm options-mode-toggle" role="group">
                                <input type="radio" class="btn-check" name="optionsMode" id="modeManual" autocomplete="off" @(hasVoterOptions ? "" : "checked") />
                                <label class="btn btn-outline-secondary" for="modeManual">
                                    <i class="bi bi-pencil me-1"></i>Manual CSV
                                </label>
                                <input type="radio" class="btn-check" name="optionsMode" id="modeVoters" autocomplete="off" @(hasVoterOptions ? "checked" : "") />
                                <label class="btn btn-outline-primary" for="modeVoters">
                                    <i class="bi bi-people me-1"></i>Pick from Voters (@voters.Count)
                                </label>
                            </div>
                        </div>
                    }
                </div>

                <input class="form-control" name="optionsCsv" id="optionsCsv"
                       value="@optionsCsv"
                       placeholder="Option A, Option B, Option C"
                       @(hasVoterOptions ? "readonly" : "")
                       required />
                <div class="form-text" id="optionsCsvHelp">
                    @(hasVoterOptions
                        ? "Options are populated automatically from your voter selection."
                        : "Enter each option separated by a comma.")
                </div>

                @if (voters.Any())
                {
                    <div id="voterPickerSection" class="collapse @(hasVoterOptions ? "show" : "") mt-3">
                        <div class="card border">
                            <div class="card-header bg-light py-2 px-3">
                                <button class="btn btn-link text-decoration-none text-dark p-0 w-100 text-start d-flex align-items-center justify-content-between voter-collapse-btn"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#votersCollapsePanel"
                                        aria-expanded="true"
                                        aria-controls="votersCollapsePanel">
                                    <span class="fw-semibold text-secondary">
                                        <i class="bi bi-people me-2 text-primary"></i>Voter List (@voters.Count)
                                    </span>
                                    <i class="bi bi-chevron-down collapse-icon"></i>
                                </button>
                            </div>
                            <div id="votersCollapsePanel" class="collapse show">
                                <div class="card-body p-3">
                                    <div class="voter-picker-actions border-bottom pb-2 mb-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
                                        <div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2" onclick="selectAllVoters(true)" style="font-size:0.8rem;">
                                                <i class="bi bi-check-all me-1"></i>Select All
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2" onclick="selectAllVoters(false)" style="font-size:0.8rem;">
                                                <i class="bi bi-x me-1"></i>Clear All
                                            </button>
                                        </div>
                                        <div class="text-muted small">Checking a voter adds them to options.</div>
                                    </div>

                                    <div class="mb-3 position-relative">
                                        <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-muted">
                                            <i class="bi bi-search"></i>
                                        </span>
                                        <input type="text" id="voterSearchInput" class="form-control ps-5 pe-5"
                                               placeholder="Search voters by name…" oninput="filterVoters()" />
                                        <button type="button" id="clearSearchBtn"
                                                class="btn btn-link position-absolute top-50 end-0 translate-middle-y pe-3 text-muted d-none"
                                                onclick="clearVoterSearch()" style="box-shadow:none;text-decoration:none;">
                                            <i class="bi bi-x-circle-fill"></i>
                                        </button>
                                    </div>

                                    <div id="noVotersFoundMessage" class="text-center py-4 text-muted d-none border rounded-3 bg-light">
                                        <i class="bi bi-search fs-3 mb-2 d-block text-secondary"></i>
                                        No matching voters found
                                    </div>

                                    <div class="voter-picker-panel" style="max-height:250px;overflow-y:auto;">
                                        @foreach (var v in voters)
                                        {
                                            var lbl  = string.IsNullOrWhiteSpace(v.FullName) ? v.Username : v.FullName;
                                            var lblW = $"{lbl} ({v.Weight.ToString("N0")} {(v.Weight == 1 ? "share" : "shares")})";
                                            bool isChecked      = currentOptions.Contains(lbl) || currentOptions.Contains(lblW);
                                            bool weightIncluded = isChecked && currentOptions.Contains(lblW);

                                            <div class="voter-item d-flex align-items-center justify-content-between py-2 border-bottom">
                                                <div class="d-flex align-items-center gap-2">
                                                    <input class="form-check-input flex-shrink-0 voter-checkbox"
                                                           type="checkbox"
                                                           id="voter_@v.Id"
                                                           data-id="@v.Id"
                                                           data-label="@lbl"
                                                           data-weight="@v.Weight"
                                                           onchange="rebuildOptions()"
                                                           @(isChecked ? "checked" : "") />
                                                    <label class="form-check-label ms-1" for="voter_@v.Id">
                                                        <strong>@lbl</strong>
                                                        <span class="text-muted">(@v.Weight.ToString("N0") shares)</span>
                                                    </label>
                                                </div>
                                                <div class="form-check form-switch mb-0">
                                                    <input class="form-check-input voter-weight-toggle"
                                                           type="checkbox"
                                                           role="switch"
                                                           id="weightToggle_@v.Id"
                                                           data-voter-id="@v.Id"
                                                           onchange="rebuildOptions()"
                                                           @(weightIncluded ? "checked" : "") />
                                                    <label class="form-check-label text-muted" for="weightToggle_@v.Id" style="font-size:0.75rem;">
                                                        Include Weight
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="minVotesPerVoter">Minimum Votes Per Voter</label>
                    <input type="number" class="form-control" id="minVotesPerVoter" name="minVotesPerVoter" value="@minVotes" min="1" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="maxVotesPerVoter">Maximum Votes Per Voter</label>
                    <input type="number" class="form-control" id="maxVotesPerVoter" name="maxVotesPerVoter" value="@maxVotes" min="1" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="startDateTime">Start Time</label>
                    <input type="datetime-local" class="form-control" id="startDateTime" name="startDateTime" value="@startDateTime" required />
                    <small class="text-muted">In your local time</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="endDateTime">End Time</label>
                    <input type="datetime-local" class="form-control" id="endDateTime" name="endDateTime" value="@endDateTime" required />
                    <small class="text-muted">In your local time</small>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="allowPublicResults" name="allowPublicResults" value="true" @(allowPublicResults ? "checked" : "") />
                <label class="form-check-label" for="allowPublicResults">Allow public to view results</label>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="enableLiveVoteCount" name="enableLiveVoteCount" value="true"
                       @((ViewBag.EnableLiveVoteCount ?? poll?.EnableLiveVoteCount ?? false) ? "checked" : "") />
                <label class="form-check-label" for="enableLiveVoteCount">Enable live vote count updates for users</label>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="enablePollNotifications" name="enablePollNotifications" value="true"
                       @((ViewBag.EnablePollNotifications ?? poll?.EnablePollNotifications ?? false) ? "checked" : "") />
                <label class="form-check-label" for="enablePollNotifications">Enable notifications when poll starts/ends</label>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="allowUsercodeEntry" name="allowUsercodeEntry" value="true"
                       @((ViewBag.AllowUsercodeEntry ?? poll?.AllowUsercodeEntry ?? false) ? "checked" : "") />
                <label class="form-check-label" for="allowUsercodeEntry">
                    Allow usercode-only entry <span class="text-muted fw-normal">(voters enter only their username — no password needed)</span>
                </label>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="requireAttendance" name="requireAttendance" value="true"
                       @((ViewBag.RequireAttendance ?? poll?.RequireAttendance ?? false) ? "checked" : "") />
                <label class="form-check-label" for="requireAttendance">
                    Require attendance <span class="text-muted fw-normal">(voters must be marked present by admin before they can vote)</span>
                </label>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>Update Poll
                </button>
                <a class="btn btn-secondary" href="/Admin/Polls">
                    <i class="bi bi-x-circle me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@{
    var sharedUsers = ViewBag.SharedUsers as List<VoteMaster.Models.AppUser> ?? new();
    var allAdmins   = ViewBag.AllAdmins   as List<VoteMaster.Models.AppUser> ?? new();
    var sharePoll   = ViewBag.Poll as VoteMaster.Models.Poll;
}

@if (sharePoll != null)
{
    <div class="row justify-content-center mt-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-700 mb-3"><i class="bi bi-share me-2"></i>Share with other Admins</h5>

                @if (sharedUsers.Any())
                {
                    <div class="mb-3">
                        <div class="fw-semibold small text-muted mb-2">Currently shared with:</div>
                        @foreach (var u in sharedUsers)
                        {
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="badge bg-info">@u.Username</span>
                                <form method="post" action="/Admin/Polls/Unshare" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="pollId" value="@sharePoll.Id" />
                                    <input type="hidden" name="withUserId" value="@u.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2">
                                        <i class="bi bi-x"></i> Remove
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                }

                @if (allAdmins.Any())
                {
                    <form method="post" action="/Admin/Polls/Share" class="d-flex gap-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="pollId" value="@sharePoll.Id" />
                        <div class="flex-grow-1">
                            <label class="form-label small fw-semibold">Add admin:</label>
                            <select name="withUserId" class="form-select form-select-sm">
                                @foreach (var a in allAdmins.Where(a => !sharedUsers.Select(s => s.Id).Contains(a.Id)))
                                {
                                    <option value="@a.Id">@a.Username</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary">
                            <i class="bi bi-share me-1"></i>Share
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-muted small mb-0">No other admins to share with.</p>
                }
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
// ── Mode toggle ──────────────────────────────────────────────────────────────
document.querySelectorAll('input[name="optionsMode"]').forEach(function (radio) {
    radio.addEventListener('change', function () {
        var isVoterMode = document.getElementById('modeVoters').checked;
        var section = document.getElementById('voterPickerSection');
        var csv  = document.getElementById('optionsCsv');
        var help = document.getElementById('optionsCsvHelp');
        if (!section) return;

        var collapseEl = bootstrap.Collapse.getInstance(section) ||
                         new bootstrap.Collapse(section, { toggle: false });

        if (isVoterMode) {
            collapseEl.show();
            csv.setAttribute('readonly', 'readonly');
            help.textContent = 'Options are populated automatically from your voter selection.';
            rebuildOptions();
        } else {
            collapseEl.hide();
            csv.removeAttribute('readonly');
            help.textContent = 'Enter each option separated by a comma.';
        }
    });
});

// ── Build CSV from checked voters ────────────────────────────────────────────
function rebuildOptions() {
    var checked = document.querySelectorAll('.voter-checkbox:checked');
    var parts = Array.from(checked).map(function (cb) {
        var label = cb.dataset.label;
        var voterId = cb.dataset.id;
        var weightToggle = document.getElementById('weightToggle_' + voterId);
        var includeWeight = weightToggle ? weightToggle.checked : false;
        var text = label;
        if (includeWeight) {
            var w = parseInt(cb.dataset.weight, 10);
            text = label + ' (' + w.toLocaleString('en-US') + ' ' + (w === 1 ? 'share' : 'shares') + ')';
        }
        return text.includes(',') ? '"' + text + '"' : text;
    });
    document.getElementById('optionsCsv').value = parts.join(', ');
}

// ── Select / clear all ────────────────────────────────────────────────────────
function selectAllVoters(checked) {
    document.querySelectorAll('.voter-item:not(.d-none) .voter-checkbox').forEach(function (cb) {
        cb.checked = checked;
    });
    rebuildOptions();
}

// ── Search voters ────────────────────────────────────────────────────────────
function filterVoters() {
    var query = (document.getElementById('voterSearchInput').value || '').toLowerCase().trim();
    var clearBtn = document.getElementById('clearSearchBtn');
    clearBtn.classList.toggle('d-none', !query);

    var items = document.querySelectorAll('.voter-item');
    var matchCount = 0;
    items.forEach(function (item) {
        var cb = item.querySelector('.voter-checkbox');
        var show = cb.dataset.label.toLowerCase().includes(query);
        item.classList.toggle('d-none', !show);
        if (show) matchCount++;
    });

    var noMatch = document.getElementById('noVotersFoundMessage');
    var panel   = document.querySelector('.voter-picker-panel');
    if (noMatch) noMatch.classList.toggle('d-none', matchCount > 0);
    if (panel)   panel.classList.toggle('d-none', matchCount === 0);
}

function clearVoterSearch() {
    var input = document.getElementById('voterSearchInput');
    if (input) { input.value = ''; filterVoters(); input.focus(); }
}
</script>
}
