@model IDictionary<string, int>
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var pollId = (int)ViewBag.PollId;
    var sortedResults = Model.OrderByDescending(x => x.Value).ToList();
    var totalVotes = sortedResults.Sum(x => x.Value);
}

<div class="mb-4">
    <h3 class="mb-1" style="font-weight: 700; color: #0f172a;">
        <i class="bi bi-bar-chart-fill me-2"></i>Voting Results
    </h3>
    <p class="text-muted mb-0">Real-time poll results and rankings</p>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0" id="resultsTable">
                <thead>
                    <tr>
                        <th style="width: 100px;">Rank</th>
                        <th>Candidate</th>
                        <th style="width: 120px;" class="text-end">Votes</th>
                        <th style="width: 200px;" class="d-none d-md-table-cell">Distribution</th>
                    </tr>
                </thead>
                <tbody>
                @for (int i = 0; i < sortedResults.Count; i++)
                {
                    var rank = i + 1;
                    var result = sortedResults[i];
                    var percentage = totalVotes > 0 ? (result.Value * 100.0 / totalVotes) : 0;
                    
                    <tr>
                        <td class="align-middle">
                            @if (rank <= 3)
                            {
                                <span class="badge" style="background: @GetRankColor(rank); font-size: 0.9rem; padding: 0.5rem 0.75rem;">
                                    <i class="bi @GetRankIcon(rank) me-1"></i>@rank
                                </span>
                            }
                            else
                            {
                                <span class="text-muted fw-semibold">#@rank</span>
                            }
                        </td>
                        <td class="align-middle fw-semibold" style="color: #1e293b;">@result.Key</td>
                        <td class="align-middle text-end">
                            <span class="badge bg-light text-dark" style="font-size: 0.9rem; padding: 0.5rem 0.75rem;">
                                @result.Value.ToString("N0")
                            </span>
                        </td>
                        <td class="align-middle d-none d-md-table-cell">
                            <div class="progress" style="height: 24px; border-radius: 0.5rem; background: #e0f2fe;">
                                <div class="progress-bar" role="progressbar" 
                                     style="width: @percentage.ToString("F1")%; background: linear-gradient(135deg, #14b8a6 0%, #06b6d4 100%);"
                                     aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                    <span class="fw-semibold" style="font-size: 0.8125rem; color: white;">@percentage.ToString("F1")%</span>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="border-top p-3 bg-light" style="border-radius: 0 0 1rem 1rem;">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-semibold" style="color: #475569;">
                    <i class="bi bi-people-fill me-2"></i>Total Votes
                </span>
                <span class="badge bg-primary" style="font-size: 1rem; padding: 0.5rem 1rem;">
                    @totalVotes.ToString("N0")
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Action Buttons -->
<div class="action-buttons-wrapper">
    <div class="action-buttons-section">
        <h6 class="action-section-title">Analytics & Reports</h6>
        <div class="action-buttons-group">
            <a class="btn btn-outline-secondary" href="/Admin/Analytics/PollDetails/@pollId">
                <i class="bi bi-graph-up me-2"></i>View Analytics
            </a>
            <a class="btn btn-outline-success" href="/Admin/Analytics/ExportCsv/@pollId">
                <i class="bi bi-file-earmark-spreadsheet me-2"></i>Export CSV
            </a>
            <a class="btn btn-outline-danger" href="/Admin/Analytics/ExportPdf/@pollId">
                <i class="bi bi-file-earmark-pdf me-2"></i>Export PDF
            </a>
            <button class="btn btn-outline-primary" onclick="exportToExcel()">
                <i class="bi bi-file-earmark-excel me-2"></i>Export to Excel
            </button>
        </div>
    </div>
    
    <div class="action-buttons-section">
        <h6 class="action-section-title">Share Poll</h6>
        <div class="action-buttons-group">
            <button class="btn btn-outline-primary" onclick="copyPollLink()">
                <i class="bi bi-link-45deg me-2"></i>Copy Link
            </button>
            <button class="btn btn-success" onclick="showQRCode()">
                <i class="bi bi-qr-code me-2"></i>QR Code
            </button>
        </div>
    </div>
    
    <div class="action-buttons-section">
        <div class="action-buttons-group">
            <a class="btn btn-dark" href="/Admin/Dashboard">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>
</div>

@functions {
    private string GetRankIcon(int rank) => rank switch
    {
        1 => "bi-trophy-fill",
        2 => "bi-award-fill",
        3 => "bi-award-fill",
        _ => ""
    };

    private string GetRankColor(int rank) => rank switch
    {
        1 => "linear-gradient(135deg, #FFD700 0%, #FFA500 100%)",
        2 => "linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%)",
        3 => "linear-gradient(135deg, #CD7F32 0%, #B8860B 100%)",
        _ => "#6c757d"
    };
}

<style>
    .progress-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        transition: width 0.6s ease;
    }
    
    .action-buttons-wrapper {
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .action-buttons-section {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: var(--vm-shadow-sm);
    }
    
    .action-section-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--vm-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }
    
    .action-buttons-group {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    
    .action-buttons-group .btn {
        white-space: nowrap;
        flex: 0 1 auto;
    }
    
    .action-buttons-group .btn-outline-secondary {
        border: 2px solid #6b7280;
        color: #6b7280;
    }
    
    .action-buttons-group .btn-outline-secondary:hover {
        background: #6b7280;
        border-color: #6b7280;
        color: white;
    }
    
    .action-buttons-group .btn-outline-success {
        border: 2px solid #10b981;
        color: #10b981;
    }
    
    .action-buttons-group .btn-outline-success:hover {
        background: #10b981;
        border-color: #10b981;
        color: white;
    }
    
    .action-buttons-group .btn-outline-danger {
        border: 2px solid #ef4444;
        color: #ef4444;
    }
    
    .action-buttons-group .btn-outline-danger:hover {
        background: #ef4444;
        border-color: #ef4444;
        color: white;
    }
    
    .action-buttons-group .btn-outline-primary {
        border: 2px solid var(--vm-accent);
        color: var(--vm-accent);
    }
    
    .action-buttons-group .btn-outline-primary:hover {
        background: var(--vm-accent);
        border-color: var(--vm-accent);
        color: white;
    }
    
    @@media (max-width: 768px) {
        .table thead th {
            font-size: 0.8125rem;
            padding: 0.875rem 0.75rem;
        }
        .table tbody td {
            padding: 0.875rem 0.75rem;
        }
        
        .action-buttons-wrapper {
            gap: 1rem;
        }
        
        .action-buttons-section {
            padding: 1.25rem;
        }
        
        .action-section-title {
            font-size: 0.8125rem;
            margin-bottom: 0.75rem;
        }
        
        .action-buttons-group {
            flex-direction: column;
        }
        
        .action-buttons-group .btn {
            width: 100%;
            flex: 1 1 100%;
        }
    }
</style>

<!-- SheetJS library for Excel export -->
<script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>

@section Scripts {
    <script>
        const pollId = @pollId;
        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/results").build();
        connection.on("resultsUpdated", (id) => {
            if (id === pollId) {
                location.reload();
            }
        });
        connection.start();
        
        function exportToExcel() {
            // Collect results data from the table
            const rows = document.querySelectorAll('#resultsTable tbody tr');
            const exportData = [];
            
            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                const rank = cells[0].textContent.trim().replace('#', '');
                const candidate = cells[1].textContent.trim();
                const votes = cells[2].textContent.trim().replace(/,/g, '');
                
                // Calculate percentage
                const totalVotes = @totalVotes;
                const voteCount = parseInt(votes);
                const percentage = totalVotes > 0 ? ((voteCount * 100.0) / totalVotes).toFixed(1) : '0.0';
                
                exportData.push({
                    'Rank': rank,
                    'Candidate': candidate,
                    'Votes': voteCount,
                    'Percentage': percentage + '%'
                });
            });
            
            // Add total row
            exportData.push({
                'Rank': '',
                'Candidate': 'TOTAL',
                'Votes': @totalVotes,
                'Percentage': '100.0%'
            });
            
            // Create workbook and worksheet
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.json_to_sheet(exportData);
            
            // Set column widths
            ws['!cols'] = [
                { wch: 8 },  // Rank
                { wch: 40 }, // Candidate
                { wch: 12 }, // Votes
                { wch: 12 }  // Percentage
            ];
            
            // Add worksheet to workbook
            XLSX.utils.book_append_sheet(wb, ws, 'Results');
            
            // Generate filename with current date
            const now = new Date();
            const filename = `Poll_Results_${pollId}_${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}.xlsx`;
            
            // Save file
            XLSX.writeFile(wb, filename);
            
            // Show success message
            const alert = document.createElement('div');
            alert.className = 'alert alert-success alert-dismissible fade show mt-3';
            alert.innerHTML = '<i class="bi bi-check-circle me-2"></i>Results exported to Excel successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
            document.querySelector('.container').insertAdjacentElement('afterbegin', alert);
            
            setTimeout(() => alert.remove(), 3000);
        }
        
        // Share and QR Code functionality
        const pollUrl = window.location.origin + '/Client/Vote/' + pollId;
        
        function copyPollLink() {
            navigator.clipboard.writeText(pollUrl).then(() => {
                // Show success message
                const alert = document.createElement('div');
                alert.className = 'alert alert-success alert-dismissible fade show';
                alert.style.position = 'fixed';
                alert.style.top = '20px';
                alert.style.right = '20px';
                alert.style.zIndex = '9999';
                alert.innerHTML = '<i class="bi bi-check-circle me-2"></i>Poll link copied to clipboard! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                document.body.appendChild(alert);
                
                setTimeout(() => alert.remove(), 3000);
            }).catch(err => {
                alert('Failed to copy link. Please copy manually: ' + pollUrl);
            });
        }
        
        function showQRCode() {
            // Generate QR code
            const qrContainer = document.getElementById('qrCodeContainer');
            qrContainer.innerHTML = ''; // Clear previous QR code
            
            const qr = new QRCode(qrContainer, {
                text: pollUrl,
                width: 256,
                height: 256,
                colorDark: "#000000",
                colorLight: "#ffffff",
                correctLevel: QRCode.CorrectLevel.H
            });
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('qrCodeModal'));
            modal.show();
        }
        
        function downloadQRCode() {
            const canvas = document.querySelector('#qrCodeContainer canvas');
            if (canvas) {
                const link = document.createElement('a');
                link.download = `poll-${pollId}-qr-code.png`;
                link.href = canvas.toDataURL();
                link.click();
            }
        }
        
        // Set poll URL in modal input
        document.addEventListener('DOMContentLoaded', function() {
            const pollLinkInput = document.getElementById('pollLinkInput');
            if (pollLinkInput) {
                pollLinkInput.value = pollUrl;
            }
        });
    </script>
}

<!-- QR Code Modal -->
<div class="modal fade" id="qrCodeModal" tabindex="-1" aria-labelledby="qrCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="qrCodeModalLabel">
                    <i class="bi bi-qr-code me-2"></i>Share Poll QR Code
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3">Share this QR code for voters to access the poll</p>
                <div id="qrCodeContainer" class="d-flex justify-content-center mb-3"></div>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="pollLinkInput" readonly>
                    <button class="btn btn-outline-primary" onclick="copyPollLink()">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="downloadQRCode()">
                    <i class="bi bi-download me-2"></i>Download QR Code
                </button>
            </div>
        </div>
    </div>
</div>

<!-- QR Code Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
