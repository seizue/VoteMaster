@model IDictionary<string, int>
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var pollId            = (int)ViewBag.PollId;
    var pollTitle         = (string)(ViewBag.PollTitle ?? "Poll Results");
    var requireAttendance = (bool)(ViewBag.RequireAttendance ?? false);
    var presentWeightTotal = requireAttendance ? (int)(ViewBag.PresentWeightTotal ?? 0) : 0;
    var presentCount      = requireAttendance ? (int)(ViewBag.PresentCount ?? 0) : 0;
    var sortedResults = Model.OrderByDescending(x => x.Value).ToList();
    var totalVotes   = sortedResults.Sum(x => x.Value);
    // Participation % based on present voters' weight (only when attendance enabled)
    var participationPct = requireAttendance && presentWeightTotal > 0
        ? (totalVotes * 100.0 / presentWeightTotal)
        : (double?)null;
}

<div class="mb-3 d-flex align-items-start justify-content-between flex-wrap gap-2">
    <div>
        <h3 class="mb-1" style="font-weight: 700; color: #0f172a;">
            <i class="bi bi-bar-chart-fill me-2"></i>Voting Results
        </h3>
        <p class="text-muted mb-0">Real-time poll results and rankings</p>
    </div>
    <button class="btn btn-primary" onclick="openPresentation()" title="Open fullscreen presentation view">
        <i class="bi bi-fullscreen me-2"></i>Presentation View
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0" id="resultsTable">
                <thead>
                    <tr>
                        <th style="width: 100px;">Rank</th>
                        <th>Candidate</th>
                        <th style="width: 120px;" class="text-end">Votes</th>
                        <th style="width: 200px;" class="d-none d-md-table-cell">Distribution</th>
                    </tr>
                </thead>
                <tbody>
                @for (int i = 0; i < sortedResults.Count; i++)
                {
                    var rank = i + 1;
                    var result = sortedResults[i];
                    var percentage = totalVotes > 0 ? (result.Value * 100.0 / totalVotes) : 0;
                    
                    <tr>
                        <td class="align-middle">
                            @if (rank <= 3)
                            {
                                <span class="badge" style="background: @GetRankColor(rank); font-size: 0.9rem; padding: 0.5rem 0.75rem;">
                                    <i class="bi @GetRankIcon(rank) me-1"></i>@rank
                                </span>
                            }
                            else
                            {
                                <span class="text-muted fw-semibold">#@rank</span>
                            }
                        </td>
                        <td class="align-middle fw-semibold" style="color: #1e293b;">@result.Key</td>
                        <td class="align-middle text-end">
                            <span class="badge bg-light text-dark" style="font-size: 0.9rem; padding: 0.5rem 0.75rem;">
                                @result.Value.ToString("N0")
                            </span>
                        </td>
                        <td class="align-middle d-none d-md-table-cell">
                            <div class="d-flex align-items-center gap-2">
                                <span style="min-width:42px;font-size:0.8rem;font-weight:700;color:#f97316;">@percentage.ToString("F1")%</span>
                                <div class="progress flex-grow-1" style="height:14px;border-radius:0.5rem;background:#e0f2fe;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width:@percentage.ToString("F1")%;background:linear-gradient(135deg,#14b8a6 0%,#06b6d4 100%);"
                                         aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="border-top p-3 bg-light" style="border-radius: 0 0 1rem 1rem;">
            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-semibold" style="color: #475569;">
                    <i class="bi bi-people-fill me-2"></i>Total Weighted Votes
                </span>
                <span class="badge bg-primary" style="font-size: 1rem; padding: 0.5rem 1rem;">
                    @totalVotes.ToString("N0")
                </span>
            </div>
            @if (requireAttendance)
            {
                <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                    <span class="fw-semibold" style="color: #475569; font-size: 0.9rem;">
                        <i class="bi bi-clipboard-check me-2" style="color:#f97316;"></i>Present Voters' Weight Total
                        <span class="text-muted fw-normal" style="font-size:0.78rem;">(@presentCount present)</span>
                    </span>
                    <span class="badge" style="background:#f97316; font-size: 1rem; padding: 0.5rem 1rem;">
                        @presentWeightTotal.ToString("N0")
                    </span>
                </div>
                @if (participationPct.HasValue)
                {
                    <div class="mt-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span style="font-size:0.82rem; color:#64748b;">
                                <i class="bi bi-bar-chart-fill me-1"></i>Vote participation (weighted)
                            </span>
                            <span style="font-size:0.85rem; font-weight:700; color:@(participationPct >= 100 ? "#22c55e" : "#f97316");">
                                @participationPct.Value.ToString("F1")%
                            </span>
                        </div>
                        <div class="progress" style="height:8px; border-radius:99px; background:#e2e8f0;">
                            <div class="progress-bar"
                                 role="progressbar"
                                 style="width:@(Math.Min(participationPct.Value, 100).ToString("F1"))%;
                                        background:linear-gradient(90deg,#14b8a6,#06b6d4);
                                        border-radius:99px;"
                                 aria-valuenow="@participationPct.Value.ToString("F1")"
                                 aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<!-- Action Buttons -->
<div class="action-buttons-wrapper">
    <div class="action-buttons-section">
        <h6 class="action-section-title">Analytics & Reports</h6>
        <div class="action-buttons-group">
            <a class="btn btn-outline-secondary" href="/Admin/Analytics/PollDetails/@pollId">
                <i class="bi bi-graph-up me-2"></i>View Analytics
            </a>
            <a class="btn btn-outline-success" href="/Admin/Analytics/ExportCsv/@pollId">
                <i class="bi bi-file-earmark-spreadsheet me-2"></i>Export CSV
            </a>
            <a class="btn btn-outline-danger" href="/Admin/Analytics/ExportPdf/@pollId">
                <i class="bi bi-file-earmark-pdf me-2"></i>Export PDF
            </a>
            <button class="btn btn-outline-primary" onclick="exportToExcel()">
                <i class="bi bi-file-earmark-excel me-2"></i>Export to Excel
            </button>
        </div>
    </div>
    
    <div class="action-buttons-section">
        <h6 class="action-section-title">Share Poll</h6>
        <div class="action-buttons-group">
            <button class="btn btn-outline-primary" onclick="copyPollLink()">
                <i class="bi bi-link-45deg me-2"></i>Copy Link
            </button>
            <button class="btn btn-success" onclick="showQRCode()">
                <i class="bi bi-qr-code me-2"></i>QR Code
            </button>
        </div>
    </div>
    
    <div class="action-buttons-section">
        <div class="action-buttons-group">
            <a class="btn btn-dark" href="/Admin/Dashboard">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
            <a class="btn" href="/Admin/Polls/ProxyVote/@pollId"
               style="background:#8b5cf6;color:white;">
                <i class="bi bi-person-check me-2"></i>Proxy Vote
            </a>
            <a class="btn" href="/Admin/Polls/Nominees/@pollId"
               style="background:#f59e0b;color:white;">
                <i class="bi bi-trophy-fill me-2"></i>Nominees
            </a>
        </div>
    </div>
</div>

@functions {
    private string GetRankIcon(int rank) => rank switch
    {
        1 => "bi-trophy-fill",
        2 => "bi-award-fill",
        3 => "bi-award-fill",
        _ => ""
    };

    private string GetRankColor(int rank) => rank switch
    {
        1 => "linear-gradient(135deg, #FFD700 0%, #FFA500 100%)",
        2 => "linear-gradient(135deg, #C0C0C0 0%, #A8A8A8 100%)",
        3 => "linear-gradient(135deg, #CD7F32 0%, #B8860B 100%)",
        _ => "#6c757d"
    };
}

<style>
    .progress-bar {
        transition: width 0.6s ease;
    }
    
    .action-buttons-wrapper {
        margin-top: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .action-buttons-section {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        padding: 1.5rem;
        box-shadow: var(--vm-shadow-sm);
    }
    
    .action-section-title {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--vm-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }
    
    .action-buttons-group {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    
    .action-buttons-group .btn {
        white-space: nowrap;
        flex: 0 1 auto;
    }
    
    .action-buttons-group .btn-outline-secondary {
        border: 2px solid #6b7280;
        color: #6b7280;
    }
    
    .action-buttons-group .btn-outline-secondary:hover {
        background: #6b7280;
        border-color: #6b7280;
        color: white;
    }
    
    .action-buttons-group .btn-outline-success {
        border: 2px solid #10b981;
        color: #10b981;
    }
    
    .action-buttons-group .btn-outline-success:hover {
        background: #10b981;
        border-color: #10b981;
        color: white;
    }
    
    .action-buttons-group .btn-outline-danger {
        border: 2px solid #ef4444;
        color: #ef4444;
    }
    
    .action-buttons-group .btn-outline-danger:hover {
        background: #ef4444;
        border-color: #ef4444;
        color: white;
    }
    
    .action-buttons-group .btn-outline-primary {
        border: 2px solid var(--vm-accent);
        color: var(--vm-accent);
    }
    
    .action-buttons-group .btn-outline-primary:hover {
        background: var(--vm-accent);
        border-color: var(--vm-accent);
        color: white;
    }
    
    @@media (max-width: 768px) {
        .table thead th {
            font-size: 0.8125rem;
            padding: 0.875rem 0.75rem;
        }
        .table tbody td {
            padding: 0.875rem 0.75rem;
        }
        
        .action-buttons-wrapper {
            gap: 1rem;
        }
        
        .action-buttons-section {
            padding: 1.25rem;
        }
        
        .action-section-title {
            font-size: 0.8125rem;
            margin-bottom: 0.75rem;
        }
        
        .action-buttons-group {
            flex-direction: column;
        }
        
        .action-buttons-group .btn {
            width: 100%;
            flex: 1 1 100%;
        }
    }

    /* ── Presentation overlay — light / on-brand ── */
    #presentationOverlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #f8fafc;          /* same bg-light the rest of the app uses */
        flex-direction: column;
        overflow: hidden;
    }
    #presentationOverlay.active { display: flex; }

    .pres-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 2rem 1rem;
        flex-shrink: 0;
        background: white;
        border-bottom: 1px solid var(--vm-border);
        box-shadow: var(--vm-shadow-sm);
    }
    .pres-title {
        font-size: clamp(1.1rem, 2.5vw, 1.6rem);
        font-weight: 800;
        color: var(--vm-text-primary);
        letter-spacing: -0.01em;
    }
    .pres-subtitle { font-size: 0.8rem; color: var(--vm-text-secondary); margin-top: 0.15rem; }

    .pres-close-btn {
        display: flex; align-items: center; gap: 0.4rem;
        padding: 0.5rem 1.1rem; font-size: 0.875rem; font-weight: 600;
        border-radius: 0.6rem; cursor: pointer; flex-shrink: 0;
        background: var(--vm-text-primary); color: white;
        border: none; transition: background 0.15s;
    }
    .pres-close-btn:hover { background: #334155; }

    .pres-body {
        flex: 1; overflow-y: auto;
        padding: 1.5rem 2rem 2rem;
        display: flex; flex-direction: column; gap: 0.75rem;
    }

    .pres-row {
        display: grid;
        grid-template-columns: 80px 1fr 180px;
        align-items: center;
        gap: 1.25rem;
        padding: 1rem 1.5rem;
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        box-shadow: var(--vm-shadow-sm);
        transition: box-shadow 0.2s, transform 0.15s;
        animation: presSlideIn 0.35s ease both;
    }
    .pres-row:hover { box-shadow: var(--vm-shadow-md); transform: translateY(-1px); }

    /* top-3 get a subtle left accent stripe */
    .pres-row:nth-child(1) { border-left: 4px solid #FFD700; }
    .pres-row:nth-child(2) { border-left: 4px solid #C0C0C0; }
    .pres-row:nth-child(3) { border-left: 4px solid #CD7F32; }

    @@keyframes presSlideIn {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .pres-rank { text-align: center; }
    .pres-rank-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: clamp(42px, 5vw, 56px); height: clamp(42px, 5vw, 56px);
        border-radius: 50%; font-size: clamp(1rem, 2vw, 1.3rem); font-weight: 800; color: white;
    }
    .pres-rank-num {
        font-size: clamp(1rem, 2.5vw, 1.4rem); font-weight: 700;
        color: var(--vm-text-secondary);
    }

    .pres-candidate {
        font-size: clamp(1rem, 2.2vw, 1.4rem); font-weight: 700;
        color: var(--vm-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    .pres-bar-wrap { display: flex; flex-direction: column; gap: 0.4rem; }
    .pres-bar-meta { display: flex; justify-content: space-between; align-items: baseline; }
    .pres-votes {
        font-size: clamp(0.875rem, 1.8vw, 1.1rem); font-weight: 700;
        color: var(--vm-text-primary);
    }
    .pres-pct {
        font-size: clamp(0.75rem, 1.5vw, 0.95rem); font-weight: 700;
        color: var(--vm-accent);          /* teal — matches the existing distribution % */
    }
    .pres-bar-track {
        height: clamp(10px, 1.4vh, 16px);
        background: #e0f2fe;              /* light teal tint — matches regular Results page */
        border-radius: 99px; overflow: hidden;
    }
    .pres-bar-fill {
        height: 100%; border-radius: 99px;
        background: linear-gradient(90deg, #14b8a6, #06b6d4);   /* same as table's progress bar */
        transition: width 1.1s cubic-bezier(0.4, 0, 0.2, 1);
        width: 0%;
    }
    /* rank-specific bar colours */
    .pres-row:nth-child(1) .pres-bar-fill { background: linear-gradient(90deg, #FFD700, #FFA500); }
    .pres-row:nth-child(2) .pres-bar-fill { background: linear-gradient(90deg, #94a3b8, #64748b); }
    .pres-row:nth-child(3) .pres-bar-fill { background: linear-gradient(90deg, #CD7F32, #B8860B); }

    .pres-footer {
        flex-shrink: 0;
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
        padding: 1rem 2rem;
        border-top: 1px solid var(--vm-border);
        background: white;
        box-shadow: 0 -1px 3px rgba(15,23,42,0.06);
    }
    .pres-total-label {
        font-size: 0.9rem; font-weight: 600;
        color: var(--vm-text-secondary);
        display: flex; align-items: center; gap: 0.5rem;
    }
    .pres-total-value {
        font-size: clamp(1.1rem, 2vw, 1.5rem); font-weight: 800;
        color: var(--vm-text-primary);
        background: var(--vm-accent);
        color: white;
        padding: 0.35rem 1.1rem;
        border-radius: 2rem;
    }
    .pres-live {
        display: flex; align-items: center; gap: 0.5rem;
        font-size: 0.8rem; color: var(--vm-text-secondary);
    }
    .pres-pulse {
        width: 8px; height: 8px; border-radius: 50%; background: #22c55e;
        animation: pulseDot 2s infinite;
    }
    @@keyframes pulseDot {
        0%,100% { opacity:1; transform:scale(1); }
        50%      { opacity:0.4; transform:scale(0.75); }
    }

    @@media (max-width: 640px) {
        .pres-header { padding: 0.875rem 1rem; }
        .pres-body   { padding: 0.875rem 1rem; gap: 0.5rem; }
        .pres-footer { padding: 0.75rem 1rem; }
        .pres-row    { grid-template-columns: 50px 1fr 100px; gap: 0.6rem; padding: 0.75rem 1rem; border-radius: 0.75rem; }
    }
</style>

@* ── Presentation overlay (fixed, full-screen, light / on-brand) ── *@
<div id="presentationOverlay" role="dialog" aria-modal="true" aria-label="Results Presentation View">
    <div class="pres-header">
        <div>
            <div class="pres-title">
                <i class="bi bi-bar-chart-fill me-2" style="color:#14b8a6;"></i>@pollTitle
            </div>
            <div class="pres-subtitle">Voting Results &nbsp;·&nbsp; Real-time</div>
        </div>
        <button class="pres-close-btn" onclick="closePresentation()" title="Exit (Esc)">
            <i class="bi bi-fullscreen-exit"></i> Exit
        </button>
    </div>

    <div class="pres-body" id="presBody">
        @for (int i = 0; i < sortedResults.Count; i++)
        {
            var rank       = i + 1;
            var result     = sortedResults[i];
            var percentage = totalVotes > 0 ? (result.Value * 100.0 / totalVotes) : 0;

            <div class="pres-row" style="animation-delay: @(i * 70)ms;">
                <div class="pres-rank">
                    @if (rank == 1)
                    {
                        <div class="pres-rank-badge" style="background:linear-gradient(135deg,#FFD700,#FFA500);">
                            <i class="bi bi-trophy-fill"></i>
                        </div>
                    }
                    else if (rank == 2)
                    {
                        <div class="pres-rank-badge" style="background:linear-gradient(135deg,#C0C0C0,#A8A8A8);">
                            <i class="bi bi-award-fill"></i>
                        </div>
                    }
                    else if (rank == 3)
                    {
                        <div class="pres-rank-badge" style="background:linear-gradient(135deg,#CD7F32,#B8860B);">
                            <i class="bi bi-award-fill"></i>
                        </div>
                    }
                    else
                    {
                        <div class="pres-rank-num">#@rank</div>
                    }
                </div>
                <div class="pres-candidate" title="@result.Key">@result.Key</div>
                <div class="pres-bar-wrap">
                    <div class="pres-bar-meta">
                        <span class="pres-votes">@result.Value.ToString("N0")</span>
                        <span class="pres-pct">@percentage.ToString("F1")%</span>
                    </div>
                    <div class="pres-bar-track">
                        <div class="pres-bar-fill" data-pct="@percentage.ToString("F1")"></div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="pres-footer">
        <div class="pres-live">
            <span class="pres-pulse"></span>
            Live &nbsp;·&nbsp; updates every 10s
        </div>
    </div>
</div>

<script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>

@section Scripts {
    <script>
        const pollId = @pollId;

        // ── SignalR — update table without reloading when NOT in presentation mode ──
        const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/results").build();
        connection.on("resultsUpdated", (id) => {
            if (id === pollId) {
                if (document.getElementById('presentationOverlay').classList.contains('active')) {
                    // In presentation mode — fetch and update in-place, no reload
                    refreshPresentation();
                } else {
                    location.reload();
                }
            }
        });
        connection.start();

        // ── Presentation mode ──────────────────────────────────────────────
        let presRefreshTimer = null;

        // Rank badge HTML helper
        function rankBadgeHtml(rank) {
            if (rank === 1) return '<div class="pres-rank-badge" style="background:linear-gradient(135deg,#FFD700,#FFA500);"><i class="bi bi-trophy-fill"></i></div>';
            if (rank === 2) return '<div class="pres-rank-badge" style="background:linear-gradient(135deg,#C0C0C0,#A8A8A8);"><i class="bi bi-award-fill"></i></div>';
            if (rank === 3) return '<div class="pres-rank-badge" style="background:linear-gradient(135deg,#CD7F32,#B8860B);"><i class="bi bi-award-fill"></i></div>';
            return '<div class="pres-rank-num">#' + rank + '</div>';
        }

        // Fetch latest results and re-render the overlay rows in-place
        function refreshPresentation() {
            fetch('/api/polls/' + pollId + '/results')
                .then(function(r) { return r.ok ? r.json() : null; })
                .then(function(data) {
                    if (!data) return;

                    // data is { candidateName: voteCount, ... }
                    var entries = Object.entries(data).sort(function(a, b) { return b[1] - a[1]; });
                    var total   = entries.reduce(function(s, e) { return s + e[1]; }, 0);

                    var body = document.getElementById('presBody');
                    var existingRows = body.querySelectorAll('.pres-row');

                    entries.forEach(function(entry, i) {
                        var name  = entry[0];
                        var votes = entry[1];
                        var pct   = total > 0 ? (votes * 100 / total) : 0;
                        var rank  = i + 1;

                        var row = existingRows[i];
                        if (!row) {
                            // New option appeared — create row
                            row = document.createElement('div');
                            row.className = 'pres-row';
                            row.innerHTML =
                                '<div class="pres-rank"></div>' +
                                '<div class="pres-candidate"></div>' +
                                '<div class="pres-bar-wrap">' +
                                    '<div class="pres-bar-meta">' +
                                        '<span class="pres-votes"></span>' +
                                        '<span class="pres-pct"></span>' +
                                    '</div>' +
                                    '<div class="pres-bar-track"><div class="pres-bar-fill"></div></div>' +
                                '</div>';
                            body.appendChild(row);
                        }

                        row.querySelector('.pres-rank').innerHTML = rankBadgeHtml(rank);
                        row.querySelector('.pres-candidate').textContent = name;
                        row.querySelector('.pres-candidate').title = name;
                        row.querySelector('.pres-votes').textContent = votes.toLocaleString();
                        row.querySelector('.pres-pct').textContent   = pct.toFixed(1) + '%';

                        var fill = row.querySelector('.pres-bar-fill');
                        fill.style.width = pct.toFixed(1) + '%';
                        fill.dataset.pct = pct.toFixed(1);
                    });

                    // Update footer total
                    var totalEl = document.querySelector('.pres-total-value');
                    if (totalEl) totalEl.textContent = total.toLocaleString();

                    // Also refresh the regular table so it's up-to-date when exiting
                    refreshTable(entries, total);
                })
                .catch(function() { /* silent — keep showing last data */ });
        }

        // Silently update the regular results table as well
        function refreshTable(entries, total) {
            var tbody = document.querySelector('#resultsTable tbody');
            if (!tbody) return;
            var rows = tbody.querySelectorAll('tr');
            entries.forEach(function(entry, i) {
                var tr = rows[i];
                if (!tr) return;
                var votes   = entry[1];
                var pct     = total > 0 ? (votes * 100 / total) : 0;
                var votesTd = tr.querySelector('td:nth-child(3) .badge');
                if (votesTd) votesTd.textContent = votes.toLocaleString();
                var bar = tr.querySelector('.progress-bar');
                if (bar) { bar.style.width = pct.toFixed(1) + '%'; bar.setAttribute('aria-valuenow', pct.toFixed(1)); }
                var pctSpan = tr.querySelector('.d-none.d-md-table-cell span');
                if (pctSpan) pctSpan.textContent = pct.toFixed(1) + '%';
            });
        }

        function openPresentation() {
            const overlay = document.getElementById('presentationOverlay');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';

            // Animate bars in after a brief paint delay
            requestAnimationFrame(function() {
                setTimeout(function() {
                    overlay.querySelectorAll('.pres-bar-fill').forEach(function(bar) {
                        bar.style.width = (bar.dataset.pct || '0') + '%';
                    });
                }, 120);
            });

            // Auto-refresh every 10 s — fetch in-place, no page reload
            presRefreshTimer = setInterval(refreshPresentation, 10000);
        }

        function closePresentation() {
            const overlay = document.getElementById('presentationOverlay');
            overlay.classList.remove('active');
            document.body.style.overflow = '';
            clearInterval(presRefreshTimer);
            presRefreshTimer = null;
        }

        // Esc key closes presentation
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePresentation();
        });
        
        function exportToExcel() {
            // Collect results data from the table
            const rows = document.querySelectorAll('#resultsTable tbody tr');
            const exportData = [];
            const totalVotes = @totalVotes;

            rows.forEach((row, index) => {
                const cells = row.querySelectorAll('td');
                const rankText = cells[0].textContent.trim();
                const candidate = cells[1].textContent.trim();
                const votes = parseInt(cells[2].textContent.trim().replace(/[^0-9]/g, '')) || 0;
                const distribution = totalVotes > 0 ? ((votes * 100.0) / totalVotes).toFixed(1) + '%' : '0.0%';

                exportData.push({
                    'Rank': rankText,
                    'Candidate': candidate,
                    'Votes': votes.toLocaleString(),
                    'Distribution': distribution
                });
            });

            // Add total row
            exportData.push({
                'Rank': '',
                'Candidate': 'TOTAL',
                'Votes': totalVotes.toLocaleString(),
                'Distribution': '100.0%'
            });

            // Create workbook and worksheet
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.json_to_sheet(exportData);

            // Set column widths
            ws['!cols'] = [
                { wch: 10 }, // Rank
                { wch: 40 }, // Candidate
                { wch: 14 }, // Votes
                { wch: 14 }  // Distribution
            ];

            // Add worksheet to workbook
            XLSX.utils.book_append_sheet(wb, ws, 'Results');
            
            // Generate filename with current date
            const now = new Date();
            const filename = `Poll_Results_${pollId}_${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}.xlsx`;
            
            // Save file
            XLSX.writeFile(wb, filename);
            
            // Show success message
            const alert = document.createElement('div');
            alert.className = 'alert alert-success alert-dismissible fade show mt-3';
            alert.innerHTML = '<i class="bi bi-check-circle me-2"></i>Results exported to Excel successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
            document.querySelector('.container').insertAdjacentElement('afterbegin', alert);
            
            setTimeout(() => alert.remove(), 3000);
        }
        
        // Share and QR Code functionality
        const _networkBase = '@(ViewBag.NetworkBaseUrl ?? string.Empty)'
                           || '@(ViewBag.RequestBaseUrl ?? string.Empty)'
                           || window.location.origin;
        const pollUrl = _networkBase + '/Client/Vote/' + pollId;
        
        function copyPollLink() {
            navigator.clipboard.writeText(pollUrl).then(() => {
                // Show success message
                const alert = document.createElement('div');
                alert.className = 'alert alert-success alert-dismissible fade show';
                alert.style.position = 'fixed';
                alert.style.top = '20px';
                alert.style.right = '20px';
                alert.style.zIndex = '9999';
                alert.innerHTML = '<i class="bi bi-check-circle me-2"></i>Poll link copied to clipboard! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                document.body.appendChild(alert);
                
                setTimeout(() => alert.remove(), 3000);
            }).catch(err => {
                alert('Failed to copy link. Please copy manually: ' + pollUrl);
            });
        }
        
        function showQRCode() {
            // Generate QR code
            const qrContainer = document.getElementById('qrCodeContainer');
            qrContainer.innerHTML = ''; // Clear previous QR code
            
            const qr = new QRCode(qrContainer, {
                text: pollUrl,
                width: 256,
                height: 256,
                colorDark: "#000000",
                colorLight: "#ffffff",
                correctLevel: QRCode.CorrectLevel.H
            });
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('qrCodeModal'));
            modal.show();
        }
        
        function downloadQRCode() {
            const canvas = document.querySelector('#qrCodeContainer canvas');
            if (canvas) {
                const link = document.createElement('a');
                link.download = `poll-${pollId}-qr-code.png`;
                link.href = canvas.toDataURL();
                link.click();
            }
        }
        
        // Set poll URL in modal input
        document.addEventListener('DOMContentLoaded', function() {
            const pollLinkInput = document.getElementById('pollLinkInput');
            if (pollLinkInput) {
                pollLinkInput.value = pollUrl;
            }
        });
    </script>
}

<!-- QR Code Modal -->
<div class="modal fade" id="qrCodeModal" tabindex="-1" aria-labelledby="qrCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="qrCodeModalLabel">
                    <i class="bi bi-qr-code me-2"></i>Share Poll QR Code
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3">Share this QR code for voters to access the poll</p>
                <div id="qrCodeContainer" class="d-flex justify-content-center mb-3"></div>
                <div class="input-group mb-3">
                    <input type="text" class="form-control" id="pollLinkInput" readonly>
                    <button class="btn btn-outline-primary" onclick="copyPollLink()">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="downloadQRCode()">
                    <i class="bi bi-download me-2"></i>Download QR Code
                </button>
            </div>
        </div>
    </div>
</div>

<!-- QR Code Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
