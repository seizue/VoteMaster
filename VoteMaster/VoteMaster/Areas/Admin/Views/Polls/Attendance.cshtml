@model List<VoteMaster.Models.AppUser>
@using VoteMaster.Models
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var poll       = ViewBag.Poll as Poll;
    var pollId     = poll?.Id ?? 0;
    var presentIds = (ViewBag.PresentIds as HashSet<int>) ?? new HashSet<int>();
    var votedIds   = (ViewBag.VotedIds   as HashSet<int>) ?? new HashSet<int>();
    int total      = Model?.Count ?? 0;
    int presCount  = presentIds.Count(id => Model?.Any(u => u.Id == id) == true);
}

<style>
    .att-header { margin-bottom: 1.5rem; }
    .att-header h3 { font-weight: 700; color: #0f172a; }

    .att-stats {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem; margin-bottom: 1.25rem;
    }
    .att-stat {
        background: white; border: 1px solid #e2e8f0;
        border-radius: 0.75rem; padding: 0.875rem 1rem; text-align: center;
    }
    .att-stat-value { font-size: 1.5rem; font-weight: 700; line-height: 1; }
    .att-stat-label { font-size: 0.75rem; color: #64748b; margin-top: 0.25rem; }

    .att-toolbar {
        display: flex; align-items: center; flex-wrap: wrap; gap: 0.6rem;
        margin-bottom: 1.25rem; padding: 0.875rem 1rem;
        background: white; border: 1px solid #e2e8f0; border-radius: 0.75rem;
    }
    .att-toolbar .section-label {
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.05em; color: #94a3b8;
    }
    .att-toolbar .divider { width: 1px; height: 24px; background: #e2e8f0; }

    .att-select-bar {
        display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
        padding: 0.55rem 1rem; background: #f8fafc;
        border-bottom: 1px solid #e2e8f0; font-size: 0.875rem;
    }

    .att-table-wrap { overflow-x: auto; }
    .att-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 420px; }
    .att-table thead th {
        background: #f8fafc; padding: 0.75rem 1rem;
        font-size: 0.8125rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.04em; color: #64748b; border-bottom: 2px solid #e2e8f0;
        white-space: nowrap;
    }
    .att-table tbody tr:hover { background: #f8fafc; }
    .att-table tbody td { padding: 0.7rem 1rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .att-table tbody tr:last-child td { border-bottom: none; }

    .voter-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white; display: inline-flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.8rem; flex-shrink: 0;
    }

    .att-cards { display: none; }
    .att-voter-card {
        background: white; border: 1px solid #e2e8f0; border-radius: 0.75rem;
        padding: 0.875rem 1rem; margin-bottom: 0.625rem;
        display: flex; align-items: center; gap: 0.75rem;
    }
    .att-voter-info { flex: 1; min-width: 0; }
    .att-voter-name { font-weight: 600; color: #0f172a; font-size: 0.9375rem; }
    .att-voter-meta { font-size: 0.78rem; color: #94a3b8; margin-top: 0.1rem; }

    @@media (max-width: 640px) {
        .att-table-wrap { display: none; }
        .att-cards      { display: block; }
    }
</style>

<div class="att-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-1">
        <h3 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Attendance</h3>
        @if (poll?.RequireAttendance == true)
        {
            <span class="badge bg-warning text-dark" style="font-size:0.82rem;padding:0.4rem 0.85rem;">
                <i class="bi bi-shield-lock me-1"></i>Attendance Required to Vote
            </span>
        }
        else
        {
            <span class="badge bg-secondary" style="font-size:0.82rem;padding:0.4rem 0.85rem;">
                <i class="bi bi-shield me-1"></i>Attendance Optional (tracking only)
            </span>
        }
    </div>
    <p class="text-muted small mb-0">@poll?.Title</p>
</div>

@if (TempData["AttendanceSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["AttendanceSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["AttendanceError"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["AttendanceError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="att-stats">
    <div class="att-stat">
        <div class="att-stat-value text-primary">@total</div>
        <div class="att-stat-label">Total</div>
    </div>
    <div class="att-stat">
        <div class="att-stat-value text-success">@presCount</div>
        <div class="att-stat-label">Present</div>
    </div>
    <div class="att-stat">
        <div class="att-stat-value text-danger">@(total - presCount)</div>
        <div class="att-stat-label">Absent</div>
    </div>
</div>

@if (total == 0)
{
    <div class="card p-5 text-center text-muted">
        <i class="bi bi-people fs-1 d-block mb-2"></i>No voters found for this poll.
    </div>
}
else
{
    @* ── Bulk-action toolbar (its own form, no table inside it) ── *@
    <div class="att-toolbar">
        <span class="section-label"><i class="bi bi-person-check me-1"></i>Bulk Actions</span>
        <button type="button" class="btn btn-sm btn-success" onclick="bulkSubmit('present')">
            <i class="bi bi-check-circle me-1"></i>Mark Selected Present
        </button>
        <button type="button" class="btn btn-sm btn-outline-danger" onclick="bulkSubmit('absent')">
            <i class="bi bi-x-circle me-1"></i>Mark Selected Absent
        </button>
        <div class="divider"></div>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="selectAll(true)">
            <i class="bi bi-check-all me-1"></i>Select All
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="selectAll(false)">
            <i class="bi bi-x me-1"></i>Clear
        </button>
        <span class="text-muted small ms-1">
            <span id="selCount">0</span> selected
        </span>
    </div>

    @* ── Desktop table (NO outer form — checkboxes are just UI, bulk form built by JS) ── *@
    <div class="card att-table-wrap">
        <div class="att-select-bar">
            <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="masterCheck" onchange="toggleMaster(this)" />
                <label class="form-check-label fw-semibold" for="masterCheck">Select all</label>
            </div>
        </div>
        <table class="att-table">
            <thead>
                <tr>
                    <th style="width:44px;"></th>
                    <th>Voter</th>
                    <th>Attendance</th>
                    <th>Voted</th>
                    <th>Quick Toggle</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var voter in Model!.OrderBy(u => u.Username))
                {
                    var isPresent = presentIds.Contains(voter.Id);
                    var hasVoted  = votedIds.Contains(voter.Id);
                    var initials  = voter.Username.Length > 0 ? voter.Username[0].ToString().ToUpper() : "?";

                    <tr>
                        <td>
                            <input type="checkbox" class="form-check-input voter-check"
                                   value="@voter.Id" onchange="updateSelCount()" />
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="voter-avatar">@initials</div>
                                <div>
                                    <div class="fw-semibold" style="color:#0f172a;">@voter.Username</div>
                                    <div style="font-size:0.72rem;color:#94a3b8;">weight: @voter.Weight</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @if (isPresent)
                            {
                                <span class="badge bg-success px-3 py-2">
                                    <i class="bi bi-check-circle-fill me-1"></i>Present
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-light text-secondary border px-3 py-2">
                                    <i class="bi bi-dash-circle me-1"></i>Absent
                                </span>
                            }
                        </td>
                        <td>
                            @if (hasVoted)
                            {
                                <span class="badge bg-primary px-3 py-2">
                                    <i class="bi bi-check-lg me-1"></i>Voted
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @* Standalone toggle button — submits its own dedicated form outside the table *@
                            <button type="button"
                                    class="btn btn-sm @(isPresent ? "btn-outline-danger" : "btn-outline-success")"
                                    onclick="submitToggle(@voter.Id, @(isPresent ? "false" : "true"))"
                                    title="@(isPresent ? "Mark absent" : "Mark present")">
                                @if (isPresent)
                                {
                                    <i class="bi bi-x-lg me-1"></i><span>Remove</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i><span>Mark Present</span>
                                }
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* ── Mobile cards ── *@
    <div class="att-cards">
        @foreach (var voter in Model!.OrderBy(u => u.Username))
        {
            var isPresent = presentIds.Contains(voter.Id);
            var hasVoted  = votedIds.Contains(voter.Id);
            var initials  = voter.Username.Length > 0 ? voter.Username[0].ToString().ToUpper() : "?";
            var cardBg    = isPresent ? "#f0fdf4" : "#f8fafc";
            var dotColor  = isPresent ? "#22c55e" : "#94a3b8";

            <div class="att-voter-card">
                <input type="checkbox" class="form-check-input voter-check"
                       value="@voter.Id" onchange="updateSelCount()"
                       style="width:20px;height:20px;flex-shrink:0;" />
                <div class="voter-avatar" style="background:@cardBg;color:@dotColor;border:1px solid @dotColor;">
                    @initials
                </div>
                <div class="att-voter-info">
                    <div class="att-voter-name">@voter.Username</div>
                    <div class="att-voter-meta">
                        weight @voter.Weight
                        @if (hasVoted) { <text>&nbsp;·&nbsp;<span class="text-primary">Voted</span></text> }
                    </div>
                </div>
                @if (isPresent)
                {
                    <span class="badge bg-success">Present</span>
                }
                else
                {
                    <span class="badge bg-light text-secondary border">Absent</span>
                }
                <button type="button"
                        class="btn btn-sm @(isPresent ? "btn-outline-danger" : "btn-outline-success")"
                        style="white-space:nowrap;"
                        onclick="submitToggle(@voter.Id, @(isPresent ? "false" : "true"))">
                    @(isPresent ? "Remove" : "Mark Present")
                </button>
            </div>
        }
    </div>
}

<div class="mt-3 d-flex gap-2 flex-wrap">
    <a href="@Url.Action("VoterStatus","Polls",new{area="Admin",id=pollId})" class="btn btn-dark">
        <i class="bi bi-arrow-left me-2"></i>Back to Voter Status
    </a>
    <a href="@Url.Action("Results","Polls",new{area="Admin",id=pollId})" class="btn btn-outline-primary">
        <i class="bi bi-bar-chart me-2"></i>Results
    </a>
</div>

@* ── Hidden forms — rendered OUTSIDE any other form, no nesting ── *@

@* Single toggle form — reused by JS for any voter *@
<form method="post"
      action="@Url.Action("ToggleAttendance","Polls",new{area="Admin",id=pollId})"
      id="toggleForm" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" id="toggleUserId" value="0" />
    <input type="hidden" name="present" id="togglePresent" value="true" />
</form>

@* Bulk action form — reused by JS *@
<form method="post"
      action="@Url.Action("MarkAttendance","Polls",new{area="Admin",id=pollId})"
      id="bulkForm" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="action" id="bulkAction" value="present" />
    <span id="bulkUserIds"></span>
</form>

@section Scripts {
<script>
(function () {
    // ── Selection helpers ───────────────────────────────────────────────
    function updateSelCount() {
        var n = document.querySelectorAll('.voter-check:checked').length;
        var el = document.getElementById('selCount');
        if (el) el.textContent = n;
        var master = document.getElementById('masterCheck');
        if (master) {
            var all = document.querySelectorAll('.voter-check').length;
            master.indeterminate = n > 0 && n < all;
            master.checked = n === all && all > 0;
        }
    }
    window.updateSelCount = updateSelCount;

    window.toggleMaster = function (cb) {
        document.querySelectorAll('.voter-check').forEach(function (c) { c.checked = cb.checked; });
        updateSelCount();
    };

    window.selectAll = function (check) {
        document.querySelectorAll('.voter-check').forEach(function (c) { c.checked = check; });
        updateSelCount();
    };

    // ── Single toggle — uses the hidden #toggleForm ─────────────────────
    window.submitToggle = function (userId, present) {
        document.getElementById('toggleUserId').value = userId;
        document.getElementById('togglePresent').value = present;
        document.getElementById('toggleForm').submit();
    };

    // ── Bulk action — uses the hidden #bulkForm ─────────────────────────
    window.bulkSubmit = function (action) {
        var checked = Array.from(document.querySelectorAll('.voter-check:checked'));
        if (checked.length === 0) { alert('Please select at least one voter.'); return; }

        document.getElementById('bulkAction').value = action;

        var container = document.getElementById('bulkUserIds');
        container.innerHTML = '';
        checked.forEach(function (c) {
            var inp = document.createElement('input');
            inp.type  = 'hidden';
            inp.name  = 'selectedUserIds';
            inp.value = c.value;
            container.appendChild(inp);
        });

        document.getElementById('bulkForm').submit();
    };
})();
</script>
}
