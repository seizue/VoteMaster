@model IEnumerable<PollViewDto>
@using VoteMaster.Services
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var currentStatus = ViewBag.CurrentStatus ?? "active";
    var statusOptions = ViewBag.StatusOptions ?? new List<string>();
}

<style>
    .polls-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .polls-header h3 {
        margin: 0;
        flex: 1;
        min-width: 150px;
        font-weight: 700;
        color: var(--vm-text-primary);
        font-size: 1.75rem;
    }
    .polls-header .button-group {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .polls-header .button-group .btn {
        white-space: nowrap;
    }
    .filter-buttons {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        background: white;
        padding: 0.5rem;
        border-radius: 0.75rem;
        border: 1px solid var(--vm-border);
        box-shadow: 0 1px 3px rgba(15,23,42,0.08);
    }
    .filter-buttons .btn {
        padding: 0.625rem 1.25rem;
        font-size: 0.875rem;
        border-radius: 0.5rem;
        font-weight: 600;
        border: none;
        background: transparent;
        color: var(--vm-text-secondary);
        transition: all 0.2s ease;
    }
    .filter-buttons .btn:hover {
        background: rgba(20,184,166,0.05);
        color: var(--vm-accent);
    }
    .filter-buttons .btn-primary {
        background: var(--vm-accent);
        color: white;
        box-shadow: 0 2px 6px rgba(20,184,166,0.25);
    }
    .filter-buttons .btn-primary:hover {
        background: var(--vm-accent-hover);
        color: white;
    }
    .table-responsive {
        border-radius: 1rem;
        overflow: visible;
        box-shadow: 0 1px 3px rgba(15,23,42,0.08);
        background: white;
        margin-bottom: 2rem;
    }
    .table-actions {
        display: flex;
        gap: 0.35rem;
        flex-wrap: nowrap;
        align-items: center;
    }
    .table-actions .dropdown {
        display: inline-flex;
        align-items: center;
    }
    .table-actions .btn {
        white-space: nowrap;
        font-size: 0.8125rem;
        padding: 0.3rem 0.65rem;
        flex: 0 0 auto;
    }
    .table-actions form {
        display: inline-flex;
        margin: 0;
        flex: 0 0 auto;
    }
    .table-actions form .btn {
        padding: 0.3rem 0.65rem;
        font-size: 0.8125rem;
    }
    .ta-end {
        background: #f97316;
        color: white;
        border: none;
    }
    .ta-end:hover { background: #ea6c0a; color: white; }

    /* Mobile card view */
    .poll-card {
        display: none;
        background: white;
        border-radius: 1rem;
        border: 1px solid var(--vm-border);
        margin-bottom: 1rem;
        padding: 1.25rem;
        box-shadow: 0 1px 4px rgba(15,23,42,0.07);
        transition: box-shadow 0.2s;
    }
    .poll-card:hover { box-shadow: 0 4px 16px rgba(15,23,42,0.10); }
    .poll-card-title {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--vm-text-primary);
        margin-bottom: 0.4rem;
    }
    .poll-card-description {
        font-size: 0.82rem;
        color: var(--vm-text-secondary);
        margin: 0.2rem 0 0;
    }
    .poll-card-meta {
        font-size: 0.85rem;
        color: var(--vm-text-secondary);
        display: flex;
        align-items: center;
        gap: 0.35rem;
        margin: 0.5rem 0 1rem;
    }
    .poll-card-actions {
        display: none;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
        margin-top: 0.75rem;
    }
    .poll-card-actions.open { display: grid; }
    .poll-card-actions .btn,
    .poll-card-actions form { margin: 0; }
    .poll-card-actions form { display: contents; }
    .poll-card-actions form .btn { width: 100%; }
    .poll-card-actions .btn-full,
    .poll-card-actions form.full { grid-column: 1 / -1; }
    .poll-card-actions form.full .btn { width: 100%; }
    .poll-card-actions .btn {
        padding: 0.7rem 1rem;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 0.65rem;
    }
    .pc-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.35rem;
        width: 100%;
        margin-top: 0.75rem;
        padding: 0.45rem 1rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--vm-text-secondary);
        background: #f1f5f9;
        border: 1px solid var(--vm-border);
        border-radius: 0.5rem;
        cursor: pointer;
        transition: background 0.15s;
    }
    .pc-toggle:hover { background: #e2e8f0; }

    @@media (max-width: 768px) {
        .polls-header {
            flex-direction: column;
            align-items: stretch;
        }
        .polls-header h3 {
            order: 1;
            width: 100%;
            font-size: 1.5rem;
        }
        .polls-header .button-group {
            order: 2;
            width: 100%;
            flex-direction: column;
        }
        .polls-header .button-group .btn {
            width: 100%;
        }
        .filter-buttons .btn {
            flex: 1;
            padding: 0.5rem 0.75rem;
            font-size: 0.8125rem;
        }
        .table-responsive {
            display: none !important;
        }
        .poll-card {
            display: block;
        }
    }

    @@media (min-width: 769px) {
        .table-actions { flex-wrap: nowrap; }
    }

    @@media (max-width: 480px) {
        .polls-header h3 { font-size: 1.25rem; }
        .filter-buttons { padding: 0.75rem; }
        .filter-buttons .btn {
            font-size: 0.75rem;
            padding: 0.5rem 0.625rem;
        }
    }

    .actions-dropdown-menu {
        display: flex;
        flex-direction: column;
        padding: 0.35rem;
        gap: 0.25rem;
    }
    .actions-dropdown-menu .btn {
        width: 100%;
        text-align: left;
        font-size: 0.8125rem;
        padding: 0.4rem 0.75rem;
        border-radius: 0.4rem;
        border-width: 1.5px;
    }
    .actions-dropdown-menu form {
        display: contents;
    }
    .actions-dropdown-menu form .btn {
        width: 100%;
        text-align: left;
    }
    .actions-dropdown-menu hr {
        margin: 0.15rem 0 !important;
        border: 0 !important;
        border-top: 1px solid #e2e8f0 !important;
        opacity: 1 !important;
        height: 0 !important;
    }
</style>

<div class="polls-header">
    <h3><i class="bi bi-list-check me-2"></i>Polls</h3>
    <div class="button-group">
        <button class="btn" onclick="exportToExcel()" style="background: white; color: #14b8a6; border: 2px solid #14b8a6;">
            <i class="bi bi-file-earmark-excel me-2"></i>Export to Excel
        </button>
        <a class="btn btn-success" href="/Admin/Polls/Create">
            <i class="bi bi-plus-circle me-2"></i>Create New Poll
        </a>
    </div>
</div>

<!-- Search and Filters -->
<div class="dashboard-filters">
    <div class="search-box">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" class="form-control" placeholder="Search polls...">
    </div>
    
    <div class="filter-group">
        <div class="date-filter">
            <input type="date" id="dateFrom" class="form-control" placeholder="From">
        </div>
        <div class="date-filter">
            <input type="date" id="dateTo" class="form-control" placeholder="To">
        </div>
        <button class="btn btn-outline-primary" onclick="applyFilters()">
            <i class="bi bi-funnel me-1"></i>Apply
        </button>
        <button class="btn btn-outline-secondary" onclick="clearFilters()">
            <i class="bi bi-x-circle me-1"></i>Clear
        </button>
    </div>
</div>

<div class="filter-buttons">
    @foreach (var option in statusOptions)
    {
        var isActive = currentStatus.Equals(option, StringComparison.OrdinalIgnoreCase);
        var btnClass = isActive ? "btn btn-primary" : "btn btn-outline-primary";
        <a href="/Admin/Polls?status=@option" class="@btnClass">
            @(char.ToUpper(option[0]) + option.Substring(1))
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary text-center py-4">
        <i class="bi bi-info-circle me-2"></i>
        <span>No polls found in this category.</span>
    </div>
}
else
{
    <!-- Desktop Table View -->
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th style="width: 40%;">Poll Title</th>
                    <th style="width: 12%;">Status</th>
                    <th style="width: 25%;" class="d-none d-lg-table-cell">Time Period</th>
                    <th style="width: 23%;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model) {
                var poll = item.Poll;
                var status = item.Status;
                var statusBadgeClass = status switch
                {
                    "Active" => "badge bg-success",
                    "Archived" => "badge bg-secondary",
                    "Upcoming" => "badge bg-info",
                    _ => "badge bg-light"
                };

                <tr class="poll-item" data-poll-id="@poll.Id" data-start-date="@poll.StartTime.ToString("yyyy-MM-dd")" data-end-date="@poll.EndTime.ToString("yyyy-MM-dd")" style="display:none;">
                    <td>
                        <div class="fw-semibold" style="color: var(--vm-text-primary);">@poll.Title</div>
                        @if (!string.IsNullOrEmpty(poll.Description))
                        {
                            <small class="text-muted d-block">@poll.Description</small>
                        }
                    </td>
                    <td><span class="@statusBadgeClass">@status</span></td>
                    <td class="d-none d-lg-table-cell" style="color: var(--vm-text-secondary); font-size: 0.875rem;">
                        <div>@poll.StartTime.ToLocalTime().ToString("MMM dd, h:mm tt")</div>
                        <div>@poll.EndTime.ToLocalTime().ToString("MMM dd, h:mm tt")</div>
                    </td>
                    <td>
                        <div class="table-actions">
                            <a class="btn btn-sm btn-primary" href="/Admin/Polls/Results/@poll.Id" title="Results">
                                <i class="bi bi-bar-chart me-1"></i>Results
                            </a>
                            <a class="btn btn-sm btn-info" href="/Admin/Polls/VoterStatus/@poll.Id" title="Voter Status">
                                <i class="bi bi-people me-1"></i>Status
                            </a>
                            <a class="btn btn-sm" href="/Admin/Polls/Nominees/@poll.Id" title="Nominees"
                               style="background:#f59e0b;color:white;">
                                <i class="bi bi-trophy-fill me-1"></i>Nominees
                            </a>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="true"
                                        data-action-dropdown
                                        aria-expanded="false"
                                        title="More actions">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end p-0 border-0 shadow"
                                    style="min-width:180px;">
                                    <li>
                                        <div class="actions-dropdown-menu">
                                            <button class="btn btn-sm btn-outline-primary" onclick="sharePollLink(@poll.Id)">
                                                <i class="bi bi-link-45deg me-1"></i>Copy Link
                                            </button>
                                            <button class="btn btn-sm btn-success" onclick="sharePollQR(@poll.Id)">
                                                <i class="bi bi-qr-code me-1"></i>QR Code
                                            </button>
                                            <hr />
                                            <a class="btn btn-sm btn-secondary" href="/Admin/Analytics/PollDetails/@poll.Id">
                                                <i class="bi bi-graph-up me-1"></i>Analytics
                                            </a>
                                            @if (status != "Archived")
                                            {
                                                <a class="btn btn-sm btn-warning" href="/Admin/Polls/Edit/@poll.Id">
                                                    <i class="bi bi-pencil me-1"></i>Edit
                                                </a>
                                            }
                                            @if (status == "Active")
                                            {
                                                <a class="btn btn-sm" href="/Admin/Polls/ProxyVote/@poll.Id"
                                                   style="background:#8b5cf6;color:white;">
                                                    <i class="bi bi-person-check me-1"></i>Proxy Vote
                                                </a>
                                                @if (poll.RequireAttendance)
                                                {
                                                    <a class="btn btn-sm btn-primary" href="/Admin/Polls/Attendance/@poll.Id">
                                                        <i class="bi bi-clipboard-check me-1"></i>Attendance
                                                    </a>
                                                }
                                                <hr />
                                                <form method="post" action="/Admin/Polls/End/@poll.Id"
                                                      onsubmit="return confirm('End this poll now? Voting will close immediately.');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm ta-end">
                                                        <i class="bi bi-stop-circle me-1"></i>End Poll
                                                    </button>
                                                </form>
                                            }
                                            @if (status == "Archived")
                                            {
                                                <a class="btn btn-sm btn-success" href="/Admin/Polls/VoterStatus/@poll.Id">
                                                    <i class="bi bi-play-circle me-1"></i>Reactivate
                                                </a>
                                            }
                                            <hr />
                                            @if (status == "Upcoming" || status == "Active")
                                            {
                                                <form method="post" action="/Admin/Polls/Delete/@poll.Id"
                                                      onsubmit="return confirm('Are you sure?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="bi bi-trash me-1"></i>Delete
                                                    </button>
                                                </form>
                                            }
                                            @if (status == "Archived")
                                            {
                                                <button type="button" class="btn btn-sm btn-danger"
                                                        onclick="showArchiveDeleteModal(@poll.Id, '@poll.Title')">
                                                    <i class="bi bi-trash me-1"></i>Delete
                                                </button>
                                            }
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <!-- Mobile Card View -->
    @foreach (var item in Model) {
        var poll = item.Poll;
        var status = item.Status;
        var statusBadgeClass = status switch
        {
            "Active" => "badge bg-success",
            "Archived" => "badge bg-secondary",
            "Upcoming" => "badge bg-info",
            _ => "badge bg-light"
        };

        <div class="poll-card" data-poll-id="@poll.Id" data-start-date="@poll.StartTime.ToString("yyyy-MM-dd")" data-end-date="@poll.EndTime.ToString("yyyy-MM-dd")" style="display:none;">
            <div class="poll-card-title">@poll.Title</div>
            <span class="@statusBadgeClass">@status</span>
            @if (!string.IsNullOrEmpty(poll.Description))
            {
                <div class="poll-card-description">@poll.Description</div>
            }
            <div class="poll-card-meta">
                <i class="bi bi-calendar-event"></i>
                @poll.StartTime.ToLocalTime().ToString("MMM dd, h:mm tt") &ndash; @poll.EndTime.ToLocalTime().ToString("MMM dd, h:mm tt")
            </div>
            <button class="pc-toggle" onclick="toggleCardActions(this)">
                Actions
            </button>
            <div class="poll-card-actions">
                <a class="btn btn-primary" href="/Admin/Polls/Results/@poll.Id">
                    <i class="bi bi-bar-chart me-1"></i>Results
                </a>
                <a class="btn btn-secondary" href="/Admin/Analytics/PollDetails/@poll.Id">
                    <i class="bi bi-graph-up me-1"></i>Analytics
                </a>
                <a class="btn btn-info" href="/Admin/Polls/VoterStatus/@poll.Id">
                    <i class="bi bi-people me-1"></i>Status
                </a>
                <a class="btn" href="/Admin/Polls/Nominees/@poll.Id" style="background:#f59e0b;color:white;">
                    <i class="bi bi-trophy-fill me-1"></i>Nominees
                </a>
                <button class="btn btn-outline-primary" onclick="sharePollLink(@poll.Id)">
                    <i class="bi bi-link-45deg me-1"></i>Copy Link
                </button>
                <button class="btn btn-success" onclick="sharePollQR(@poll.Id)">
                    <i class="bi bi-qr-code me-1"></i>QR Code
                </button>
                @if (status != "Archived")
                {
                    <a class="btn btn-warning" href="/Admin/Polls/Edit/@poll.Id">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                }
                @if (status == "Active")
                {
                    @if (poll.RequireAttendance)
                    {
                        <a class="btn btn-primary" href="/Admin/Polls/Attendance/@poll.Id">
                            <i class="bi bi-clipboard-check me-1"></i>Attendance
                        </a>
                    }
                    <a class="btn" href="/Admin/Polls/ProxyVote/@poll.Id" style="background:#8b5cf6;color:white;">
                        <i class="bi bi-person-check me-1"></i>Proxy Vote
                    </a>
                    <form method="post" action="/Admin/Polls/End/@poll.Id" onsubmit="return confirm('End this poll now? Voting will close immediately.');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn ta-end">
                            <i class="bi bi-stop-circle me-1"></i>End Poll
                        </button>
                    </form>
                }
                @if (status == "Upcoming" || status == "Active")
                {
                    <form class="full" method="post" action="/Admin/Polls/Delete/@poll.Id" onsubmit="return confirm('Are you sure?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                }
                @if (status == "Archived")
                {
                    <a class="btn btn-success" href="/Admin/Polls/VoterStatus/@poll.Id">
                        <i class="bi bi-play-circle me-1"></i>Reactivate
                    </a>
                    <button type="button" class="btn btn-danger btn-full" onclick="showArchiveDeleteModal(@poll.Id, '@poll.Title')">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                }
            </div>
        </div>
    }

    <!-- Pagination -->
    <div class="pagination-container">
        <div class="pagination-info">
            Showing <span id="showingStart">1</span> to <span id="showingEnd">10</span> of <span id="totalItems">@Model.Count()</span> polls
        </div>
        <nav>
            <ul class="pagination" id="pagination">
                <!-- Pagination will be generated by JavaScript -->
            </ul>
        </nav>
    </div>
}

<!-- Share / QR Modal -->
<div class="modal fade" id="shareQrModal" tabindex="-1" aria-labelledby="shareQrModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="shareQrModalLabel">
                    <i class="bi bi-qr-code me-2"></i>Share Poll
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted mb-3">Scan to access the voting page</p>
                <div id="shareQrContainer" class="d-flex justify-content-center mb-3"></div>
                <div class="input-group">
                    <input type="text" class="form-control form-control-sm" id="shareQrLinkInput" readonly>
                    <button class="btn btn-outline-primary btn-sm" onclick="copyFromModal()" title="Copy">
                        <i class="bi bi-clipboard" id="shareQrCopyIcon"></i>
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="downloadShareQR()">
                    <i class="bi bi-download me-2"></i>Download QR
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Archive Delete Modal -->
<div class="modal fade" id="archiveDeleteModal" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="archiveDeleteModalTitle">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="archiveDeleteModalTitle">Delete Archived Poll</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>You are about to delete the archived poll: <strong id="pollTitleModal"></strong></p>
                <p class="text-danger">This action cannot be undone. Please enter your admin credentials to confirm.</p>
                <form id="archiveDeleteForm">
                    <div class="mb-3">
                        <label class="form-label" for="adminUsername">Admin Username</label>
                        <input type="text" class="form-control" id="adminUsername" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="adminPassword">Admin Password</label>
                        <input type="password" class="form-control" id="adminPassword" required />
                    </div>
                    <div id="deleteError" class="alert alert-danger d-none"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="confirmArchiveDelete()">Delete Poll</button>
            </div>
        </div>
    </div>
</div>

<!-- SheetJS library for Excel export -->
<script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>

<script>
let currentArchiveDeleteId = null;
let currentPage = 1;
let itemsPerPage = 10;
let allPolls = [];
let filteredPolls = [];
let pollsData = [];

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
    const pollItems = document.querySelectorAll('.poll-item');
    const pollCards = document.querySelectorAll('.poll-card');
    
    allPolls = Array.from(pollItems).map((item, index) => {
        const title = (item.querySelector('.fw-semibold') || item.querySelector('strong'))?.textContent.trim() ?? '';
        const status = item.querySelector('.badge')?.textContent.trim() ?? '';
        const description = item.querySelector('small.text-muted')?.textContent.trim() ?? '';

        // Dates are stored as data attributes on the row
        const startDateAttr = item.getAttribute('data-start-date');
        const endDateAttr   = item.getAttribute('data-end-date');
        const startDate = startDateAttr ? new Date(startDateAttr) : null;
        const endDate   = endDateAttr   ? new Date(endDateAttr)   : null;
        const timeText  = (startDate && endDate)
            ? `Start: ${startDate.toLocaleDateString()} | End: ${endDate.toLocaleDateString()}`
            : '';

        return {
            element: item,
            card: pollCards[index],
            title: title,
            status: status,
            description: description,
            timeText: timeText,
            startDate: startDate,
            endDate: endDate
        };
    });
    
    // Collect poll data for export
    pollsData = allPolls.map(poll => ({
        'Poll Title': poll.title,
        'Status': poll.status,
        'Description': poll.description,
        'Time Period': poll.timeText
    }));
    
    // Set default date range to current month (same as Dashboard)
    const now = new Date();
    const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
    const lastDay  = new Date(now.getFullYear(), now.getMonth() + 1, 0);
    document.getElementById('dateFrom').value = firstDay.toISOString().split('T')[0];
    document.getElementById('dateTo').value   = lastDay.toISOString().split('T')[0];

    filteredPolls = [...allPolls];
    applyFilters();
});

// Search functionality
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('searchInput')?.addEventListener('input', function(e) {
        applyFilters();
    });
});

function displayPage(page) {
    currentPage = page;
    const start = (page - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    
    // Hide all items
    allPolls.forEach(poll => {
        poll.element.style.display = 'none';
        if (poll.card) poll.card.style.display = 'none';
    });
    
    // Show items for current page
    const itemsToShow = filteredPolls.slice(start, end);
    itemsToShow.forEach(poll => {
        poll.element.style.display = '';
        if (poll.card) poll.card.style.display = '';
    });
    
    // Update pagination info
    document.getElementById('showingStart').textContent = filteredPolls.length > 0 ? start + 1 : 0;
    document.getElementById('showingEnd').textContent = Math.min(end, filteredPolls.length);
    document.getElementById('totalItems').textContent = filteredPolls.length;
    
    updatePaginationButtons();
}

function updatePagination() {
    const totalPages = Math.ceil(filteredPolls.length / itemsPerPage);
    const pagination = document.getElementById('pagination');
    pagination.innerHTML = '';
    
    if (totalPages <= 1) return;
    
    // Previous button
    const prevLi = document.createElement('li');
    prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
    prevLi.innerHTML = `<a class="page-link" href="#" onclick="changePage(${currentPage - 1}); return false;"><i class="bi bi-chevron-left"></i></a>`;
    pagination.appendChild(prevLi);
    
    // Page numbers
    const maxVisible = 5;
    let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
    let endPage = Math.min(totalPages, startPage + maxVisible - 1);
    
    if (endPage - startPage < maxVisible - 1) {
        startPage = Math.max(1, endPage - maxVisible + 1);
    }
    
    if (startPage > 1) {
        const li = document.createElement('li');
        li.className = 'page-item';
        li.innerHTML = `<a class="page-link" href="#" onclick="changePage(1); return false;">1</a>`;
        pagination.appendChild(li);
        
        if (startPage > 2) {
            const dots = document.createElement('li');
            dots.className = 'page-item disabled';
            dots.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dots);
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        const li = document.createElement('li');
        li.className = `page-item ${i === currentPage ? 'active' : ''}`;
        li.innerHTML = `<a class="page-link" href="#" onclick="changePage(${i}); return false;">${i}</a>`;
        pagination.appendChild(li);
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            const dots = document.createElement('li');
            dots.className = 'page-item disabled';
            dots.innerHTML = `<span class="page-link">...</span>`;
            pagination.appendChild(dots);
        }
        
        const li = document.createElement('li');
        li.className = 'page-item';
        li.innerHTML = `<a class="page-link" href="#" onclick="changePage(${totalPages}); return false;">${totalPages}</a>`;
        pagination.appendChild(li);
    }
    
    // Next button
    const nextLi = document.createElement('li');
    nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
    nextLi.innerHTML = `<a class="page-link" href="#" onclick="changePage(${currentPage + 1}); return false;"><i class="bi bi-chevron-right"></i></a>`;
    pagination.appendChild(nextLi);
}

function updatePaginationButtons() {
    updatePagination();
}

function changePage(page) {
    const totalPages = Math.ceil(filteredPolls.length / itemsPerPage);
    if (page < 1 || page > totalPages) return;
    displayPage(page);
}

// Filter by search and date
function applyFilters() {
    const dateFromInput = document.getElementById('dateFrom').value;
    const dateToInput = document.getElementById('dateTo').value;
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    
    const dateFrom = dateFromInput ? new Date(dateFromInput) : null;
    const dateTo = dateToInput ? new Date(dateToInput) : null;
    
    // Set time to end of day for dateTo to include the entire day
    if (dateTo) {
        dateTo.setHours(23, 59, 59, 999);
    }
    
    filteredPolls = allPolls.filter(poll => {
        let matches = true;
        
        // Search filter
        if (searchTerm) {
            const titleMatch = poll.title.toLowerCase().includes(searchTerm);
            const descMatch = poll.description.toLowerCase().includes(searchTerm);
            if (!titleMatch && !descMatch) {
                matches = false;
            }
        }
        
        // Date filter - check if poll's date range overlaps with filter range
        if (dateFrom || dateTo) {
            if (!poll.startDate || !poll.endDate) {
                matches = false;
            } else {
                if (dateFrom && poll.endDate < dateFrom) {
                    matches = false;
                }
                if (dateTo && poll.startDate > dateTo) {
                    matches = false;
                }
            }
        }
        
        return matches;
    });
    
    currentPage = 1;
    updatePagination();
    displayPage(1);
}

function clearFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('dateFrom').value = '';
    document.getElementById('dateTo').value = '';
    
    filteredPolls = [...allPolls];
    currentPage = 1;
    updatePagination();
    displayPage(1);
}

function toggleCardActions(btn) {
    const panel = btn.closest('.poll-card').querySelector('.poll-card-actions');
    const isOpen = panel.classList.toggle('open');
    btn.textContent = isOpen ? 'Close' : 'Actions';
}

function showArchiveDeleteModal(pollId, pollTitle) {
    currentArchiveDeleteId = pollId;
    document.getElementById('pollTitleModal').textContent = pollTitle;
    document.getElementById('adminUsername').value = '';
    document.getElementById('adminPassword').value = '';
    document.getElementById('deleteError').classList.add('d-none');
    
    const modal = new bootstrap.Modal(document.getElementById('archiveDeleteModal'));
    modal.show();
}

function confirmArchiveDelete() {
    const username = document.getElementById('adminUsername').value;
    const password = document.getElementById('adminPassword').value;
    const errorDiv = document.getElementById('deleteError');
    
    if (username === 'admin' && password === 'admin123') {
        const item = document.querySelector(`li[data-poll-id="${currentArchiveDeleteId}"]`);
        if (item) {
            item.style.opacity = '0.5';
            setTimeout(() => {
                item.remove();
                
                // Update polls arrays
                allPolls = allPolls.filter(p => p.element.dataset.pollId !== currentArchiveDeleteId.toString());
                filteredPolls = filteredPolls.filter(p => p.element.dataset.pollId !== currentArchiveDeleteId.toString());
                pollsData = allPolls.map(poll => ({
                    'Poll Title': poll.title,
                    'Status': poll.status,
                    'Description': poll.description,
                    'Time Period': poll.timeText
                }));
                
                updatePagination();
                displayPage(currentPage);
            }, 300);
        }
        
        bootstrap.Modal.getInstance(document.getElementById('archiveDeleteModal')).hide();
        
        const alert = document.createElement('div');
        alert.className = 'alert alert-success alert-dismissible fade show mt-3';
        alert.innerHTML = 'Archived poll deleted successfully (frontend only). <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
        document.querySelector('.container').insertAdjacentElement('afterbegin', alert);
        
        setTimeout(() => alert.remove(), 3000);
    } else {
        errorDiv.classList.remove('d-none');
        errorDiv.textContent = 'Invalid credentials. Please try again.';
    }
}

function exportToExcel() {
    // Export only filtered polls
    const exportData = filteredPolls.map(poll => ({
        'Poll Title': poll.title,
        'Status': poll.status,
        'Description': poll.description,
        'Time Period': poll.timeText
    }));
    
    // Create workbook and worksheet
    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.json_to_sheet(exportData);
    
    // Set column widths
    ws['!cols'] = [
        { wch: 40 }, // Poll Title
        { wch: 12 }, // Status
        { wch: 50 }, // Description
        { wch: 40 }  // Time Period
    ];
    
    // Add worksheet to workbook
    XLSX.utils.book_append_sheet(wb, ws, 'Polls');
    
    // Generate filename with current date
    const now = new Date();
    const filename = `VoteMaster_Polls_${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}.xlsx`;
    
    // Save file
    XLSX.writeFile(wb, filename);
    
    // Show success message
    const alert = document.createElement('div');
    alert.className = 'alert alert-success alert-dismissible fade show mt-3';
    alert.innerHTML = `<i class="bi bi-check-circle me-2"></i>Exported ${exportData.length} poll(s) to Excel successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    document.querySelector('.container').insertAdjacentElement('afterbegin', alert);
    
    setTimeout(() => alert.remove(), 3000);
}

// Initialize action dropdowns with Popper fixed strategy
// This bypasses ALL parent stacking contexts (z-index, overflow, transform)
// and works in every browser including Edge.
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-action-dropdown]').forEach(function(el) {
        new bootstrap.Dropdown(el, {
            popperConfig: {
                strategy: 'fixed'
            }
        });
    });
});

// ── Share: Copy Link ──────────────────────────────────────────────────────
function sharePollLink(pollId) {
    const url = `${location.protocol}//${location.host}/Client/Vote/${pollId}`;
    navigator.clipboard.writeText(url).then(() => {
        showShareToast('Poll link copied to clipboard!');
    }).catch(() => { prompt('Copy this link:', url); });
}

// ── Share: QR Code ────────────────────────────────────────────────────────
function sharePollQR(pollId) {
    const url = `${location.protocol}//${location.host}/Client/Vote/${pollId}`;
    document.getElementById('shareQrLinkInput').value = url;
    const container = document.getElementById('shareQrContainer');
    container.innerHTML = '';
    new QRCode(container, {
        text: url, width: 220, height: 220,
        colorDark: '#0f172a', colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H
    });
    document.getElementById('shareQrCopyIcon').className = 'bi bi-clipboard';
    new bootstrap.Modal(document.getElementById('shareQrModal')).show();
}

function copyFromModal() {
    const val = document.getElementById('shareQrLinkInput').value;
    navigator.clipboard.writeText(val).then(() => {
        const icon = document.getElementById('shareQrCopyIcon');
        icon.className = 'bi bi-check2';
        setTimeout(() => icon.className = 'bi bi-clipboard', 1800);
    });
}

function downloadShareQR() {
    const canvas = document.querySelector('#shareQrContainer canvas');
    if (!canvas) return;
    const a = document.createElement('a');
    a.download = 'poll-qr-code.png';
    a.href = canvas.toDataURL();
    a.click();
}

function showShareToast(msg) {
    const el = document.createElement('div');
    el.className = 'alert alert-success alert-dismissible fade show';
    el.style.cssText = 'position:fixed;top:1.25rem;right:1.25rem;z-index:99999;min-width:240px;box-shadow:0 4px 16px rgba(0,0,0,.12);';
    el.innerHTML = `<i class="bi bi-check-circle me-2"></i>${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 3000);
}
