@model IEnumerable<VoteMaster.Models.TicketTemplate>
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    var list = Model.ToList();
    int perPage = 5;
    int totalPages = (int)Math.Ceiling(list.Count / (double)perPage);
}

<style>
    .templates-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .templates-header h3 {
        margin: 0;
        font-weight: 700;
        color: var(--vm-text-primary);
        font-size: 1.75rem;
    }
    .template-card {
        background: white;
        border: 1px solid var(--vm-border);
        border-radius: 1rem;
        padding: 1.25rem 1.5rem;
        margin-bottom: 0.75rem;
        box-shadow: 0 1px 3px rgba(15,23,42,0.08);
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
    }
    .template-thumb {
        width: 64px;
        height: 64px;
        border-radius: 0.5rem;
        object-fit: cover;
        border: 1px solid var(--vm-border);
        flex-shrink: 0;
    }
    .template-thumb-placeholder {
        width: 64px;
        height: 64px;
        border-radius: 0.5rem;
        background: var(--vm-bg);
        border: 1px dashed var(--vm-border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--vm-text-secondary);
        flex-shrink: 0;
    }
    .template-info { flex: 1; min-width: 150px; }
    .template-info .name { font-weight: 700; color: var(--vm-text-primary); font-size: 1rem; }
    .template-info .meta { font-size: 0.875rem; color: var(--vm-text-secondary); margin-top: 0.25rem; }
    .template-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .pagination-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 1.5rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .pagination-info { font-size: 0.875rem; color: var(--vm-text-secondary); }
</style>

<div class="templates-header">
    <h3><i class="bi bi-layout-text-window me-2"></i>Ticket Templates</h3>
    <a class="btn btn-success" href="/Admin/Templates/Create">
        <i class="bi bi-plus-circle me-2"></i>New Template
    </a>
</div>

@if (!list.Any())
{
    <div class="alert alert-secondary text-center py-5">
        <i class="bi bi-layout-text-window fs-1 d-block mb-3 text-muted"></i>
        <p class="mb-2">No templates yet.</p>
        <a class="btn btn-primary" href="/Admin/Templates/Create">Create your first template</a>
    </div>
}
else
{
    <div id="templateList">
        @for (int i = 0; i < list.Count; i++)
        {
            var t = list[i];
            int pageIdx = i / perPage;
            <div class="template-card" data-page="@pageIdx" style="@(pageIdx == 0 ? "" : "display:none;")">
                @if (!string.IsNullOrEmpty(t.HeaderImagePath))
                {
                    <img src="@t.HeaderImagePath" alt="Header" class="template-thumb" />
                }
                else
                {
                    <div class="template-thumb-placeholder"><i class="bi bi-image fs-4"></i></div>
                }
                <div class="template-info">
                    <div class="name">@t.Name</div>
                    <div class="meta">
                        <i class="bi bi-bar-chart me-1"></i>@(t.Poll?.Title ?? "Unknown Poll")
                        &nbsp;·&nbsp;
                        <i class="bi bi-clock me-1"></i>@t.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                </div>
                <div class="template-actions">
                    <a class="btn btn-primary btn-sm" href="/Admin/Templates/Ticket/@t.Id">
                        <i class="bi bi-eye me-1"></i>View
                    </a>
                    <a class="btn btn-warning btn-sm" href="/Admin/Templates/Edit/@t.Id">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <form method="post" action="/Admin/Templates/Delete/@t.Id" onsubmit="return confirm('Delete this template?');" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash me-1"></i>Delete
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>

}

<div class="mt-4">
    <a class="btn btn-dark" href="/Admin/Dashboard">
        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
    </a>
</div>

@if (list.Count > 0 && totalPages > 1)
{
    <div class="pagination-bar mt-3">
        <div class="pagination-info">
            Showing <span id="showStart">1</span>–<span id="showEnd">@Math.Min(perPage, list.Count)</span> of @list.Count templates
        </div>
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item" id="liPrev">
                    <a class="page-link" href="#" onclick="changePage(-1);return false;"><i class="bi bi-chevron-left"></i></a>
                </li>
                @for (int p = 0; p < totalPages; p++)
                {
                    <li class="page-item @(p == 0 ? "active" : "")" data-pg="@p" id="pgBtn@p">
                        <a class="page-link" href="#" onclick="goPage(@p);return false;">@(p + 1)</a>
                    </li>
                }
                <li class="page-item" id="liNext">
                    <a class="page-link" href="#" onclick="changePage(1);return false;"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    </div>
}

@if (list.Count > perPage)
{
    <script>
    const perPage = @perPage;
    const total = @list.Count;
    const totalPages = @totalPages;
    let cur = 0;

    function goPage(p) {
        document.querySelectorAll('.template-card').forEach(c => c.style.display = 'none');
        document.querySelectorAll('.template-card[data-page="' + p + '"]').forEach(c => c.style.display = '');
        document.querySelectorAll('[data-pg]').forEach(li => li.classList.remove('active'));
        document.getElementById('pgBtn' + p)?.classList.add('active');
        cur = p;
        const start = p * perPage + 1;
        const end = Math.min((p + 1) * perPage, total);
        document.getElementById('showStart').textContent = start;
        document.getElementById('showEnd').textContent = end;
        document.getElementById('liPrev').classList.toggle('disabled', p === 0);
        document.getElementById('liNext').classList.toggle('disabled', p === totalPages - 1);
    }

    function changePage(dir) { goPage(Math.max(0, Math.min(totalPages - 1, cur + dir))); }

    goPage(0);
    </script>
}
